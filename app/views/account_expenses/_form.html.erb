    <div class="modal-body">
     <%= form_with(model: account_expense, method: :post, remote: false) do |form| %>
      

    <div class="row">
         <div class="col-xs-12"> 
           <div id="div-error"></div>
         </div>
                
             <%= form.hidden_field :account_id, placeholder: "", class: "form-control"%>
       
          <div class="col-xs-12">
            <div id="div-error"></div>
            <div class="form-group">
                <%= form.label :amount,'Monto', class: "sr-only" %>
                <div class="input-group">
                
                    <div class="input-group-addon"><i class=" fas fa-dollar-sign"></i></div>
                <%= form.text_field :amount, placeholder: "Monto de gasto efectuado.", class: "form-control" %>
              </div>
            </div>
          </div>
           
          <div class="col-xs-12">
            <div class="form-group">
                <%= form.label :description, class: "sr-only" %>
                 <div class="input-group">
                  <div class="input-group-addon"><i class=" fas fa-info"></i></div>
                  <%= form.text_area :description, placeholder: "Razon motivo del gasto", class: "form-control"%>
                
              </div>

            </div>
          </div>  

        </div>

        <div class="actions">
          <%= form.submit "Registrar", class: "btn btn-success " %>
        </div>
    <% end %>
</div>