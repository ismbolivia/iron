<% if @ban %>
   $("#modalRendicion").modal("hide");
   // Mostrar notificación si tienes SweetAlert o similar
   if (typeof swal === 'function') {
       swal("¡Éxito!", "Transferencia ejecutada correctamente.", "success");
   } else if (typeof toastr !== 'undefined') {
       toastr.success("Transferencia ejecutada correctamente.");
   } else {
       alert("Transferencia ejecutada correctamente.");
   }
   
   // Recargar la página o recargar balances vía AJAX
   setTimeout(function() {
       location.reload();
   }, 1000);
<% else %>
   <% if @account_transfer.errors.any? %>
       $("#div-error-transfer").html('<div class="alert alert-danger" style="border-radius: 8px;"><button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button><ul style="margin: 0; padding-left: 20px;"><% @account_transfer.errors.full_messages.each do |msg| %><li><%= j msg %></li><% end %></ul></div>');
   <% else %>
       $("#div-error-transfer").html('<div class="alert alert-danger" style="border-radius: 8px;"><button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button><i class="fa fa-exclamation-circle"></i> Error al guardar la transferencia.</div>');
   <% end %>
<% end %>
