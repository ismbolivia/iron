<table class="table">
  <thead>
    <tr>
      <th>Descripción</th>
      <th>Monto</th>
      <th>Fecha</th>
      <th colspan="2"></th>
    </tr>
  </thead>
  <tbody>
    <% @account.account_expenses.limit(20).order(created_at: :desc).each do |expense| %>
      <tr>
        <td><%= expense.description %></td>
        <td><%= @account.currency.symbol %><%= expense.amount %></td>
        <td><%= expense.created_at.strftime("%d/%m/%Y") %></td> 
        <% if current_user.is_admin? %>         
           
        <td>
          <%= button_to edit_account_expense_path(expense), {method: :get, class: "btn btn-info"} do %>
            <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> Editar
          <% end %>
        </td> 
         <td><%= link_to 'Destroy', expense, method: :delete, data: { confirm: 'Are you sure?' }, class: "btn btn-danger" %>
         </td>        
          <% end %>
      </tr>
    <% end %>
  </tbody>
</table>


<div class="clearfix"></div>
  <hr>
  <div class="text-right">                                                                         
     <%= link_to  new_account_expense_path(:account_id => @account.id), {method: :get, class: "btn btn-success", remote: true} do %>

     <span class=" " aria-hidden="true">Registrar  </span>
    <% end %>     
  <button id="print" class="btn btn-default btn-outline" type="button"> <span><i class="fa fa-print"></i> Print</span> </button>
</div>