<table class="table">
  <thead>
    <tr>
      <th>N° Recibo</th>
      <th>Monto</th>
      <th>Fecha de pago</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @account.payments.limit(20).order(created_at: :desc).each do |payment| %>
      <tr>
        <td><%= payment.get_num_payment %></td>
        <td><%= @mycompany.get_current_currency.symbol %><%= payment.rode %></td>
        <td><%= payment.created_at.strftime("%d/%m/%Y") %></td>  
           <% if current_user.is_admin? %>       
        <td>
          <%= button_to edit_payment_path(payment), {method: :get, class: "btn btn-info"} do %>
            <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> Editar
          <% end %>
        </td>     
         <td><%= link_to 'Destroy', payment, method: :delete, data: { confirm: 'Are you sure?' },  class: "btn btn-danger" %></td>  
         <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
