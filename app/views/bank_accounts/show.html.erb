<div class="row">
  <div class="col-lg-12">
    <div class="col-lg-1"> </div>
    <div class="col-lg-10">
      <div class="panel panel-success">
        <div class="panel-head">Cuenta Bancaria</div>
            <div class="panel-wrapper collapse in" aria-expanded="true">
              <div class="panel-body">
                <div class="form-body">                  
					<div class="row">
					   <div class = "col-lg-12 col-md-12 col-sm-12" >
					     <div class="col-lg-2 col-md-2 col-sm-2">
					     	<%= link_to banks_path do %>
						        <div class="product-img "> 
						       		<h1 class="big_icon"><i class="fas fa-university"></i></h1>					             
						        </div>
					        <%end%>
					     </div>
					       <div class="col-lg-4 col-md-4 col-sm-4">
					            <div class="form-group">                 
					                <div class="input-group">
					                  <%= link_to @bank_account.bank do %>
					                  <h2 class="m-b-0 m-t-0 m-t-40"><%= @bank_account.bank.name %></h2>	
									  <% end %>					                  	
					                  <h4 class="text-muted db"> <i class="far fa-credit-card"></i> <%= @bank_account.number%></h4>
					                  <h6 class="text-muted db"> <i class=" fas fa-diagnoses"></i> <%= @bank_account.titular %></h6>                 
					                  </div>            
					            </div>
					        </div>
					           <div class="col-lg-6 col-md-4 col-sm-6">
					              <a class="btn btn-app">
					                <span class="badge bg-yellow">50</span>
					                <i class=" fa fa-building"></i> Stock
					              </a>
					              <a class="btn btn-app">
					                <span class="badge bg-green">300</span>
					                <i class="fa fa-barcode"></i> Products
					              </a>
					              <a class="btn btn-app">
					                <span class="badge bg-purple">891</span>
					                <i class="fa fa-users"></i> Users
					              </a>
					              <a class="btn btn-app">
					                <span class="badge bg-teal">67</span>
					                <i class="fa fa-inbox"></i> Orders
					              </a>
					              <a class="btn btn-app">
					                <span class="badge bg-aqua">12</span>
					                <i class="fa fa-envelope"></i> Inbox
					              </a>
					              <a class="btn btn-app">
					                <span class="badge bg-red">531</span>
					                <i class="fa fa-thumbs-up"></i> Likes
					              </a>
					           </div>
					   </div>
					</div>
					<hr>	
					<ul class="nav nav-tabs" role="tablist">
					    <li role="presentation" class="active"><a href="#iprofile" aria-controls="profile" role="tab" data-toggle="tab" aria-expanded="true"><span><i class="far fa-money-bill-alt"></i></span> Depositos</a></li>
					    <li role="presentation" class=""><a href="#payment" aria-controls="home" role="tab" data-toggle="tab" aria-expanded="false"><span><i class="far fa-building text-info"></i></span>Pagos</a></li>					       
					</ul>
					<div class="tab-content">
						 <div role="tabpanel" class="tab-pane active" id="iprofile">
				              <div class="col-md-12 col-sm-12">                                      
				                 <div class="white-box">
				                    <div class="table-responsive" id="deposit_panel_id">
				                      <%= render 'table', bank_account: @bank_account %>
				                     </div>     
				                </div>
				              </div>
				           <div class="clearfix"></div>
						 </div>
					</div>		
							
					<%= link_to 'Editar', edit_bank_account_path(@bank_account), class: 'btn btn-info', remote:true %> 
					<%= link_to 'Depositar', new_deposit_path(bank_account_id:@bank_account.id), class: 'btn btn-success  pull-right ', remote:true %>          
                </div>
            </div>
          </div>
        </div>
      </div>
    <div class="col-lg-1"></div>
 </div>
</div>