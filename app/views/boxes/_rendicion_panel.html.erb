<% 
  # Bucamos cobros pendientes de rendir en esta caja
  pendientes = Payment.where(box_id: box.id, state: :draft).order(created_at: :desc)
%>

<div class="panel panel-default" style="border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
    <div class="panel-heading" style="background: white; border-bottom: 2px solid #f1f5f9; padding: 20px; border-radius: 12px 12px 0 0;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; font-weight: 800; color: #1e293b;">📋 Cobros por Rendir / Arqueo</h3>
            <span class="label label-warning" style="font-size: 0.9rem; padding: 5px 10px; border-radius: 20px;"><span id="pendientes_count_value"><%= pendientes.count %></span> Pendientes</span>
        </div>
    </div>
    
    <div class="panel-body" style="padding: 15px;">
        <% if pendientes.any? %>
            <div class="table-responsive">
                <table class="table table-hover" id="tabla_rendicion" style="margin-bottom: 0;">
                    <thead style="background: #f8fafc;">
                        <tr>
                            <th style="font-weight: 700; color: #64748b;">Recibo #</th>
                            <th style="font-weight: 700; color: #64748b;">Cliente / Venta</th>
                            <th style="font-weight: 700; color: #64748b; text-align: right;">Monto</th>
                            <th style="font-weight: 700; color: #64748b; text-align: center;">Tipo</th>
                            <th style="font-weight: 700; color: #64748b; text-align: center;">Accines</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pendientes.each do |p| %>
                            <tr id="payment_row_<%= p.id %>" style="transition: all 0.3s;">
                                <td style="vertical-align: middle; font-weight: 600; color: #475569;">#<%= p.get_num_payment %></td>
                                <td style="vertical-align: middle;">
                                    <div style="font-weight: 700; color: #1e293b;"><%= p.sale.client.name rescue 'Sin Cliente' %></div>
                                    <small class="text-muted">Venta #<%= p.sale_id %></small>
                                </td>
                                <td style="vertical-align: middle; font-weight: 800; color: #10b981; text-align: right;">
                                    <%= p.rode %> <%= box.currency.symbol %>
                                </td>
                                <td style="vertical-align: middle; text-align: center;">
                                    <span class="label label-default" style="border-radius: 12px;"><%= p.payment_type.nethod rescue 'Desconocido' %></span>
                                </td>
                                <td style="vertical-align: middle; text-align: center;">
                                    <% if current_user.is_admin? || current_user.is_manager? %>
                                        <%= link_to approve_payment_path(p), method: :post, remote: true, class: "btn btn-success btn-sm", style: "border-radius: 20px; font-weight: 700; padding: 4px 12px; background: #10b981; border: none;", onclick: "this.style.opacity='0.5'; this.innerText='Aprobando...';" do %>
                                            <i class="fas fa-check"></i> Aprobar
                                        <% end %>
                                        <button type="button" class="btn btn-danger btn-sm" style="border-radius: 20px; font-weight: 700; padding: 4px 12px; background: #ef4444; border: none; margin-left: 5px;" onclick="cargarRechazo('<%= p.id %>', '<%= p.get_num_payment %>');">
                                            <i class="fas fa-times"></i> Rechazar
                                        </button>
                                    <% else %>
                                        <span class="label label-warning" style="border-radius: 12px; font-size: 0.8rem;"><i class="fas fa-clock"></i> Esperando Arqueo</span>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% else %>
            <div style="text-align: center; padding: 40px; color: #94a3b8;">
                <i class="fas fa-check-circle fa-4x" style="color: #10b981; margin-bottom: 15px; opacity: 0.7;"></i>
                <h4 style="font-weight: 700; color: #475569;">¡Todo al día!</h4>
                <p style="margin: 0;">No hay cobros pendientes de rendir en esta caja.</p>
            </div>
        <% end %>

        <!-- 📊 Resumen de Comisiones (Cajas de Ruta) -->
        <% if box.ruta? || box.sucursal_ruta? %>
          <%
            # Cobros de esta caja por liquidar
            cobros_pendientes = Payment.where(box_id: box.id, state: :draft)
            total_recaudado = cobros_pendientes.sum(:rode).to_f.round(2)
            total_comisiones = cobros_pendientes.sum(:commission_amount).to_f.round(2)
          %>
          <% if total_recaudado > 0 %>
            <div class="row" style="margin: 20px 0; padding: 15px; background: #fafafa; border-radius: 8px; border: 1px solid #eee;">
                <div class="col-md-4">
                    <small style="color: #64748b; font-weight: 700; display: block;">Recaudado en Auditoría</small>
                    <strong style="font-size: 1.4rem; color: #1e293b;"><%= box.currency.symbol %> <%= number_with_precision(total_recaudado, precision: 2) %></strong>
                </div>
                <div class="col-md-4">
                    <small style="color: #0c4a6e; font-weight: 700; display: block; background: #e0f2fe; padding: 3px 8px; border-radius: 4px; display: inline-block;">Comisiones del Vendedor</small>
                    <strong style="font-size: 1.4rem; color: #0284c7; display: block; margin-top: 5px;"><%= box.currency.symbol %> <%= number_with_precision(total_comisiones, precision: 2) %></strong>
                </div>
                <div class="col-md-4">
                    <small style="color: #166534; font-weight: 700; display: block; background: #dcfce7; padding: 3px 8px; border-radius: 4px; display: inline-block;">Monto Neto Sugerido</small>
                    <strong style="font-size: 1.4rem; color: #10b981; display: block; margin-top: 5px;"><%= box.currency.symbol %> <%= number_with_precision((total_recaudado - total_comisiones), precision: 2) %></strong>
                </div>
            </div>
          <% end %>
        <% end %>

        <% if current_user.is_admin? || current_user.is_manager? %>
        <!-- 💸 Botón de Rendición a Caja General -->
        <hr style="margin: 20px 0;">
        <div class="text-right">
            <% if box.saldo.to_f > 0 %>
                <button type="button" class="btn btn-warning btn-lg" style="border-radius: 8px; font-weight: 700; background: #f59e0b; border: none;" data-toggle="modal" data-target="#modalRendicion">
                    <i class="fas fa-exchange-alt m-r-10"></i> Rendir Saldo a Caja General ($ <span id="rendir_saldo_value"><%= number_with_precision(box.saldo, precision: 2) %></span>)
                </button>
            <% end %>
        </div>
        <% else %>
          <hr style="margin: 20px 0;">
          <div class="text-right text-muted" style="font-weight: 600;">
            <% if box.saldo.to_f > 0 %>
                <i class="fas fa-info-circle text-info"></i> Tienes <strong>$ <%= number_with_precision(box.saldo, precision: 2) %></strong> en tu caja esperando a ser recibidos en matriz. Entrega y pide la aprobación al cajero.
            <% end %>
          </div>
        <% end %>
    </div>
</div>

<% if current_user.is_admin? || current_user.is_manager? %>
<!-- Modal para Rendición de Saldo -->
<div class="modal fade" id="modalRendicion" tabindex="-1" role="dialog" aria-labelledby="modalRendicionLabel">
  <div class="modal-dialog" role="document" style="width: 100%; max-width: 500px;">
    <div class="modal-content" style="border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: none;">
      <div class="modal-header" style="background: #f8fafc; border-radius: 12px 12px 0 0; border-bottom: 1px solid #e2e8f0; padding: 20px;">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="modalRendicionLabel" style="font-weight: 800; color: #1e293b;">🏢 Rendición a Caja General</h4>
      </div>
      <%= form_with(model: AccountTransfer.new, url: account_transfers_path, method: :post, remote: true) do |f| %>
        <%= f.hidden_field :from_box_id, value: box.id %>
        <div class="modal-body" style="padding: 25px;">
            <div id="div-error-transfer"></div> <!-- Contenedor para mostrar Errores -->
            
            <div class="row">
                <!-- Saldo a Entregar -->
                <div class="col-md-12" style="margin-bottom: 15px;">
                    <div class="form-group">
                        <label style="font-weight: 700; color: #475569; display: block; margin-bottom: 8px;">💰 Saldo a Entregar:</label>
                        <div class="input-group">
                            <span class="input-group-addon" style="background: #f1f5f9; font-weight: 700; color: #475569;"><%= box.currency.symbol %></span>
                            <%= f.text_field :amount, value: box.saldo.to_f.round(2), class: "form-control input-lg", style: "font-size: 1.6rem; font-weight: 800; text-align: right; color: #10b981; background: #f8fafc; border-radius: 0 6px 6px 0;", readonly: true %>
                        </div>
                    </div>
                </div>

                <!-- Caja de Destino -->
                <div class="col-md-12" style="margin-bottom: 15px;">
                    <div class="form-group">
                        <label style="font-weight: 700; color: #475569; display: block; margin-bottom: 8px;">📥 Caja de Destino (Matriz):</label>
                        <% core_boxes = Box.where(box_type: Box.box_types.values_at(:central_matriz, :central_sucursal)).where(currency_id: box.currency_id) %>
                        <%= f.select :to_box_id, core_boxes.map { |b| [b.name, b.id] }, { include_blank: '--- Seleccionar Caja ---' }, { class: "form-control input-lg custom-select", required: true, style: "font-weight: 600;" } %>
                    </div>
                </div>

                <!-- Comentario -->
                <div class="col-md-12">
                    <div class="form-group">
                        <label style="font-weight: 700; color: #475569; display: block; margin-bottom: 8px;">📝 Comentario:</label>
                        <%= f.text_area :note, class: "form-control", rows: 3, placeholder: "Ej. Rendición del día #{Date.today.strftime('%d/%m/%y')}", style: "border-radius: 8px;" %>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer" style="padding: 15px 25px; border-top: 1px solid #e2e8f0; background: #f8fafc; border-radius: 0 0 12px 12px;">
            <button type="button" class="btn btn-default" data-dismiss="modal" style="border-radius: 8px; font-weight: 600;">Cancelar</button>
            <%= f.submit "✅ Confirmar Entrega", class: "btn btn-success btn-lg", style: "font-weight: 800; border-radius: 8px; padding: 10px 20px; background: #10b981; border: none;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<!-- Modal para Rechazar Pago -->
<div class="modal fade" id="modalRechazo" tabindex="-1" role="dialog" aria-labelledby="modalRechazoLabel">
  <div class="modal-dialog" role="document" style="width: 100%; max-width: 450px;">
    <div class="modal-content" style="border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: none;">
      <div class="modal-header" style="background: #fef2f2; border-radius: 12px 12px 0 0; border-bottom: 1px solid #fee2e2; padding: 20px;">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" style="font-weight: 800; color: #991b1b;"><i class="fas fa-ban m-r-10"></i> Rechazar Cobro #<span id="txt_num_payment"></span></h4>
      </div>
      <form id="form_rechazo" action="" method="post" data-remote="true">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="modal-body" style="padding: 20px;">
            <div class="form-group">
                <label style="font-weight: 700; color: #475569; display: block; margin-bottom: 8px;">📝 Motivo de rechazo / Discrepancia:</label>
                <textarea name="audit_note" id="audit_note_input" class="form-control" rows="3" required placeholder="Ej: Faltan $5, billete falso, etc." style="border-radius: 8px;"></textarea>
            </div>
        </div>
        <div class="modal-footer" style="padding: 15px 25px; border-top: 1px solid #e2e8f0; background: #f8fafc; border-radius: 0 0 12px 12px;">
          <button type="button" class="btn btn-default" data-dismiss="modal" style="border-radius: 8px; font-weight: 600;">Cancelar</button>
          <button type="submit" class="btn btn-danger" style="background: #ef4444; border: none; font-weight: 700; border-radius: 8px; padding: 8px 16px;" data-disable-with="Rechazando...">Confirmar Rechazo</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Estilo para que desaparezca la fila con animación cuando sea aprobada -->
<script>
// Manejar respuestas exitosas de AJAX
$(document).on('ajax:success', 'a[data-remote], form[data-remote]', function() {
    $(this).closest('tr').fadeOut(400, function() {
        $(this).remove();
    });
    // Si fue el modal, cerrarlo
    if ($(this).attr('id') === 'form_rechazo') {
        $('#modalRechazo').modal('hide');
    }
});

function cargarRechazo(id, num) {
    $('#audit_note_input').val(''); // vaciar nota
    $('#txt_num_payment').text(num);
    $('#form_rechazo').attr('action', '/payments/' + id + '/reject');
    $('#modalRechazo').modal('show');
}

$(document).ready(function() {
    $('#modalRendicion').appendTo('body');
    $('#modalRechazo').appendTo('body');
});
</script>
