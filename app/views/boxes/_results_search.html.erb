<div class="row">
    <% if @boxes.any? %>
        <% @boxes.each do |box| %>
            <% 
              # Definir colores para cada tipo de caja
              type_colors = {
                'central_matriz' => '#db2777',     # Rosa fuerte (Matriz)
                'central_sucursal' => '#7c3aed',   # Violeta (Sucursal)
                'almacen_matriz' => '#ea580c',     # Naranja (Almacén)
                'ruta' => '#0284c7',              # Azul (Ruta)
                'sucursal_ruta' => '#059669',     # Esmeralda (Ruta Sucursal)
                'caja_chica' => '#d97706'          # Ámbar (Caja Chica)
              }
              color_type = type_colors[box.box_type] || '#64748b'
            %>
            <div class="col-lg-3 col-md-4 col-sm-6 col-xs-12 m-b-20">
                <div class="white-box" style="border-radius: 16px; transition: all 0.3s ease; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 25px; border: 1px solid #e2e8f0; position: relative; overflow: hidden; background: white;">
                    
                    <!-- Decoración Superior según Activa/Inactiva -->
                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: <%= box.active ? '#10b981' : '#ef4444' %>;"></div>

                    <div class="row" style="min-height: 95px;">
                        <div class="col-xs-8">
                            <!-- Código de la Caja -->
                            <% if box.code.present? %>
                                <span class="badge" style="background: #e2e8f0; color: #475569; font-weight: 800; border-radius: 4px; font-size: 0.85rem; margin-bottom: 5px; padding: 4px 8px;"><%= box.code %></span>
                            <% end %>

                            <h3 style="font-weight: 800; color: #1e293b; margin-top: 4px; font-size: 1.4rem; letter-spacing: -0.025em;">
                                <i class="fas fa-cash-register" style="color: #64748b; margin-right: 8px; font-size: 1.15rem;"></i> <%= box.name %>
                            </h3>
                            <p class="text-muted" style="font-size: 0.95rem; margin-top: 6px; margin-bottom: 0;"><%= box.description || 'Sin descripción' %></p>
                        </div>
                        <div class="col-xs-4 text-right">
                             <span class="label" style="background-color: <%= color_type %>; border-radius: 20px; font-weight: 700; padding: 5px 12px; font-size: 0.85rem; color: white; display: inline-block;">
                                <%= box.box_type&.titleize || "General" %>
                             </span>
                        </div>
                    </div>

                    <!-- Visualización del Saldo Actual -->
                    <div class="row m-t-15" style="margin-top: 15px;">
                        <div class="col-xs-12">
                            <div style="background: #f8fafc; padding: 15px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #f1f5f9;">
                                <span style="font-weight: 700; color: #475569; font-size: 1rem;">💰 Saldo</span>
                                <strong style="font-size: 1.5rem; font-weight: 800; color: #10b981; letter-spacing: -0.025em;">
                                    <%= box.currency.symbol %> <%= number_with_precision(box.saldo, precision: 2) %>
                                </strong>
                            </div>
                        </div>
                    </div>

                    <!-- Datos Secundarios -->
                    <div class="row m-t-12" style="margin-top: 12px; font-size: 0.95rem;">
                        <div class="col-xs-12">
                            <% if box.parent_box %>
                                <span style="font-weight: 600; color: #64748b;"><i class="fas fa-sitemap text-muted"></i> Rinde a:</span>
                                <strong style="color: #1e293b;"><%= box.parent_box.name %></strong>
                            <% else %>
                                <span style="font-weight: 600; color: #64748b;"><i class="fas fa-circle" style="font-size: 0.5rem; vertical-align: middle; color: <%= box.active ? '#10b981' : '#ef4444' %>;"></i> Estado:</span>
                                <strong style="color: <%= box.active ? '#10b981' : '#ef4444' %>"><%= box.active ? "Activa" : "Inactiva" %></strong>
                            <% end %>
                        </div>
                    </div>

                    <hr style="border-color: #f1f5f9; margin: 15px 0 12px 0;">

                    <!-- Botones de Acción -->
                    <div class="row">
                        <div class="col-xs-12" style="display: flex; gap: 8px; justify-content: flex-end;">
                            <%= link_to box, class: "btn btn-success btn-sm", style: "border-radius: 8px; font-weight: 700; display: flex; align-items: center; gap: 5px; background: #10b981; border: none; padding: 8px 16px; font-size: 0.85rem;" do %>
                                <i class="fas fa-eye"></i> Ver
                            <% end %>
                            
                            <%= link_to edit_box_path(box), class: "btn btn-default btn-sm", style: "border-radius: 8px; font-weight: 700; display: flex; align-items: center; gap: 5px; border: 1px solid #cbd5e1; color: #334155; padding: 8px 16px; background: white; font-size: 0.85rem;" do %>
                                <i class="fas fa-edit"></i> Editar
                            <% end %>

                            <% if current_user.is_admin? %>
                                <%= link_to box, method: :delete, data: { confirm: '¿Estás seguro de eliminar esta caja?' }, class: "btn btn-danger btn-sm", style: "border-radius: 8px; font-weight: 700; padding: 8px 14px; background: #ef4444; border: none; font-size: 0.85rem;" do %>
                                    <i class="fas fa-trash-alt"></i>
                                <% end %>
                            <% end %>
                        </div>
                    </div>

                </div>
            </div>
        <% end %>
    <% else %>
        <div class="col-md-12 text-center text-muted" style="padding: 4rem;">
            <i class="fas fa-cash-register fa-4x" style="color: #e2e8f0; margin-bottom: 15px;"></i>
            <h3 style="font-weight: 800; color: #475569;">No hay cajas registradas</h3>
            <p>Crea una caja para empezar a recibir transacciones.</p>
        </div>
    <% end %>
</div>

<style>
  .white-box:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 20px -3px rgba(0,0,0,0.1) !important;
      border-color: #cbd5e1 !important;
  }
</style>
