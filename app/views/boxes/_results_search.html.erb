<table class="table">
  <thead>
    <tr>
 <!-- aqui paginación -->
    </tr>
    <tr>
      <th>Nombre </th>
      <th>Description</th>
      <th>Moneda</th>
      <th>Activo</th>

      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
   <% @boxes.each do |box| %>
      <tr>
      <td><%= box.name %></td>
       <td><%= box.description %></td>
        <td><%= box.currency.get_full_name %></td>
        <td><%= box.active %></td>
        <td><%= link_to 'Show', box  , class: "btn btn-success"%></td>
        <td><%= link_to 'Edit', edit_box_path(box), class: "btn btn-primary"%></td>
        <td><%= link_to 'Destroy', box, method: :delete, data: { confirm: 'Are you sure?' } , class: "btn btn-danger"%></td>
      </tr>
    <% end %>
  </tbody>
</table>



