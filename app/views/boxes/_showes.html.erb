<div class="row m-b-30">
    <!-- Columna Izquierda: Información de la Caja -->
    <div class="col-lg-5 col-md-5 col-sm-12">
        <div style="display: flex; align-items: center; gap: 20px;">
            <div style="background: #f1f5f9; padding: 20px; border-radius: 12px;">
                <%= image_tag('box_icon.png', alt: "Caja", style: "width: 60px; height: auto;") rescue content_tag(:i, "", class: "fas fa-cash-register fa-3x text-muted") %>              
            </div>
            <div>
                <h2 style="font-weight: 800; color: #1e293b; margin: 0; display: flex; align-items: center; gap: 8px;">
                    <%= @box.name %>
                    <% if @box.code.present? %>
                        <span style="font-size: 0.9rem; background: #e2e8f0; color: #475569; padding: 2px 6px; border-radius: 4px; font-weight: 600;"><%= @box.code %></span>
                    <% end %>
                </h2>
                <p class="text-muted" style="margin: 4px 0 8px 0; font-size: 1rem;"><i class="fas fa-list-ul"></i> <%= @box.description.present? ? @box.description : 'Sin descripción asignada.' %></p>
                <div style="display: flex; gap: 5px;">
                    <span class="label label-info" style="font-weight: 700; border-radius: 4px;"><%= @box.currency.get_full_name %> (<%= @box.currency.symbol %>)</span>
                    <% 
                      type_colors = {
                        'central_matriz' => '#db2777',     # Rosa fuerte
                        'central_sucursal' => '#7c3aed',   # Violeta
                        'almacen_matriz' => '#ea580c',     # Naranja
                        'ruta' => '#0284c7',              # Azul
                        'sucursal_ruta' => '#059669',     # Esmeralda
                        'caja_chica' => '#d97706'          # Ámbar
                      }
                      color_type = type_colors[@box.box_type] || '#64748b'
                    %>
                    <span class="label" style="background-color: <%= color_type %>; font-weight: 700; border-radius: 4px; color: white;">
                        <%= @box.box_type&.titleize || "General" %>
                    </span>

                    <% if @box.parent_box %>
                        <span style="font-size: 0.85rem; color: #64748b; margin-left: 8px;">
                            <i class="fas fa-sitemap"></i> Reporta a: <strong style="color: #334155;"><%= @box.parent_box.name %></strong>
                        </span>
                    <% end %>
                </div>
            </div>
        </div>
    </div>

    <!-- Columna Derecha: Acciones Rápidas -->
    <div class="col-lg-7 col-md-7 col-sm-12 text-right">
        <%= link_to boxes_path, class: "btn btn-default", style: "border-radius: 8px; font-weight: 700;" do %>
            <i class="fas fa-arrow-left"></i> Volver
        <% end %>
        <%= link_to edit_box_path(@box), class: "btn btn-warning", style: "border-radius: 8px; font-weight: 700; color: white; background: #f59e0b; border: none; margin-left:8px;" do %>
            <i class="fas fa-pencil-alt"></i> Editar Caja
        <% end %>
    </div>
</div>

<!-- 📊 Tarjetas de KPIs (Saldos y Totales) -->
<div class="row">
    <div class="col-lg-3 col-md-6 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #0ea5e9; color: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);">
            <h4 class="text-white" style="margin-top: 0; font-weight: 700;">💰 Saldo Actual</h4>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 15px;">
                <i class="fas fa-wallet fa-2x" style="opacity: 0.8;"></i>
                <h2 class="text-white" style="font-weight: 800; margin: 0; font-size: 1.8rem;"><span id="kpi_saldo_value"><%= @box.saldo %></span> <%= @box.currency.symbol %></h2>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #10b981; color: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.15);">
            <h4 class="text-white" style="margin-top: 0; font-weight: 700;">📥 Total Entradas</h4>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 15px;">
                <i class="fas fa-arrow-circle-up fa-2x" style="opacity: 0.8;"></i>
                <h2 class="text-white" style="font-weight: 800; margin: 0; font-size: 1.8rem;"><span id="kpi_entradas_value"><%= @box.totalInput %></span> <%= @box.currency.symbol %></h2>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #a855f7; color: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 12px rgba(168, 85, 247, 0.15);">
            <h4 class="text-white" style="margin-top: 0; font-weight: 700;">📤 Total Salidas</h4>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 15px;">
                <i class="fas fa-arrow-circle-down fa-2x" style="opacity: 0.8;"></i>
                <h2 class="text-white" style="font-weight: 800; margin: 0; font-size: 1.8rem;"><%= @box.totalOutput %> <%= @box.currency.symbol %></h2>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #64748b; color: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 12px rgba(100, 116, 139, 0.15);">
            <h4 class="text-white" style="margin-top: 0; font-weight: 700;">👥 Cajeros Asignados</h4>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 15px;">
                <i class="fas fa-user-friends fa-2x" style="opacity: 0.8;"></i>
                <h2 class="text-white" style="font-weight: 800; margin: 0; font-size: 1.8rem;"><%= @box.box_users.activo.count %></h2>
            </div>
        </div>
    </div>
</div>
<hr style="border-color: #f1f5f9; margin: 10px 0 25px 0;"> 