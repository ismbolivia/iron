<style>
.custom-form-field {
  margin-bottom: 2.5rem;
}

.custom-label {
  display: block;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 1rem;
  font-size: 1.4rem;
  letter-spacing: -0.3px;
}

.custom-input {
  width: 100%;
  padding: 16px 20px;
  border: 2.5px solid #e2e8f0;
  border-radius: 16px;
  background: #f8fafc;
  font-size: 1.4rem;
  transition: all 0.2s ease;
  color: #0f172a;
  font-weight: 600;
}

.custom-input:focus {
  background: white;
  border-color: #2563eb;
  box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.1);
  outline: none;
}

.image-upload-wrapper {
  margin-bottom: 2.5rem;
}

.image-preview-card {
  border: 3px dashed #cbd5e1;
  border-radius: 20px;
  padding: 1.25rem;
  text-align: center;
  background: #f8fafc;
  transition: all 0.2s;
  cursor: pointer;
  max-width: 100%;
}

.image-preview-card:hover {
  border-color: #2563eb;
  background: white;
}

.image-preview-container {
  width: 100%;
  height: 240px;
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e2e8f0;
  position: relative;
  margin-bottom: 1.25rem;
}

.image-preview-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  opacity: 0;
  transition: opacity 0.2s;
  font-weight: 800;
  font-size: 1.2rem;
  border-radius: 16px;
}

.image-preview-card:hover .upload-overlay {
  opacity: 1;
}

.btn-upload {
  background: white;
  color: #1e293b;
  border: 2px solid #e2e8f0;
  padding: 12px 24px;
  border-radius: 14px;
  font-size: 1.15rem;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: all 0.2s;
}

.image-preview-card:hover .btn-upload {
  border-color: #2563eb;
  color: #2563eb;
}

.form-actions {
  display: flex;
  gap: 20px;
  margin-top: 3rem;
  border-top: 3px solid #e2e8f0;
  padding-top: 2.5rem;
}

.btn-submit {
  background: #1e3a8a;
  color: white;
  padding: 16px 32px;
  border-radius: 16px;
  font-weight: 900;
  border: none;
  font-size: 1.3rem;
  transition: all 0.2s;
  box-shadow: 0 4px 12px rgba(30, 58, 138, 0.2);
  cursor: pointer;
}

.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(30, 58, 138, 0.3);
  background: #1d4ed8;
}

.btn-cancel {
  background: #f1f5f9;
  color: #1e293b;
  padding: 16px 32px;
  border-radius: 16px;
  font-weight: 800;
  text-decoration: none !important;
  font-size: 1.3rem;
  display: inline-flex;
  align-items: center;
  transition: all 0.2s;
}

.btn-cancel:hover {
  background: #e2e8f0;
  color: #0f172a;
}
</style>

<%= form_with(model: category, local: true) do |f| %>
  <% if category.errors.any? %>
    <div class="alert alert-danger" style="border-radius: 12px; margin-bottom: 2rem;">
      <h4 style="font-weight:700; font-size: 1rem; margin-bottom: 0.5rem;"><i class="fas fa-exclamation-circle mr-2"></i> Error al guardar la categoría:</h4>
      <ul style="margin-left: 20px; font-size: 0.9rem; margin-bottom: 0;">
        <% category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-7">
      <div class="custom-form-field">
        <%= f.label :name, "Nombre de la Categoría", class: "custom-label" %>
        <%= f.text_field :name, autofocus: true, placeholder: "Ej. Pinturas, Ferretería, Herramientas", class: "custom-input" %>
      </div>
    </div>

    <div class="col-md-5">
      <div class="custom-form-field">
        <label class="custom-label">Imagen de la Categoría</label>
        <%= render partial: 'form_image', locals: { f: f, category: category } %>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit @category.new_record? ? "Crear Categoría" : "Guardar Cambios", class: "btn-submit" %>
    <%= link_to 'Cancelar', categories_path, class: "btn-cancel" %>
  </div>
<% end %>

