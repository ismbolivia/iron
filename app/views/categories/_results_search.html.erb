
<style>
.category-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 1.5rem;
  margin-top: 1.25rem;
}

.category-card {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.02);
  border: 1px solid #f1f5f9;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.category-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  border-color: #e2e8f0;
}

.category-img-container {
  width: 100%;
  height: 170px;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  border-bottom: 2px solid #f1f5f9;
}

.category-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s;
}

.category-card:hover .category-img {
  transform: scale(1.04);
}

.category-placeholder {
  font-size: 5rem;
  color: #cbd5e1;
  opacity: 0.7;
}

.category-body {
  padding: 1.4rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category-name {
  font-size: 1.55rem;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 0.5rem;
  letter-spacing: -0.4px;
  line-height: 1.25;
}

.category-stats {
  font-size: 1.15rem;
  color: #475569;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 0.4rem;
  font-weight: 600;
}

.category-date {
  font-size: 0.95rem;
  color: #64748b;
  margin-top: 4px;
  font-weight: 500;
}

.category-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  padding-top: 1.25rem;
  border-top: 1.8px solid #f8fafc;
  margin-top: 1.5rem;
}

.btn-action {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  transition: all 0.2s ease;
  cursor: pointer;
  border: 1px solid transparent;
}

/* Colores suaves por defecto */
.btn-action.btn-view {
  background: #eff6ff; 
  color: #2563eb; 
  border-color: #dbeafe;
}

.btn-action.btn-edit {
  background: #f0fdf4; 
  color: #16a34a; 
  border-color: #dcfce7;
}

.btn-action.btn-delete {
  background: #fef2f2; 
  color: #dc2626; 
  border-color: #fecaca;
}

.btn-action:hover {
  transform: translateY(-3px);
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.btn-action.btn-view:hover { background: #dbeafe; color: #1d4ed8; }
.btn-action.btn-edit:hover { background: #dcfce7; color: #15803d; }
.btn-action.btn-delete:hover { background: #fecaca; color: #b91c1c; }

.empty-state {
  text-align: center;
  padding: 4rem 2rem;
  background: white;
  border-radius: 16px;
  border: 3px dashed #e2e8f0;
  color: #475569;
}
</style>

<div class="pager-wrapper" style="display: flex; justify-content: flex-end; margin-bottom: 0.5rem;">
  <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
</div>

<% if @categories.any? %>
  <div class="category-grid">
    <% @categories.each do |category| %>
      <div class="category-card">
        <div class="category-img-container">
          <% if category.pictures.present? && category.pictures.url.present? %>
            <%= image_tag category.pictures.url, class: "category-img" %>
          <% else %>
            <div class="category-placeholder">
              <i class="fas fa-folder-open"></i>
            </div>
          <% end %>
        </div>
        <div class="category-body">
          <div>
            <div class="category-name"><%= category.name %></div>
            <div class="category-stats">
              <i class="fas fa-boxes" style="color: #3b82f6;"></i> 
              <span style="font-weight: 600; color: #334155;"><%= category.items.count %></span> artículos
            </div>
            <div class="category-date">
              Actualizado: <%= category.updated_at.strftime("%d/%m/%Y") %>
            </div>
          </div>
          
          <div class="category-actions">
            <%= link_to category_path(category), class: "btn-action btn-view", title: "Ver Detalle" do %>
              <i class="fas fa-eye"></i>
            <% end %>
            <%= link_to edit_category_path(category), class: "btn-action btn-edit", title: "Editar" do %>
              <i class="fas fa-edit"></i>
            <% end %>
            <%= button_to category, method: :delete, data: { confirm: '¿Está seguro de eliminar esta categoría?' }, class: "btn-action btn-delete", title: "Eliminar", form_class: 'm-0' do %>
              <i class="fas fa-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
    <h3 style="font-weight: 700; color: #334155; margin-bottom: 0.5rem;">No se encontraron categorías</h3>
    <p style="margin-bottom: 1.5rem;">Intente con otros términos de búsqueda o cree una nueva categoría.</p>
    <%= link_to new_category_path, class: "btn btn-primary", style: "border-radius: 12px; font-weight: 600; padding: 10px 20px;" do %>
      <i class="fas fa-plus"></i> Nueva Categoría
    <% end %>
  </div>
<% end %>

<div class="pager-wrapper" style="display: flex; justify-content: flex-end; margin-top: 1.5rem;">
  <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
</div>