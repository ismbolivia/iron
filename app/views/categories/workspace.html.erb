/* AMOLED Black */
.premium-dashboard.theme-amoled, body.theme-amoled .premium-dashboard {
  --bg-color: #000000;
  --panel-bg: #000000;
  --text-primary: #ffffff;
  --text-secondary: #a1a1aa;
  --border-color: #27272a;
