<style>
/* Variables por defecto (Modo Claro) */
.premium-dashboard {
  --bg-color: #f4f7fa;
  --panel-bg: #ffffff;
  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --border-color: #f1f5f9;
  --node-hover: #f8fafc;
  --node-active: #f0f7ff;
  --node-active-text: #1d4ed8;
  --scrollbar: #e2e8f0;
  
  transition: background 0.3s, color 0.3s;
}

/* Slate Dark */
.premium-dashboard.theme-dark-slate, body.theme-dark-slate .premium-dashboard {
  --bg-color: #0f172a;
  --panel-bg: #1e293b;
  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;
  --border-color: #334155;
