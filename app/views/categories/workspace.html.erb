  --node-active-text: #60a5fa;
  --scrollbar: #475569;
}

/* Verde Oscuro (Bosque) */
.premium-dashboard.theme-dark-green, body.theme-dark-green .premium-dashboard {
  --bg-color: #040d0a;
  --panel-bg: #0b1c15;
  --text-primary: #f0fdf4;
  --text-secondary: #a7f3d0;
  --border-color: #064e3b;
  --node-hover: rgba(16, 185, 129, 0.05);
  --node-active: rgba(16, 185, 129, 0.15);
  --node-active-text: #34d399;
  --scrollbar: #065f46;
}

/* Violeta Oscuro */
.premium-dashboard.theme-cyber-purple, body.theme-cyber-purple .premium-dashboard {
  --bg-color: #0a0514;
  --panel-bg: #120924;
  --text-primary: #faf5ff;
  --text-secondary: #e9d5ff;
  --border-color: #3b0764;
  --node-hover: rgba(139, 92, 246, 0.05);
  --node-active: rgba(139, 92, 246, 0.15);
  --node-active-text: #a78bfa;
  --scrollbar: #4c1d95;
}

/* Deep Space Blue */
.premium-dashboard.theme-deep-space, body.theme-deep-space .premium-dashboard {
  --bg-color: #030814;
