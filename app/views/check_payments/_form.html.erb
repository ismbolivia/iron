
<%= form_for :check_payment, url: check_payments_url, method: :post, remote: true do |form| %>
    <%= form.hidden_field :payment_type_id %>
    <%= form.hidden_field :sale_id %>
      <div class="row">
        <div id="div-error-check"></div>
          <div class="col-xs-12"> 
            <div id="div-error"></div>
          </div>
          <div class="col-xs-12">  
            <div class="form-group">                   
              <div class="input-group">
                <div class="input-group-addon"><i class="fas fa-diagnoses"></i></div>
                <%= form.collection_select :check_id, @checks, :id, :full_name_combo, 
                    {selected: @check_payment.check_id, include_blank: 'Seleccione el cheque a dosificar'},
                                {class: "form-control"} %>  
              </div>
            </div>
          </div>
      </div>
      <div class="col-xs-12">         
            <div class="form-group">

            <div class="input-group">
               <div class="input-group-addon"><i class="far fa-credit-card"></i></div>
                <%= form.text_field :rode , class: "form-control" %>
            </div>
          </div>
      </div> 

      <div class="field">

      </div>

      <div class="actions">
          <%= form.submit 'Efectuar pago', class: "btn btn-success" %>
      </div>
<% end %>
