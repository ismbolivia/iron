<p id="notice"><%= notice %></p>

<h1>Check Payments</h1>

<table>
  <thead>
    <tr>
      <th>Check</th>
      <th>Payment</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @check_payments.each do |check_payment| %>
      <tr>
        <td><%= check_payment.check_id %></td>
        <td><%= check_payment.payment_id %></td>
        <td><%= link_to 'Show', check_payment %></td>
        <td><%= link_to 'Edit', edit_check_payment_path(check_payment) %></td>
        <td><%= link_to 'Destroy', check_payment, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Check Payment', new_check_payment_path %>
