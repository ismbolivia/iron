<p id="notice"><%= notice %></p>

<h1>Client Price Lists</h1>

<table>
  <thead>
    <tr>
      <th>Client</th>
      <th>Price list</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @client_price_lists.each do |client_price_list| %>
      <tr>
        <td><%= client_price_list.client_id %></td>
        <td><%= client_price_list.price_list_id %></td>
        <td><%= link_to 'Show', client_price_list %></td>
        <td><%= link_to 'Edit', edit_client_price_list_path(client_price_list) %></td>
        <td><%= link_to 'Destroy', client_price_list, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Client Price List', new_client_price_list_path %>
