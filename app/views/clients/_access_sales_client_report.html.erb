<div class="modal-content-payment">
  <div class="modal-header modal-header-success " >
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"> [ × ] </button>
    	<h2><i class=" fas fa-chart-line "></i> <%= @title %></h2>
  </div>

  <div class="modal-body">
  	<ul class="nav nav-tabs" role="tablist">
	    <li role="pre" class="active"><a href="#movement" aria-controls="movement" role="tab" data-toggle="tab" aria-expanded="true"><span><i class="fas fa-upload text-warning"></i></span> Extracto previa</a></li>
	    <li role="pre" class=""><a href="#column" aria-controls="column" role="tab" data-toggle="tab" aria-expanded="false"><span><i class="fas fa-download text-primary"></i></span> Grafica de barras</a></li>
	    <li role="pre" class=""><a href="#pie" aria-controls="pie" role="tab" data-toggle="tab" aria-expanded="false"><span><i class="fas fa-users text-success"></i></span> Grafico tortas</a></li>
	    <li role="pre" class=""><a href="#pdf" aria-controls="pdf" role="tab" data-toggle="tab" aria-expanded="false"><span><i class="fas fa-chart-bar text-red"></i></span> Pdf</a></li>
	</ul>
	<div class="tab-content">
	    <div role="tabpanel" class=" tab-pane active" id="movement">
	        <div class="table-responsive">
	           <div class="col-md-12 col-sm-12">   
				<br>
	            <%= render(partial: 'sales/table_report_sales', locals: { sales: @sale_report_rage, title: @title }) %>       
	         </div>
	    </div>
	</div>

	<div role="tabpanel" class="tab-pane" id="column">
	      <div class="table-responsive">
	           <div class="col-md-12 col-sm-12">                 
	             <br>              	                                                               
	                     <%= column_chart @column_data, stacked: true, prefix: "$", thousands: "," %>                                    
	            </div>
	        </div> 
	</div>

	<div role="tabpanel" class="tab-pane " id="pie">                   
	        <div class="table-responsive">
	        	<div class="col-md-12 col-sm-12"> 
	        	<br>
	           <%= pie_chart  @pie_chart %>	           

	         </div>              
	     </div>
	 </div>  
	 <div role="tabpanel" class="tab-pane" id="pdf">
	      <div class="table-responsive">
	           <div class="col-md-12 col-sm-12">                 
	             <br>  
	               <embed src="<%= @url_sale_pdfs %>" type="application/pdf" width="100%" height="400px" />                                   
	            </div>
	        </div> 
	</div>

	</div>    
  </div>
</div>
