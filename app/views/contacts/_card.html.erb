<div class="row" id="panel_card_contact">
    <% @client.contacts.each do |contact| %>
       <div class="col-md-6">
            <div class="card panel ">
                <div class="card-body">
                    <div class="row bordes">
                        <div class="col-md-6 text-center">                                        
                            <%= image_tag(contact.profile.large.url, :alt => "imge-item", class: "rounded-circle img-fluid") %>                        
                        </div>
                        <div class="col-md-6">
                            <h3 class="box-title m-b-0"><%= contact.name %></h3> 
                            <h4>Nit: <%= contact.nit %></h4>
                            <small><%=contact.title %>(<%= contact.job %>)</small>
                            <address>
                                <%=contact.email %>
                                <br>               
                                <abbr title="Phone">Celular:</abbr> <%=contact.mobile %>
                            </address>            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% end %>  
</div>