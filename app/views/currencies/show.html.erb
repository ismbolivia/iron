<div class="row">
    <div class="col-lg-1"> </div>
        <div class="col-lg-10 panel panel-purchase ">       
            <div class="white-box">
                <div class="">     
            <div class="row">
             <div class = "col-lg-12 col-md-12 col-sm-12" >
               <div class="col-lg-2 col-md-2 col-sm-2">
                  <div class="product-img "> 
                    <%= image_tag(  ActionController::Base.helpers.asset_path('moneda.png'), :alt => "imge-item", class: "image-form") %>
                  </div>
                </div>
            
                <div class="col-lg-4 col-md-4 col-sm-4">
                    <div class="form-group">                      
                        <div class="input-group ">
                          <h2 class="m-t-50"><%= @currency.name %></h2>
                        </div>
                        <div class="input-group m-t-50">
                           
                            <label class=""><%=@currency.symbol %> </label>                     
                        </div>
                        <div class="input-group m-t-50">
                       
                            <label class=""><%=@currency.currency_unit_label %></label>
                                        
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-4 col-sm-6">
                    <a class="btn btn-app">
                        <span class="badge bg-yellow">3</span>
                        <i class="fa fa-bullhorn"></i> Notifications
                    </a>
                    <a class="btn btn-app">
                        <span class="badge bg-green">300</span>
                        <i class="fa fa-barcode"></i> Products
                        </a>
                        <a class="btn btn-app">
                          <span class="badge bg-purple">891</span>
                          <i class="fa fa-users"></i> Users
                        </a>
                        <a class="btn btn-app">
                          <span class="badge bg-teal">67</span>
                          <i class="fa fa-inbox"></i> Orders
                        </a>
                        <a class="btn btn-app">
                          <span class="badge bg-aqua">12</span>
                          <i class="fa fa-envelope"></i> Inbox
                        </a>
                        <a class="btn btn-app">
                          <span class="badge bg-red">531</span>
                          <i class="fa fa-thumbs-up"></i> Likes
                        </a>
                </div>

            </div>
          </div>
          <hr>
             <div class="row">
                    <div class="col-lg-12 col-md-12 col-sm-12">

                        <div class="row">
                            <div class="col-sm-6 col-lg-4">
                                <div class="form-group row">
                                  <label class="col-sm-3 text-left control-label col-form-label">Sub unidad monetaria</label>

                                  <div class="col-sm-9">                        
                                    <label class=""><%=@currency.currency_subunit_label %></label>
                                  </div>
                                </div>
                            </div>             
                           
                            <div class="col-sm-6 col-lg-4">
                                <div class="form-group row">
                                  <label class="col-sm-3 text-left control-label col-form-label">¿Activo?</label>
                                 
                                   <div class="col-sm-9">
                                      <% if @currency.active %>
                                          <label>Activo</label>
                                        <%else%>
                                          <label>Inactivo</label>
                                      <%end%>
                                   </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <div class="form-group row">
                                  <label class="col-sm-3 text-left control-label col-form-label">Redondeo:</label>
                                   
                                   <div class="col-sm-9">
                                      <label class=""><%= @currency.rounding %></label>
                                   </div>
                                </div>
                            </div>
                        </div>
                  </div>
          </div>
          <hr>
           <div class="row no-print ">
                  <div class="col-xs-12">

                    <%= link_to 'Back', currencies_path,  class: "btn btn-default "  %>

                  
                      <%= link_to 'Show', @currency,  class: "btn btn-primary pull-right" , style: "margin-right: 5px;"%>
                  </div>
                </div>
                <hr>
                   <%= render 'access_option', currency: @currency %>
                </div>
            </div>
        </div>
</div>
    <div class="col-lg-1">
    </div>
</div>

