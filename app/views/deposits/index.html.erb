<p id="notice"><%= notice %></p>

<h1>Depositos</h1>

<table>
  <thead>
    <tr>
      <th>Bank account</th>
      <th>Client</th>
      <th>Rode</th>
      <th>Payment</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @deposits.each do |deposit| %>
      <tr>
        <td><%= deposit.bank_account_id %></td>
        <td><%= deposit.client_id %></td>
        <td><%= deposit.rode %></td>
        <td><%= deposit.depositante %></td>
        <td><%= link_to 'Show', deposit %></td>
        <td><%= link_to 'Edit', edit_deposit_path(deposit) %></td>
        <td><%= link_to 'Destroy', deposit, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Deposit', new_deposit_path %>
