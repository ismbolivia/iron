<style>
  .login-wrapper {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', 'Outfit', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    margin: -20px;
    padding: 2.5rem;
    background: radial-gradient(circle at top right, #1e293b, #0f172a, #020617);
  }
  .login-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    padding: 5rem 4.5rem;
    width: 100%;
    max-width: 620px;
    box-shadow: 
      0 25px 50px -12px rgba(0, 0, 0, 0.6), 
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 0 0 1px rgba(255, 255, 255, 0.05);
    color: #f1f5f9;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .login-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .brand-logo {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    border-radius: 20px;
    margin: 0 auto 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px -5px rgba(59, 130, 246, 0.5);
    transform: rotate(-3deg);
  }
  .brand-logo svg {
    width: 45px;
    height: 45px;
    color: white;
  }
  .login-header h2 {
    margin: 0;
    font-size: 3.5rem;
    font-weight: 900;
    background: linear-gradient(to bottom, #ffffff 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }
  .login-header p {
    color: #94a3b8;
    margin-top: 1rem;
    font-size: 1.25rem;
    font-weight: 400;
  }
  .form-group-custom {
    margin-bottom: 2rem;
    position: relative;
  }
  .form-group-custom label {
    display: block;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: #e2e8f0;
    letter-spacing: 0.01em;
  }
  .form-control-custom {
    width: 100%;
    padding: 1.125rem 1.5rem;
    background: rgba(15, 23, 42, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #ffffff;
    font-size: 1.25rem;
    padding: 1.25rem 1.75rem;
    box-sizing: border-box;
  }
  .form-control-custom::placeholder {
    color: #475569;
  }
  .form-control-custom:focus {
    outline: none;
    border-color: #3b82f6;
    background: rgba(15, 23, 42, 1);
    box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.15), 0 0 20px rgba(59, 130, 246, 0.1);
    transform: scale(1.01);
  }
  .checkbox-custom {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-top: 1.5rem;
  }
  .checkbox-custom input[type="checkbox"] {
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 8px;
    accent-color: #3b82f6;
    cursor: pointer;
    border: 2px solid rgba(255, 255, 255, 0.2);
    background: rgba(15, 23, 42, 0.7);
  }
  .checkbox-custom label {
    font-size: 1rem;
    color: #94a3b8;
    margin: 0;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
  }
  .checkbox-custom label:hover {
    color: #f1f5f9;
  }
  .auth-actions {
    margin-top: 3.5rem;
  }
  .btn-premium {
    width: 100%;
    padding: 1.125rem;
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    color: white;
    border: none;
    border-radius: 16px;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
  }
  .btn-premium:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 20px 25px -5px rgba(37, 99, 235, 0.4);
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
  }
  .btn-premium:active {
    transform: translateY(-1px) scale(0.98);
  }
  .auth-links {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .auth-links a {
    color: #64748b;
    text-decoration: none;
    font-size: 1rem;
    transition: all 0.3s ease;
    display: inline-block;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .auth-links a:hover {
    color: #3b82f6;
    text-decoration: none;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <div class="login-header">
      <div class="brand-logo">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
      </div>
      <h2>Iniciar Sesión</h2>
      <p>Bienvenido de nuevo, ingresa tus credenciales</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group-custom">
        <%= f.label :email, "Correo Electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control-custom", placeholder: "tu@email.com" %>
      </div>

      <div class="form-group-custom">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control-custom", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="checkbox-custom">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Recordar mi sesión" %>
        </div>
      <% end %>

      <div class="auth-actions">
        <%= f.submit "Entrar al Sistema", class: "btn-premium" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
        <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name) %><br />
      <% end %>
      <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
        <%= link_to "Solicitar una cuenta", new_registration_path(resource_name) %><br />
      <% end %>
    </div>
  </div>
</div>
