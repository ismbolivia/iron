
<!DOCTYPE html>
<html>
<head>
  <title>inventario</title>
  <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>
	   <div class="col-md-12">
	 	<div class=" printableArea">	        	
	        <div class="row">
			  <table class="table product-overview table-bordered ">
			    <thead class="conf-pdf">
			    	<tr><th colspan="7" class="center">
				         	<h3><b><%=@title %></b> </h3>
				        </th>
				    </tr>
				     <tr>				      
				        <th class="center">Fecha</th>                           
                        <th class="center">Codigo</th>
                        <th class="center">Nombre</th>
                       	<th class="center">Unidad</th>
                        <th class="center">Cant</th>
                         <th class="center">Costo</th>
                        <th class="center">Valor Inventario </th>  	                    
				     </tr>
				     </thead>
				     <tbody>
				        <% @inventory_items.each do |ii| %>
				      <tr>
				        <td><%= ii.created_at.strftime("%d/%m/%Y") %></td>   
                              <td><%= ii.code_item %></td>
                              <td><%= ii.name_item %></td>
                              <td><%= ii.description_item %> </td>
                              <td><%= ii.quantity_product %></td>
                               <td><%= (ii.item.get_precio_last).round(4) %></td>
                              <td><%= @mycompany.get_current_currency.symbol%> 
                                <%= ii.price_purchase_total.round(2)
                                 %>                              
                            </td>   
				    </tr>
				    <% end %>
				    <tr><th colspan="5"  class="text-center">
				         	<span><b>Valor total en inventario: </b> </span>
				        </th>
				         <th><%= @mycompany.get_current_currency.symbol%><%= @inventory.TotalAmountInventory %> </th>				         
				    </tr>
				  </tbody>
				</table>			    
			</div>
		</div>
	</div>

</body>
	
</html>
