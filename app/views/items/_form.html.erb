
 
      <%= form_with(model: item, local: true) do |f| %>
        <% if item.errors.any? %>
          <div id="error_explanation">
            <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

            <ul>
            <% item.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
            </ul>
          </div>
        <% end %>

  <div class="row">
    <div class="col-md-5 mb-4">
        <%= render 'form_image', f: f, item: item %>
    </div>
    
    <!-- Columna Datos Reducida -->
    <div class="col-md-7">
       <div class="row">
          <div class="col-md-12 mb-4">
             <div class="form-group" style="margin-bottom: 0;">
                <%= f.label :name, "Nombre del Producto" %>
                <%= f.text_field :name, placeholder: "Ej. Cloro Industrial 5L", class: "form-control pv2-form-control", style: "font-size: 1.4rem !important; font-weight: 800 !important; color: var(--accent-indigo) !important;" %>
             </div>
          </div>
       </div>
       <div class="row">
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :code, "Código de Barras / SKU" %>
                <div class="pv2-input-group">
                   <div class="pv2-input-group-addon"><i class="fas fa-barcode"></i></div>
                   <%= f.text_field :code, placeholder: "1010214555", class: "form-control" %>
                </div>
             </div>
          </div>
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :brand, "Marca" %>
                <div class="pv2-input-group">
                   <div class="pv2-input-group-addon"><i class="fas fa-bookmark"></i></div>
                   <%= f.text_field :brand_name, placeholder: "Marca del Producto", class: "form-control", id: "item_brand" %>
                   <div style="display: none"><%= f.text_field :brand_id %></div>
                </div>
             </div>
          </div>
       </div>
    </div>
  </div> 
  <hr style="border-top: 1px solid #e2e8f0; margin: 1.5rem 0;">     

  <div class="row">
    <div class="col-md-8">
       <div class="row">
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :category_id, "Categoría" %>
                <div class="pv2-input-group">
                   <div class="pv2-input-group-addon"><i class="fas fa-pallet"></i></div>
                   <%= f.collection_select :category_id, @categories, :id, :name, {selected: @item.category_id, include_blank: 'Seleccione Categoría'}, {class: "form-control"} %>
                </div>
             </div>
          </div>
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :unit_id, "Unidad de Medida" %>
                 <div class="pv2-input-group" style="display: flex; align-items: center; gap: 8px; width: 100%;">
                    <div class="pv2-input-group-addon"><i class="fas fa-chess-pawn"></i></div>
                    <div style="flex-grow: 1;">
                      <%= f.collection_select :unit_id, @units, :id, :name, {selected: @item.unit_id, include_blank: 'Seleccione Unidad'}, {class: "form-control", id: "unit-selector"} %>
                    </div>
                    <% if @item.unit_id.present? %>
                      <%= link_to edit_unit_path(@item.unit_id), class: "btn-premium-action", style: "background: #f8fafc; color: #4f46e5; min-width: 48px; border: 1px solid #e2e8f0; border-radius: 12px; padding: 10px 14px;", title: "Configurar decimales de esta unidad", target: "_blank", id: "unit-edit-link" do %>
                        <i class="fas fa-cog"></i>
                      <% end %>
                    <% end %>
                 </div>

                 <script>
                   document.addEventListener('DOMContentLoaded', function() {
                     const selector = document.getElementById('unit-selector');
                     const editLink = document.getElementById('unit-edit-link');
                     if (selector && editLink) {
                       selector.addEventListener('change', function() {
                         const unitId = this.value;
                         if (unitId) {
                           editLink.href = `/units/${unitId}/edit`;
                           editLink.style.display = 'inline-flex';
                         } else {
                           editLink.style.display = 'none';
                         }
                       });
                     }
                   });
                 </script>
             </div>
          </div>
       </div>

       <div class="row">
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :discount, "Descuento al Producto (%)" %>
                <div class="pv2-input-group">
                   <div class="pv2-input-group-addon"><i class="fas fa-percent"></i></div>
                   <%= f.number_field :discount, placeholder: "10", class: "form-control" %>
                </div>
             </div>
          </div>
          <div class="col-md-6 mb-4">
             <div class="form-group">
                <%= f.label :description, "Descripción" %>
                <%= f.text_area :description, class: "form-control pv2-form-control", rows: 2, placeholder: "Escriba una descripción corta..." %>
             </div>
          </div>
       </div>
    </div>

    <div class="col-md-4">
       <div class="form-group">
          <label style="color: var(--text-muted); font-weight: 800; text-transform: uppercase;">Configuración & Estado</label>
          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 16px; border: 1px solid var(--border-color); display: flex; flex-direction: column; gap: 0.8rem; margin-top: 0.6rem;">
             
             <div style="display: flex; align-items: center; gap: 0.8rem;">
                <%= f.check_box :active, style: "width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-indigo);" %>
                <label style="margin: 0; font-weight: 600; font-size: 0.95rem; color: var(--text-main); text-transform: none; letter-spacing: 0;" for="item_active">¿Activo?</label>
             </div>
             
             <div style="display: flex; align-items: center; gap: 0.8rem;">
                <%= f.check_box :todiscount, style: "width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-indigo);" %>
                <label style="margin: 0; font-weight: 600; font-size: 0.95rem; color: var(--text-main); text-transform: none; letter-spacing: 0;" for="item_todiscount">¿Aplica descuento?</label>
             </div>
             
             <div style="display: flex; align-items: center; gap: 0.8rem;">
                <%= f.check_box :sold, style: "width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-indigo);" %>
                <label style="margin: 0; font-weight: 600; font-size: 0.95rem; color: var(--text-main); text-transform: none; letter-spacing: 0;" for="item_sold">¿Puede ser vendido?</label>
             </div>
             
             <div style="display: flex; align-items: center; gap: 0.8rem;">
                <%= f.check_box :bought, style: "width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-indigo);" %>
                <label style="margin: 0; font-weight: 600; font-size: 0.95rem; color: var(--text-main); text-transform: none; letter-spacing: 0;" for="item_bought">¿Puede ser comprado?</label>
             </div>
             
          </div>
       </div>
    </div>
  </div></div>
       <hr>

    
  <div class="row no-print" style="margin-top: 1.5rem;">
    <div class="col-xs-12 d-flex justify-content-between">
      <%= link_to items_path, class: "btn-premium-action", style: "background: #f1f5f9; color: #475569;" do %>
         <i class="fas fa-arrow-left mr-2"></i> Volver a Lista
      <% end %>
      <%= f.submit 'Guardar Cambios', class: "btn-premium-action btn-indigo" %>
    </div>
  </div>
    <hr> 

  
<% end %>