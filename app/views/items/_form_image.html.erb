
 
      <%= form_with(model: item, remote: true) do |f| %>


        <% if item.errors.any? %>
          <div id="error_explanation">
            <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

            <ul>
            <% item.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
            </ul>
          </div>
        <% end %>

  <div class="row">
      <div class = "col-lg-12 col-md-12 col-sm-12 " id="image_uploader" >      
         <%= image_tag(item.image.large.url, :alt => "imge-item", :style =>"iwidth:100%; height:400px;") %>
                 <div class="fileupload btn btn-info waves-effect waves-light form-control">
                 	<span><i class="ion-upload m-r-5"></i>Subir una imagen </span>
                             <%= f.file_field :image, :class =>"upload"%>
                 </div>                   
        </div>
    <div class = "col-lg-12 col-md-12 col-sm-12 hide" id="image_change" >
    <div id="loader" class="">
      <br>
    <h1>Cargando...!</h1>
    <div class="spinner"></div>
    <div class="spinner2"></div>
  </div>
</div>

</div> 
  <hr>           
    <div class="col-xs-12">         
        <%= f.submit 'Guardar', :class => "btn btn-success  pull-right", :onclick =>"change_images_item();" %>
        </div>      
      <% end %>
    
 
<script type="text/javascript">
	
function change_images_item(){
	 var div_image = document.getElementById('image_uploader');
	div_image.classList.add('hide');
	var div_change = document.getElementById('image_change');
	div_change.classList.remove('hide');
}
</script>