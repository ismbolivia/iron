<style>
  .modern-item-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    overflow: visible;
    margin-bottom: 25px;
    transition: all 0.3s ease;
    border: 1px solid #eef2f6;
    position: relative;
    z-index: 10;
  }
  .modern-item-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }
  .product-img-wrapper {
    position: relative;
    height: 180px;
    overflow: visible;
    background: #f8fafc;
    border-bottom: 1px solid #f1f5f9;
    border-radius: 12px 12px 0 0;
  }
  .product-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px;
    transition: transform 0.5s;
  }
  .modern-item-card:hover .product-img-wrapper img {
    transform: scale(1.05);
  }
  .price-pill {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #22c55e;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 800;
    font-size: 13px;
    box-shadow: 0 2px 8px rgba(34,197,94,0.3);
    z-index: 2;
  }
  .stock-pill {
    position: absolute;
    top: 12px;
    left: 12px;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 800;
    font-size: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .stock-positive { background: #0ea5e9; }
  .stock-zero { background: #ef4444; }

  .custom-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(15, 23, 42, 0.65);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 3;
    backdrop-filter: blur(2px);
  }
  .product-img-wrapper:hover .custom-overlay {
    opacity: 1;
  }
  .overlay-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 14px;
    transition: all 0.2s;
    text-decoration: none !important;
  }
  .overlay-btn:hover { transform: scale(1.15); color: white; }
  .btn-view { background: #0ea5e9; }
  .btn-edit { background: #8b5cf6; }
  .btn-delete { background: #ef4444; }
  
  .product-info {
    padding: 15px;
    display: flex;
    flex-direction: column;
    height: 120px;
  }
  .item-category {
    font-size: 11px;
    font-weight: 800;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .item-name {
    font-size: 14px;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 4px 0;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    height: 36px;
  }
  .item-description {
    font-size: 12px;
    color: #64748b;
    margin-bottom: 0px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    height: 32px;
  }
  .stock-inactive { opacity: 0.6; filter: grayscale(50%); }
</style>

<div class="table-responsive">
  <table class="table" style="margin-bottom: 0;">
    <thead>
      <tr><%= render partial: "pager", locals: { keywords: @keywords, page: @page } %></tr>
    </thead>
  </table>
</div>

<div class="row page-wrapper" style="margin-top: 15px;">
  <% @items.each do |item| %>
    <% local_stock = item.get_stock_by_branch(current_user.branch_id).to_i %>
    <div class="col-lg-3 col-md-4 col-sm-6 col-xs-12">
      <div class="modern-item-card <%= 'stock-inactive' unless item.active %>">
        
        <div class="product-img-wrapper">
          <!-- Stock Pill (Top Left) -->
          <span class="stock-pill <%= local_stock > 0 ? 'stock-positive' : 'stock-zero' %>" title="Stock Disponible">
            <i class="fas <%= local_stock > 0 ? 'fa-box' : 'fa-exclamation-circle' %>"></i>
            Stock: <%= local_stock %>
          </span>

          <!-- Price Pill (Top Right) -->
          <span class="price-pill">
            <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(item.price_default, precision: 2) %>
          </span>
          <%= image_tag(item.image.large.url, alt: item.name) %>
          
          <div class="custom-overlay">
            <%= link_to item, class: "overlay-btn btn-view", title: "Ver Detalle" do %><i class="fas fa-binoculars"></i><% end %>
            <%= link_to edit_item_path(item), class: "overlay-btn btn-edit", title: "Editar" do %><i class="fas fa-pencil-alt"></i><% end %>
            <%= link_to item, method: :delete, class: "overlay-btn btn-delete", title: "Eliminar", data: { confirm: '¿Está seguro de eliminar?' } do %><i class="fas fa-trash"></i><% end %>
          </div>

          <!-- Origin Indicators (Global Detection) -->
          <div style="position: absolute; bottom: -8px; left: 10px; z-index: 10; display: flex; flex-direction: column; gap: 4px;">
             <% if item.has_repacking %>
               <span class="badge" style="background: #7c3aed; color: white; padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 900; box-shadow: 0 4px 6px rgba(124,58,237,0.3); border: 2px solid white;">
                 <i class="fas fa-sync-alt"></i> RE-EMPAQUE
               </span>
             <% end %>
             <% if item.has_adjustment %>
               <span class="badge" style="background: #059669; color: white; padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 900; box-shadow: 0 4px 6px rgba(5, 150, 105, 0.3); border: 2px solid white;">
                 <i class="fas fa-tools"></i> AJUSTE
               </span>
             <% end %>
          </div>
        </div>

        <div class="product-info">
          <div>
            <div class="item-category"><%= item.category.name rescue 'General' %></div>
            <h4 class="item-name" title="<%= item.name %>"><%= item.name %></h4>
            <div class="item-description"><%= item.description.presence || 'Sin descripción disponible.' %></div>
          </div>
        </div>

      </div>
    </div>
  <% end %>
</div>