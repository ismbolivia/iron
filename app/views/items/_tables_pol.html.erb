<div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
  <table class="table product-overview" style="margin-bottom: 0;">
    <thead style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
      <tr>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Fecha Ingreso</th>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Referencia Orden</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Cant. Recibida</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Stock Almacén</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Disponible</th>
        <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800;">Costo Unt.</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Acción</th>
      </tr>
    </thead>
    <tbody>
      <% @item.purchase_order_lines.each do |pol| %>
        <% if pol.parcial? || pol.asignado? %>
          <tr style="transition: all 0.2s;">
            <td style="padding: 1rem 1.2rem; vertical-align: middle;">
              <div style="font-weight: 700; color: var(--text-main);"><%= pol.updated_at.strftime("%d/%m/%Y") %></div>
              <div style="font-size: 0.75rem; color: var(--text-muted);"><%= pol.updated_at.strftime("%H:%M") %> hrs</div>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle;">
              <span class="badge" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; font-weight: 600;">
                OC# <%= pol.purchase_order.name %>
              </span>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center; color: var(--text-main); font-weight: 600;">
              <%= pol.display_qty_received %>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
              <span class="badge" style="background: #ecfdf5; color: #059669; border: 1px solid #d1fae5; font-weight: 700;">
                <%= pol.item.format_qty(pol.get_total_warehouse_stock) %>
              </span>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
              <% available = pol.get_available_line_item.to_f %>
              <span class="badge" style="<%= available > 0 ? 'background: #eff6ff; color: #3b82f6; border: 1px solid #dbeafe;' : 'background: #fff1f2; color: #e11d48; border: 1px solid #ffe4e6;' %> font-weight: 800; padding: 6px 12px;">
                <%= pol.item.format_qty(available) %>
              </span>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: right; color: var(--text-main); font-family: 'JetBrains Mono', monospace;">
              <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(pol.price_unit, precision: 4) %>
            </td>
            <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
              <%= link_to new_stock_path(item_id: @item.id, total: pol.get_available_line_item, my_pol: pol.id, option_view: 0), remote: true, class: "btn btn-sm", style: "background: var(--accent-indigo); color: white; border-radius: 8px;", title: "Asignar Stock" do %>
                <i class="fas fa-hand-point-down"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>