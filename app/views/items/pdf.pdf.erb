
<!DOCTYPE html>
<html>
<head>
	<title>Productos</title>
    <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>		
	    	<div class="col-md-12">
	      		<div class=" printableArea">        		
	        	  
	         		<div class="row">
				            <table class="table product-overview table-bordered ">
				              <thead class="conf-pdf" style="-webkit-print-color-adjust: exact;">
				                <tr>
                          <th colspan="8" style="background: #1e293b !important; color: #ffffff !important; padding: 15px; border: none; text-align: left; -webkit-print-color-adjust: exact;">
                            <div style="display: flex; align-items: center; gap: 20px;">
                              <% 
                                 # Aseguramos la existencia de @mycompany
                                 @mycompany ||= Company.where(mycompany: true).first 
                              %>
                              <% if @mycompany&.logo&.url %>
                                <%= wicked_pdf_image_tag(@mycompany.logo.url, style: "height: 50px; width: auto;") %>
                              <% end %>
                              <h2 style="margin: 0; font-size: 1.5rem; color: #ffffff !important; display: inline-block; vertical-align: middle; margin-left: 15px;">LISTA DE PRODUCTOS</h2>
                            </div>
				                	</th>
				                </tr>
				                <tr>
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Código</th>
				                  <th class="cenetr" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Nombre</th>
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Descripción</th>
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Imagen</th>
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Unidad</th>
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Stock</th>				                  
				                  <th class="center" style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Categoría</th>
				                  <th style="background: #334155 !important; color: white !important; -webkit-print-color-adjust: exact;">Precio</th>				                
				                </tr>
				              </thead>
				              <tbody>
				                <% @all_items.each do |item| %>
				                  <tr>
				                    <td><%= item.code %></td>
				                    <td><%= item.name  %></td>
				                    <td> <%= item.item_description %></td>
				                    <td style="padding: 5px; text-align: center; vertical-align: middle; width: 60px;">
				                      <% if item.image.present? %>
				                        <div style="width: 50px; height: 50px; background: #fff; border-radius: 6px; overflow: hidden; display: block; margin: 0 auto; border: 1px solid #e2e8f0;">
				                          <%= wicked_pdf_image_tag(item.image.large.url, style: "width: 100%; height: 100%; object-fit: contain;") %>
				                        </div>
				                      <% else %>
				                        <div style="width: 50px; height: 50px; background: #f8fafc; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin: 0 auto; border: 1px dashed #cbd5e1;">
				                          <span style="font-size: 8px; color: #94a3b8;">S/I</span>
				                        </div>
				                      <% end %>
				                    </td>
				                    <td><%= item.unit ? item.unit.name : '' %></td>
				                   
				                    <td><%= item.min_stock %></td>
				                    <td><%= item.category ? item.category.name : '' %></td>				                    
				                    <td><%= number_to_currency(item.price) %></td>			                  				                    
				                  </tr>
				                <% end %>
				              </tbody>
				            </table>		    

					</div>
				</div>
			</div>
	</body>	
</html>