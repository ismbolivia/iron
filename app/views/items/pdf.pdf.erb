
<!DOCTYPE html>
<html>
<head>
	<title>Productos</title>
    <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>		
	    	<div class="col-md-12">
	      		<div class=" printableArea">        		
	        	  
	         		<div class="row">
				            <table class="table product-overview table-bordered ">
				              <thead class="conf-pdf">
				              	<tr><th colspan="8" class="">
				              			<h4>
				              				<b>LISTA DE PRODUCTOS </b> 
				              			</h4>
				                	</th>
				                </tr>
				                <tr>
				                  <th class="center">Código</th>
				                  <th class="cenetr">Nombre</th>
				                  <th class="center">Descripción</th>
				                  <th class="center">Imagen</th>
				                  <th class="center">Unidad</th>
				                  <th class="center">Stock</th>				                  
				                  <th class="center">Categoría</th>
				                 <!--  <th>Almacen</th> -->
				                  <th>Precio</th>				                
				                </tr>
				              </thead>
				              <tbody>
				                <% @all_items.each do |item| %>
				                  <tr>
				                    <td><%= item.code %></td>
				                    <td><%= item.name  %></td>
				                    <td> <%= item.item_description %></td>
				                    <td><% if item.image.present?  %>
				                    	 <%=  wicked_pdf_image_tag(item.image.large.url, :alt => "imge-item", :style => "iwidth:100%; height:50px;" )%>	                				                  
				                  <% end %>
				                  <% if !item.image.present?  %>
				                    	 <%= image_tag wicked_pdf_asset_base64('default_image.jpg'), :alt => "imge-item", :style => "iwidth:100%; height:50px;" %>	                 			                  
				                  <% end %>				                      
				                     </td>
				                    <td><%= item.unit ? item.unit.name : '' %></td>
				                   
				                    <td><%= item.min_stock %></td>
				                    <td><%= item.category ? item.category.name : '' %></td>				                    
				                    <td><%= number_to_currency(item.price) %></td>			                  				                    
				                  </tr>
				                <% end %>
				              </tbody>
				            </table>		    

					</div>
				</div>
			</div>
	</body>	
</html>