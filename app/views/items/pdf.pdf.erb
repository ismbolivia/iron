
<!DOCTYPE html>
<html>
<head>
	<title>Productos</title>
    <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>		
	    	<div class="col-md-12">
	      		<div class=" printableArea">        		
	        	  
	         		<div class="row">
				            <table class="table product-overview table-bordered ">
				              <thead class="conf-pdf">
				                <tr>
                          <th colspan="8" style="background: #1e293b; color: #ffffff; padding: 15px; border: none; text-align: left;">
                            <div style="display: flex; align-items: center; gap: 20px;">
                              <% 
                                 # Aseguramos la existencia de @mycompany
                                 @mycompany ||= Company.where(mycompany: true).first 
                              %>
                              <% if @mycompany&.logo&.url %>
                                <%= wicked_pdf_image_tag(@mycompany.logo.url, style: "height: 50px; width: auto;") %>
                              <% end %>
                              <h2 style="margin: 0; font-size: 1.5rem; color: #ffffff; display: inline-block; vertical-align: middle; margin-left: 15px;">LISTA DE PRODUCTOS</h2>
                            </div>
				                	</th>
				                </tr>
				                <tr>
				                  <th class="center" style="background: #334155; color: white;">Código</th>
				                  <th class="cenetr" style="background: #334155; color: white;">Nombre</th>
				                  <th class="center" style="background: #334155; color: white;">Descripción</th>
				                  <th class="center" style="background: #334155; color: white;">Imagen</th>
				                  <th class="center" style="background: #334155; color: white;">Unidad</th>
				                  <th class="center" style="background: #334155; color: white;">Stock</th>				                  
				                  <th class="center" style="background: #334155; color: white;">Categoría</th>
				                  <th style="background: #334155; color: white;">Precio</th>				                
				                </tr>
				              </thead>
				              <tbody>
				                <% @all_items.each do |item| %>
				                  <tr>
				                    <td><%= item.code %></td>
				                    <td><%= item.name  %></td>
				                    <td> <%= item.item_description %></td>
				                    <td><% if item.image.present?  %>
				                    	 <%=  wicked_pdf_image_tag(item.image.large.url, :alt => "imge-item", :style => "iwidth:100%; height:50px;" )%>	                				                  
				                  <% end %>
				                  <% if !item.image.present?  %>
				                    	 <%= image_tag wicked_pdf_asset_base64('default_image.jpg'), :alt => "imge-item", :style => "iwidth:100%; height:50px;" %>	                 			                  
				                  <% end %>				                      
				                     </td>
				                    <td><%= item.unit ? item.unit.name : '' %></td>
				                   
				                    <td><%= item.min_stock %></td>
				                    <td><%= item.category ? item.category.name : '' %></td>				                    
				                    <td><%= number_to_currency(item.price) %></td>			                  				                    
				                  </tr>
				                <% end %>
				              </tbody>
				            </table>		    

					</div>
				</div>
			</div>
	</body>	
</html>