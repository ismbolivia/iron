<!DOCTYPE html>
<html>
<head>
  <title>Lotes Disponibles - <%= @item.code %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 10mm; font-size: 10px; color: #1e293b; width: 95mm; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    th, td { border: 1px solid #cbd5e1; padding: 4px; text-align: left; }
    th { background: #1e293b; color: #ffffff; font-size: 8px; text-transform: uppercase; white-space: nowrap; }
    .text-right { text-align: right; }
    .text-center { text-align: center; }
    .no-wrap { white-space: nowrap; }
    @media print {
      @page { size: 105mm 216mm; margin: 0; }
      .no-print { display: none; }
      body { padding: 5mm; width: 95mm; }
    }
  </style>
</head>
<body onload="window.print()">
  <div class="no-print" style="margin-bottom: 10px;">
    <button onclick="window.print()" style="padding: 10px 20px; font-size: 14px; cursor: pointer; background: #4f46e5; color: white; border: none; border-radius: 4px;"><i class="fas fa-print"></i> Imprimir</button>
    <button onclick="window.close()" style="padding: 10px 20px; font-size: 14px; cursor: pointer; background: #e2e8f0; color: #475569; border: none; border-radius: 4px; margin-left: 10px;"><i class="fas fa-times"></i> Cerrar</button>
  </div>

  <div style="margin-bottom: 15px; border-bottom: 1px solid #334155; padding-bottom: 8px; display: flex; align-items: center; gap: 15px;">
    <% if @mycompany&.logo&.url %>
      <div style="flex-shrink: 0;">
        <%= image_tag(@mycompany.logo.url, style: "height: 40px; width: auto; max-width: 80px; object-fit: contain;") %>
      </div>
    <% end %>
    <div style="flex-grow: 1;">
      <strong style="font-size: 1.15rem; color: #0f172a; display: block; line-height: 1.2;"><%= @item.code %> &nbsp; <%= @item.name %></strong>
      <span style="color: #64748b; font-size: 9px; font-weight: 600;">Fecha de Impresión: <%= Time.now.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th class="text-center">#</th>
        <th>Fecha Ingreso</th>
        <th>Lote / Documento</th>
        <th class="text-center">Detalle / Empaque</th>
        <th class="text-right">Saldo (<%= @item.unit.name %>s)</th>
      </tr>
    </thead>
    <tbody>
      <% if @available_stocks.empty? %>
        <tr>
          <td colspan="5" class="text-center">No hay lotes disponibles.</td>
        </tr>
      <% else %>
        <% @available_stocks.each_with_index do |(main_stock, balance, moves_count), index| %>
          <% 
            lot_display_name = main_stock.lote.presence || (main_stock.purchase_order_line ? "LOTE OC-#{main_stock.purchase_order_line.purchase_order.name}" : "SISTEMA") 
            presentation = main_stock.presentation
            repacked = main_stock.respond_to?(:repacking_id) && main_stock.repacking_id.present?
          %>
          <tr>
             <td class="text-center no-wrap" style="width: 20px;"><%= index + 1 %></td>
             <td class="no-wrap" style="width: 70px;"><%= main_stock.created_at.strftime("%d/%m/%Y") %></td>
             <td>
               <strong><%= lot_display_name %></strong>
               <% if moves_count > 1 %><br/><small style="color: #0ea5e9;"><i class="fas fa-sync"></i> Lote consolidado</small><% end %>
               <% if repacked %> <br/><small style="color: #8b5cf6; font-weight: bold;"><i class="fas fa-box-open"></i> Lote Re-empacado</small> <% end %>
             </td>
             <td class="text-center">
                <% if presentation %>
                    <strong><%= presentation.name %></strong> <br/>
                    <small>(<%= presentation.qty %> <%= @item.unit.name %>s)</small>
                <% else %>
                    Sin Presentación
                <% end %>
             </td>
             <td class="text-right no-wrap" style="font-size: 13px; width: 60px;"><strong><%= number_with_precision(balance, precision: 0) %></strong></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
    <% unless @available_stocks.empty? %>
      <tfoot>
        <tr>
          <td colspan="4" class="text-right" style="font-size: 11px; padding: 10px;"><strong>TOTAL STOCK DISPONIBLE:</strong></td>
          <td class="text-right" style="font-size: 14px; background: #f0fdf4; color: #166534; padding: 10px;"><strong><%= number_with_precision(@available_stocks.sum { |g| g[1] }, precision: 0) %></strong></td>
        </tr>
      </tfoot>
    <% end %>
  </table>
</body>
</html>
