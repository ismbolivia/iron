                <div class="white-box" style="border: none; padding: 0;">
                      <% 
                        # Cálculo optimizado de resumen para la pestaña
                        all_draft_details = item.sale_details.joins(:sale).where(sales: { status_priority: [8, 6, 7, 10] })
                        total_draft_qty = all_draft_details.sum(:qty)
                        
                        draft_count = all_draft_details.where(sales: { status_priority: 8 }).count
                        annulled_count = all_draft_details.where(sales: { status_priority: 6 }).count
                      %>
                      
                      <!-- Resumen de Ventas No Concretadas -->
                      <div class="row mb-4" style="margin-bottom: 2rem;">
                        <div class="col-md-4">
                          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; text-align: center;">
                            <span style="display: block; font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 1px;">Total Unidades</span>
                            <strong style="font-size: 2rem; color: #0f172a;"><%= number_with_precision(total_draft_qty, precision: 0) %></strong>
                            <div style="font-size: 0.75rem; color: #94a3b8; font-weight: 600; margin-top: 4px;">SIN CONCRETAR</div>
                          </div>
                        </div>
                        <div class="col-md-4">
                          <div style="background: #fffbeb; padding: 1.5rem; border-radius: 16px; border: 1px solid #fef3c7; text-align: center;">
                            <span style="display: block; font-size: 0.75rem; font-weight: 800; color: #b45309; text-transform: uppercase; letter-spacing: 1px;">Borradores</span>
                            <strong style="font-size: 2rem; color: #92400e;"><%= draft_count %></strong>
                            <div style="font-size: 0.75rem; color: #d97706; font-weight: 600; margin-top: 4px;">PRIORIDAD 8</div>
                          </div>
                        </div>
                        <div class="col-md-4">
                          <div style="background: #fef2f2; padding: 1.5rem; border-radius: 16px; border: 1px solid #fee2e2; text-align: center;">
                            <span style="display: block; font-size: 0.75rem; font-weight: 800; color: #b91c1c; text-transform: uppercase; letter-spacing: 1px;">Anulados</span>
                            <strong style="font-size: 2rem; color: #991b1b;"><%= annulled_count %></strong>
                            <div style="font-size: 0.75rem; color: #dc2626; font-weight: 600; margin-top: 4px;">SALIDAS REVERTIDAS</div>
                          </div>
                        </div>
                      </div>

                      <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                              <table class="table product-overview" style="margin-bottom: 0;">
                                <thead style="background: #f1f5f9;">
                                  <tr>
                                    <th style="padding: 1.2rem;">Fecha</th>
                                    <th style="padding: 1.2rem;">Nro. Transaccion</th>
                                    <th style="padding: 1.2rem;">Estado</th>
                                    <th style="padding: 1.2rem;">Usuario</th>
                                    <th style="padding: 1.2rem;">Cliente</th>
                                    <th style="padding: 1.2rem; text-align: right;">Cant. (<%= item.unit.name.upcase %>S)</th>
                                    <th style="padding: 1.2rem; color: #64748b;">Instrucción Despacho</th>
                                  </tr>
                                </thead>

                                 <tbody>
                                   <% 
    # Borradores reales (8), Anulados (6), Para Anular (7) y Cancelados (10)
    base_query = item.sale_details.joins(:sale).where(sales: { status_priority: [8, 6, 7, 10] })
    draft_grand_total = base_query.sum(:qty)
    draft_details = base_query.includes(:sale => [:user, :client]).order("sales.created_at DESC").limit(50)
    drafts_by_year = draft_details.group_by { |sd| sd.sale.created_at.year }
                                     
                                     if drafts_by_year.empty?
                                   %>
                                     <tr>
                                       <td colspan="6" class="text-center" style="padding: 3rem; color: var(--text-muted);">
                                         <i class="fas fa-history fa-3x mb-3" style="opacity: 0.3;"></i>
                                         <p>No hay borradores ni ventas anuladas para este producto.</p>
                                       </td>
                                     </tr>
                                   <% else %>
                                     <% drafts_by_year.each do |year, details| 
                                        year_draft_subtotal = 0
                                     %>
                                       <tr style="background: #f1f5f9;">
                                         <td colspan="6" style="padding: 0.8rem 1.2rem; font-weight: 800; color: #64748b; font-size: 1rem;">
                                           <i class="far fa-calendar-alt mr-2"></i> Gestión <%= year %>
                                         </td>
                                       </tr>

                                       <% details.each do |detail| 
                                          sale = detail.sale
                                          qty = detail.qty.to_f
                                          year_draft_subtotal += qty
                                          draft_grand_total += qty
                                       %>
                                         <tr>
                                           <td style="padding: 1rem 1.2rem; color: var(--text-muted); font-size: 0.9rem;">
                                             <%= sale.created_at.strftime("%d/%m/%Y") %>
                                           </td>
                                           <td style="padding: 1rem 1.2rem;">
                                             <%= link_to sale, {method: :get, style: "text-decoration: none;"} do %>
                                               <span class="badge" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0; font-weight: 700; padding: 4px 8px;">
                                                 <%= sale.number %>
                                               </span>
                                             <% end %>
                                           </td>
                                           <td style="padding: 1rem 1.2rem;">
                                             <% 
                                               status = sale.payment_status_cache
                                               bg_color = "#f1f5f9"
                                               text_color = "#64748b"
                                               border_color = "#e2e8f0"

                                               if status == "BORRADOR"
                                                 bg_color = "#fef9c3"; text_color = "#a16207"; border_color = "#fef08a"
                                               elsif status == "ANULADO"
                                                 bg_color = "#fee2e2"; text_color = "#b91c1c"; border_color = "#fecaca"
                                               elsif status == "CANCELADO" || status == "PAGADA" || status == "FINALIZADA"
                                                 bg_color = "#dcfce7"; text_color = "#166534"; border_color = "#bbf7d0"
                                               end
                                             %>
                                             <span class="badge" style="background: <%= bg_color %>; color: <%= text_color %>; border: 1px solid <%= border_color %>; font-size: 0.75rem;">
                                               <%= status == "CANCELADO" ? "PAGADA" : status %>
                                             </span>
                                           </td>
                                           <td style="padding: 1rem 1.2rem; color: var(--text-main); font-size: 0.9rem;"><%= sale.user.name || sale.user.email %></td>
                                           <td style="padding: 1rem 1.2rem; color: var(--text-main); font-size: 0.9rem; font-weight: 500;"><%= sale.client.name %></td>
                                           <td style="padding: 1rem 1.2rem; text-align: right; font-weight: 700; color: var(--text-main); font-size: 1rem;">
                                             <%= number_with_precision(qty, precision: 0) %> <small style="font-size: 0.75rem; color: var(--text-muted);"><%= item.unit.name.downcase %>s</small>
                                           </td>
                                           <td style="padding: 1rem 1.2rem; color: #64748b; font-weight: 600; font-size: 0.8rem; background: #f8fafc;">
                                             <%= detail&.dispatch_instructions.presence || 'N/A' %>
                                           </td>
                                         </tr>
                                       <% end %>

                                       <%# Subtotal por Año %>
                                       <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                                         <td colspan="5" style="text-align: right; padding: 1.2rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; font-size: 1rem; letter-spacing: 0.5px;">
                                           Subtotal Gestión <%= year %>:
                                         </td>
                                         <td style="text-align: right; padding: 1.2rem; font-weight: 800; color: var(--text-main); font-size: 1.4rem;">
                                           <%= number_with_precision(year_draft_subtotal, precision: 0) %>
                                         </td>
                                       </tr>
                                     <% end %>
                                     
                                     <%# Gran Total Final %>
                                     <tr style="background: #f8fafc; border-top: 2px solid #cbd5e1;">
                                       <td colspan="5" style="text-align: right; padding: 1.5rem 1.2rem; font-weight: 800; text-transform: uppercase; font-size: 1.25rem; letter-spacing: 1px;">
                                         TOTAL BORRADORES/ANULADOS:
                                       </td>
                                       <td style="text-align: right; padding: 1.5rem 1.2rem; font-weight: 900; font-size: 1.8rem;">
                                         <%= number_with_precision(draft_grand_total, precision: 0) %>
                                       </td>
                                     </tr>
                                   <% end %>
<% base_query ||= item.sale_details.joins(:sale).where(sales: { status_priority: [8, 6, 7, 10] }) %>
<% if base_query.count > 50 %>
  <tr>
    <td colspan="7" class="text-center" style="padding: 1.5rem; color: #64748b; font-weight: 600; font-style: italic; background: #f1f5f9;">
      <i class="fas fa-info-circle mr-1"></i> Mostrando solo las últimas 50 transacciones sin concretar.
    </td>
  </tr>
<% end %>
                                 </tbody>
                              </table>
                        </div>
                  </div>
             <div class="clearfix"></div>
