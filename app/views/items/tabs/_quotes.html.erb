                <div class="white-box" style="border: none; padding: 0;">
                      <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                              <table class="table product-overview" style="margin-bottom: 0;">
                                <thead style="background: #fdf2f8;">
                                  <tr>
                                    <th style="padding: 1.2rem;">Fecha</th>
                                    <th style="padding: 1.2rem;">Nro Cotización</th>
                                    <th style="padding: 1.2rem;">Usuario</th>
                                    <th style="padding: 1.2rem;">Cliente</th>
                                    <th style="padding: 1.2rem; text-align: right;">Cant. (<%= item.unit.name.upcase %>S)</th>
                                  </tr>
                                </thead>

                                <tbody>
                                  <% 
    # Carga optimizada para Cotizaciones
    base_query = item.sale_details.joins(:sale).where(sales: { status_priority: 9 })
    quote_details = base_query.includes(:sale => [:user, :client]).order("sales.created_at DESC").limit(50)
    quotes_by_year = quote_details.group_by { |sd| sd.sale.created_at.year }
                                    
                                    if quotes_by_year.empty?
                                  %>
                                    <tr>
                                      <td colspan="5" class="text-center" style="padding: 3rem; color: var(--text-muted);">
                                        <i class="fas fa-file-invoice fa-3x mb-3" style="opacity: 0.3;"></i>
                                        <p>No hay cotizaciones registradas para este producto.</p>
                                      </td>
                                    </tr>
                                  <% else %>
                                    <% quotes_by_year.each do |year, details| %>
                                      <tr style="background: #fdf2f8;">
                                        <td colspan="5" style="padding: 0.8rem 1.2rem; font-weight: 800; color: #db2777; font-size: 1rem;">
                                          <i class="far fa-calendar-alt mr-2"></i> Gestión <%= year %>
                                        </td>
                                      </tr>

                                      <% details.each do |detail| 
                                         quote = detail.sale
                                         qty = detail.qty.to_f
                                      %>
                                        <tr>
                                          <td style="padding: 1rem 1.2rem; color: var(--text-muted); font-size: 0.9rem;">
                                            <%= quote.created_at.strftime("%d/%m/%Y") %>
                                          </td>
                                          <td style="padding: 1rem 1.2rem;">
                                            <%= link_to note_sale_sale_path(quote), remote: true, style: "text-decoration: none;" do %>
                                              <span class="badge" style="background: #fdf2f8; color: #db2777; border: 1px solid #fbcfe8; font-weight: 700; padding: 4px 8px; cursor: pointer;">
                                                <%= quote.number %>
                                              </span>
                                            <% end %>
                                          </td>
                                          <td style="padding: 1rem 1.2rem; color: var(--text-main); font-size: 0.9rem;"><%= quote.user.name || quote.user.email %></td>
                                          <td style="padding: 1rem 1.2rem; color: var(--text-main); font-size: 0.9rem; font-weight: 500;"><%= quote.client.name %></td>
                                          <td style="padding: 1rem 1.2rem; text-align: right; font-weight: 700; color: var(--text-main); font-size: 1rem;">
                                            <%= number_with_precision(qty, precision: 0) %> <small style="font-size: 0.75rem; color: var(--text-muted);"><%= item.unit.name.downcase %>s</small>
                                          </td>
                                        </tr>
                                      <% end %>
                                    <% end %>
                                  <% end %>
<% base_query ||= item.sale_details.joins(:sale).where(sales: { status_priority: 9 }) %>
<% if base_query.count > 50 %>
  <tr>
    <td colspan="5" class="text-center" style="padding: 1.5rem; color: #64748b; font-weight: 600; font-style: italic; background: #fdf2f8;">
      <i class="fas fa-info-circle mr-1"></i> Mostrando solo las últimas 50 cotizaciones registradas.
    </td>
  </tr>
<% end %>
                                </tbody>
                              </table>
                        </div>
