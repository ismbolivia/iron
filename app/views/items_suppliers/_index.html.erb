<div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
  <table class="table product-overview" style="margin-bottom: 0;">
    <thead style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
      <tr>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Proveedor</th>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Contacto / Email</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Teléfono / Celular</th>
        <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800;">Acciones</th>
      </tr>
    </thead>

    <tbody>
      <% item.items_suppliers.each do |items_supplier| %>
        <tr style="transition: all 0.2s;">
          <td style="padding: 1rem 1.2rem; vertical-align: middle;">
            <div style="font-weight: 700; color: var(--text-main);"><%= items_supplier.supplier.name %></div>
            <div style="font-size: 0.7rem; color: var(--accent-indigo); font-weight: 700; text-transform: uppercase;">Proveedor Asociado</div>
          </td>
          <td style="padding: 1rem 1.2rem; vertical-align: middle;">
            <div style="font-size: 0.9rem; color: var(--text-main);"><%= items_supplier.supplier.email %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted);"><i class="far fa-envelope mr-1"></i> Correo Electrónico</div>
          </td>
          <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
             <div style="font-weight: 600; color: var(--text-main);"><%= items_supplier.supplier.phone.present? ? items_supplier.supplier.phone : '-' %></div>
             <div style="font-size: 0.8rem; color: var(--accent-green); font-weight: 600;"><%= items_supplier.supplier.mobile %></div>
          </td>
          <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: right;">
            <%= link_to items_supplier, method: :delete, id:'id_supplier_item', data: { confirm: '¿Está seguro de desasociar este proveedor?' }, remote: true, class: "btn btn-sm", style: "background: #fff1f2; color: #e11d48; border: 1px solid #ffe4e6; font-weight: 600; border-radius: 8px;" do %>
              <i class="fas fa-unlink mr-1"></i> Desactivar
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
