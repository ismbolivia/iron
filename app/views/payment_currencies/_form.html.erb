
<%= form_for :payment_currency, url: payment_currencies_url, method: :post, remote: true do |form| %>
    <%= form.hidden_field :payment_type_id %>
    <%= form.hidden_field :sale_id %>
<div class="row">
  <div id="div-error-ef"></div>
    <div class="col-xs-12"> 
      <div id="div-error"></div>
    </div>
    <div class="col-xs-12">  
      <div class="form-group">                   
        <div class="input-group">
          <div class="input-group-addon"><i class="fas fa-diagnoses"></i></div>
          <%= form.collection_select :currency_id, @currencies, :id, :name, 
              {selected: @payment_currency.currency_id, include_blank: 'Seleccione la divisa que desea utilizar '}, {class: "form-control"} %>  
        </div>
      </div>
    </div>
</div>
<div class="field">

</div>

<div class="actions">
    <%= form.submit 'Siguiente', class: "btn btn-success" %>
</div>
<% end %>




