<div class="modal-content-payment">
  <div class="modal-header modal-header-success " >
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"> [ × ] </button>
    	<h2><i class=" fas fa-chart-line "></i> <%= @title %></h2>
  </div>

  <div class="modal-body">
  	<ul class="nav nav-tabs" role="tablist">
	    <li role="pre" class="active"><a href="#movement" aria-controls="movement" role="tab" data-toggle="tab" aria-expanded="true"><span><i class="fas fa-upload text-warning"></i></span> Extracto previa</a></li>	   
	    
	    <li role="pre" class=""><a href="#pdf" aria-controls="pdf" role="tab" data-toggle="tab" aria-expanded="false"><span><i class="fas fa-chart-bar text-red"></i></span> Pdf</a></li>
	</ul>
	<div class="tab-content">
	    <div role="tabpanel" class=" tab-pane active" id="movement">
	        <div class="table-responsive">
	           <div class="col-md-12 col-sm-12">   			

					<table class="table">
					  <thead>
					   
					   
					    <tr>
					      <th>N°</th>
					      <th>Metodo de pago</th>
					      <th>Monto</th>
					      <th>Descuento</th>
					      <th>N° Venta</th>
					      <th>Fecha de pago</th>
					      <th colspan="2"></th>
					    </tr>
					  </thead>
					  <tbody>
					    <% @payments_ranges.each do |payment| %>
					      <tr>
					        <td><%= payment.get_num_payment %></td>
					        <td><%= payment.payment_type.nethod %></td>
					        <td><%= @mycompany.get_current_currency.symbol%><%= payment.rode %></td>
					        <td><%= number_to_percentage(payment.discount, precision: 1) %></td>
					        <td><%= payment.sale.proformas.first.number_recibo %></td>
					        <td><%= payment.created_at.strftime("%d/%m/%Y") %></td>
					       
					        <% if current_user.is_admin? %>
					        <td>
					          <%= button_to edit_payment_path(payment), {method: :get, class: "btn btn-info"} do %>
					            <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> Editar
					          <% end %>
					        </td>
					        <td>
					          <%= button_to payment, { method: :delete, data: { confirm: '¿Está seguro?' }, class: "btn btn-danger" } do %>
					            <span class="glyphicon glyphicon-trash" aria-hidden="true"> </span> Eliminar
					          <% end %>
					        </td>
					        <% end %>
					      </tr>
					    <% end %>
					  </tbody>
					</table>
	              
	         </div>
	    </div>
	</div>
 
	 <div role="tabpanel" class="tab-pane" id="pdf">
	      <div class="table-responsive">
	           <div class="col-md-12 col-sm-12">                 
	             <br>  
	               <embed src="<%= @url_payment_range_pdfs %>" type="application/pdf" width="100%" height="400px" />                       
	            </div>
	        </div> 
	</div>

	</div>    
  </div>
</div>
