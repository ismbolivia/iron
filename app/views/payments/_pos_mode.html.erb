<div class="pos-payment-container animate__animated animate__fadeIn">
  <!-- Sidebar/Left Panel: Search and Sales List -->
  <div class="pos-payment-sidebar">
    <div class="pos-payment-header">
      <!-- 💰 Comisión Acumulada -->
      <%
        comisiones_pos = Payment.joins(:sale)
                                .where(sales: { user_id: current_user.id })
                                .where(state: :confirmed, commission_paid: false)
                                .sum(:commission_amount).to_f.round(2)
      %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
          <span style="font-weight: 800; color: #1e293b; font-size: 0.95rem;">📋 Notas por Cobrar</span>
      </div>

      <div class="pos-search-wrapper shadow-sm">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="pos-payment-search" class="pos-search-input" placeholder="Buscar cliente o nota..." autocomplete="off">
        <button class="search-clear-btn" id="clear-search" style="display:none">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="search-helper-text mt-2 px-1">
        <span class="badge badge-light text-muted">Nota #</span>
        <span class="badge badge-light text-muted">Cliente</span>
      </div>
    </div>
    
    <div class="pos-payment-list-container" id="pos-payment-list">
      <%= render partial: 'pos_results' %>
    </div>
  </div>

  <!-- Main/Right Panel: Sale Detail and Payment Form -->
  <div class="pos-payment-main" id="pos-payment-detail-container">
    <div class="empty-detail-state">
      <div class="text-center">
        <div class="mb-4">
          <i class="fas fa-hand-pointer fa-4x text-muted opacity-25"></i>
        </div>
        <h4 class="text-muted font-weight-bold">Seleccione una venta</h4>
        <p class="text-muted small">Elija una nota de la izquierda para ver detalles y cobrar.</p>
      </div>
    </div>
  </div>
</div>

<!-- Contenedor personalizado para Toasts (Notificaciones) -->
<div id="pos-toast-container" class="pos-toast-container"></div>

<script>
  $(document).ready(function() {
    var timer;
    $('#pos-payment-search').on('keyup', function() {
      var keywords = $(this).val();
      
      // Control de botón "limpiar"
      if (keywords.length > 0) {
        $('#clear-search').fadeIn(200);
      } else {
        $('#clear-search').fadeOut(200);
      }

      clearTimeout(timer);
      timer = setTimeout(function() {
        $.ajax({
          url: '/payments_pos_search',
          type: 'GET',
          data: { keywords: keywords },
          dataType: 'script'
        });
      }, 500); // Retraso aumentado para rendimiento
    });

    $('#clear-search').on('click', function() {
      $('#pos-payment-search').val('').trigger('keyup').focus();
    });
  });

  function selectPosSale(saleId) {
    // Add active class to the selected item
    $('.pos-payment-item').removeClass('active');
    $('[data-id="' + saleId + '"]').addClass('active');

    $.ajax({
      url: '/payments_pos_search',
      type: 'GET',
      data: { sale_id: saleId },
      dataType: 'script',
      beforeSend: function() {
        $("#pos-payment-detail-container").html('<div class="empty-detail-state"><div class="spinner-border text-primary" role="status"></div></div>');
      }
    });
  }

  function showPosNotification(message) {
    var toastId = 'toast-' + Date.now();
    var toastHtml = `
      <div id="${toastId}" class="pos-toast shadow-lg animate__animated animate__fadeInRight">
        <div class="pos-toast-icon bg-success">
          <i class="fas fa-check text-white"></i>
        </div>
        <div class="pos-toast-message">
          <strong>¡Éxito!</strong><br>
          <span>${message}</span>
        </div>
        <button type="button" class="pos-toast-close" onclick="$('#${toastId}').remove()"><i class="fas fa-times"></i></button>
      </div>
    `;
    
    $('#pos-toast-container').append(toastHtml);
    
    setTimeout(function() {
      $('#' + toastId).removeClass('animate__fadeInRight').addClass('animate__fadeOutRight');
      setTimeout(function() { $('#' + toastId).remove(); }, 500);
    }, 4500);
  }

  function highlightNewPayment(paymentId) {
    setTimeout(function() {
      var row = $('#payment-row-' + paymentId);
      if (row.length) {
        row.addClass('highlight-success');
        setTimeout(function() {
          row.removeClass('highlight-success');
        }, 3000);
      }
    }, 100);
  }
</script>

<style>
  .pos-payment-container {
    display: flex;
    height: calc(100vh - 180px);
    background: #f8f9fa;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    border: 1px solid #e2e8f0;
  }

  .pos-payment-sidebar {
    width: 420px;
    background: #fff;
    border-right: 1px solid #f1f5f9;
    display: flex;
    flex-direction: column;
    z-index: 10;
  }

  .pos-payment-header {
    padding: 25px 20px;
    background: #fff;
    border-bottom: 1px solid #f1f5f9;
  }

  .pos-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 16px;
    padding: 2px 15px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .pos-search-wrapper:focus-within {
    background: #fff;
    border-color: #4f46e5;
    box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.1), 0 4px 6px -2px rgba(79, 70, 229, 0.05) !important;
  }

  .search-icon {
    color: #94a3b8;
    font-size: 1rem;
    margin-right: 12px;
    transition: color 0.3s;
  }

  .pos-search-wrapper:focus-within .search-icon {
    color: #4f46e5;
  }

  .pos-search-input {
    flex: 1;
    border: none;
    background: transparent;
    height: 52px;
    font-size: 1rem;
    font-weight: 500;
    color: #1e293b;
    outline: none !important;
  }

  .pos-search-input::placeholder {
    color: #94a3b8;
    font-weight: 400;
  }

  .search-clear-btn {
    border: none;
    background: #e2e8f0;
    color: #64748b;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-clear-btn:hover {
    background: #cbd5e1;
    color: #1e293b;
  }

  .search-helper-text {
    display: flex;
    gap: 6px;
  }
  
  .search-helper-text .badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 6px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    background: #f1f5f9;
  }

  .pos-payment-list-container {
    flex: 1;
    overflow-y: auto;
    padding: 15px;
    background: #fff;
  }

  .pos-payment-main {
    flex: 1;
    background: #f1f5f9;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .empty-detail-state {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
  }

  /* Animations */
  .animate__animated {
    animation-duration: 0.5s;
  }

  /* Custom Scrollbar */
  .pos-payment-list-container::-webkit-scrollbar { width: 4px; }
  .pos-payment-list-container::-webkit-scrollbar-track { background: transparent; }
  .pos-payment-list-container::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
  
  .pos-payment-main::-webkit-scrollbar { width: 6px; }
  .pos-payment-main::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

  /* Toasts Styles */
  .pos-toast-container {
    position: fixed;
    top: 25px;
    right: 25px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .pos-toast {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 12px;
    padding: 14px 18px;
    min-width: 320px;
    border-left: 5px solid #10b981;
    animation-duration: 0.4s;
  }
  
  .pos-toast-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 14px;
    flex-shrink: 0;
  }
  
  .pos-toast-message {
    flex: 1;
    font-size: 0.9rem;
    color: #334155;
    line-height: 1.3;
  }
  
  .pos-toast-close {
    background: transparent;
    border: none;
    color: #94a3b8;
    margin-left: 12px;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0;
  }
  .pos-toast-close:hover { color: #475569; }

  /* Highlight Animation */
  .highlight-success {
    background-color: rgba(16, 185, 129, 0.15) !important;
  }
</style>
