<% if @sales_with_debt&.any? %>
  <div class="pos-payment-items">
    <% @sales_with_debt.each do |sale| %>
      <div class="pos-payment-item <%= 'paid-state' if sale.saldo <= 0 %>" 
           data-id="<%= sale.id %>" 
           onclick="selectPosSale(<%= sale.id %>)">
        
        <div class="text-center position-relative mb-1">
          <!-- Fecha discretamente arriba a la derecha -->
          <div class="position-absolute text-muted" style="right: 0; top: 0; font-size: 0.75rem; font-weight: 600;">
            <%= sale.date.strftime("%d/%m/%y") %>
          </div>
          
          <!-- Título Centrado que Resalta (Número de Nota Oficial) -->
          <div class="sale-number-centered font-weight-bold text-primary mb-1">
            NOTA #<%= sale.number_sale || sale.number %>
          </div>
          
          <!-- Nombre del Cliente debajo del título -->
          <div class="client-name-centered text-dark truncate-text">
            <i class="fas fa-user-circle text-muted mr-1"></i><%= sale.client.try(:name) || 'Cliente General' %>
          </div>
        </div>
        
        <div class="text-center mt-2 pt-2" style="border-top: 1px dashed #e2e8f0;">
          <% if sale.saldo > 0 %>
            <div class="text-danger text-uppercase font-weight-bold" style="font-size: 0.7rem;">
              <%= sale.saldo == sale.total_final ? "Monto a Cobrar" : "Saldo Pendiente" %>
            </div>
            <div class="font-weight-bold text-danger mt-1" style="font-size: 1.15rem; line-height: 1;">
              <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(sale.saldo, precision: 2) %>
            </div>
          <% else %>
            <div class="text-success font-weight-bold d-inline-flex align-items-center" style="font-size: 0.9rem; background: #dcfce7; padding: 4px 12px; border-radius: 16px;">
              <i class="fas fa-check-circle mr-1"></i> PAGADO
            </div>
          <% end %>
        </div>
        
        <% if sale.saldo > 0 %>
          <% percent = (100 - (sale.saldo / sale.total_final * 100)).round %>
          <div class="mini-progress mt-2">
            <div class="bar bg-primary" style="width: <%= percent %>%"></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5 text-muted opacity-50">
    <i class="fas fa-cash-register fa-4x mb-3"></i>
    <p class="font-weight-bold">No hay notas pendientes</p>
  </div>
<% end %>

<style>
  .pos-payment-item {
    padding: 12px 14px;
    border-radius: 12px;
    margin-bottom: 10px;
    background: #fff;
    border: 1.5px solid #f1f5f9;
    cursor: pointer;
    transition: all 0.25s ease-out;
    position: relative;
    overflow: hidden;
  }

  .pos-payment-item:hover {
    background: #f8fafc;
    border-color: #cbd5e1;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.04);
  }

  .pos-payment-item.active {
    background: #fff;
    border-color: #4f46e5;
    box-shadow: 0 4px 15px rgba(79, 70, 229, 0.12);
  }

  .pos-payment-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 70%;
    width: 4px;
    background: #4f46e5;
    border-radius: 0 4px 4px 0;
  }

  .sale-number-centered {
    font-size: 1.1rem;
    letter-spacing: -0.3px;
    line-height: 1.1;
  }

  .client-name-centered {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .mini-progress {
    height: 4px;
    background: #f1f5f9;
    border-radius: 10px;
    overflow: hidden;
  }
  
  .mini-progress .bar {
    height: 100%;
    border-radius: 10px;
  }

  .truncate-text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
