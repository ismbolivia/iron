<div class="pos-detail-wrapper animate__animated animate__fadeIn">
  <!-- Header: Resumen de la Venta -->
  <div class="pos-detail-header p-4 bg-white border-bottom d-flex justify-content-between align-items-center">
    <div>
      <h4 class="mb-1 font-weight-bold text-dark" style="letter-spacing: -1px;">
        Venta #<%= @sale.proformas.first.try(:number) || @sale.number_sale %>
      </h4>
      <p class="text-muted mb-0"><i class="fas fa-id-card-alt mr-1 text-primary"></i> <%= @sale.client.try(:name) || "Cliente General" %></p>
    </div>
    <div class="text-right">
      <div class="text-muted smaller font-weight-bold text-uppercase opacity-75">Monto Total</div>
      <div class="h2 font-weight-bold text-dark mb-0">
        <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(@sale.total_final, precision: 2) %>
      </div>
    </div>
  </div>

  <div class="pos-detail-content p-4">
    <div class="row">
      <!-- Left Column: Details and History -->
      <div class="col-lg-7">
        
        <!-- Progress Summary -->
        <div class="modern-card mb-4 bg-white p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h6 class="font-weight-bold text-dark mb-1">Estado de Pago</h6>
              <% percent = (100 - (@sale.saldo / @sale.total_final * 100)).round rescue 0 %>
              <p class="text-muted small mb-0">Se ha cobrado el <%= percent %>% del total</p>
            </div>
            <% if @sale.saldo <= 0.1 %>
              <span class="badge badge-pill badge-success-soft px-3 py-2">TOTALMENTE PAGADO</span>
            <% else %>
              <span class="badge badge-pill badge-warning-soft px-3 py-2">PENDIENTE</span>
            <% end %>
          </div>
          <div class="progress" style="height: 12px; border-radius: 10px; background: #f1f5f9;">
            <div class="progress-bar bg-primary-gradient progress-bar-striped progress-bar-animated" role="progressbar" style="width: <%= percent %>%"></div>
          </div>
        </div>

        <!-- Items Table -->
        <div class="modern-card mb-4 overflow-hidden bg-white">
          <div class="card-header bg-white py-3 border-0">
            <h6 class="mb-0 font-weight-bold text-dark"><i class="fas fa-receipt mr-2 text-primary"></i> Detalle de Artículos</h6>
          </div>
          <div class="table-responsive">
            <table class="table table-sm table-modern mb-0">
              <thead class="bg-light">
                <tr>
                  <th class="px-4 py-3 border-0 text-muted smaller font-weight-bold text-uppercase">Producto</th>
                  <th class="text-center border-0 text-muted smaller font-weight-bold text-uppercase">Cant.</th>
                  <th class="text-right px-4 border-0 text-muted smaller font-weight-bold text-uppercase">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <% @sale.sale_details.each do |detail| %>
                  <tr>
                    <td class="px-4 py-3">
                      <div class="font-weight-bold text-dark"><%= detail.item.name %></div>
                      <div class="smaller text-muted"><%= detail.item.code %></div>
                    </td>
                    <td class="text-center align-middle font-weight-bold"><%= detail.qty %></td>
                    <td class="text-right px-4 align-middle font-weight-bold text-dark">
                      <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(detail.subtotal, precision: 2) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Payments History -->
        <div class="modern-card overflow-hidden bg-white">
          <div class="card-header bg-white py-3 border-0">
            <h6 class="mb-0 font-weight-bold text-dark"><i class="fas fa-history mr-2 text-info"></i> Historial de Cobros</h6>
          </div>
          <div class="card-body p-0">
            <% if @payments.any? %>
              <table class="table table-sm mb-0 table-modern">
                <thead class="bg-light text-muted smaller">
                  <tr>
                    <th class="px-4 py-2 font-weight-bold text-uppercase">Fecha</th>
                    <th class="font-weight-bold text-uppercase">Nro REC</th>
                    <th class="font-weight-bold text-uppercase">Método</th>
                    <th class="text-right font-weight-bold text-uppercase">Monto</th>
                    <th class="text-center px-4 font-weight-bold text-uppercase" style="width: 80px;"><i class="fas fa-print"></i></th>
                  </tr>
                </thead>
                <tbody>
                  <% @payments.each do |p| %>
                    <tr id="payment-row-<%= p.id %>" style="transition: background-color 0.5s ease; <%= 'background: #fdf2f2;' if p.rejected? %>">
                      <td class="px-4 py-3 smaller text-muted align-middle">
                        <%= (p.date || p.created_at).strftime("%d/%m/%y") %>
                        <div class="smaller opacity-50"><%= p.created_at.strftime("%H:%M") %></div>
                      </td>
                      <td class="font-weight-bold text-dark align-middle">#<%= p.num_payment %></td>
                      <td class="align-middle">
                        <span class="badge badge-pill badge-light border text-muted px-3"><%= p.payment_type.try(:nethod) %></span>
                        <% if p.rejected? %>
                          <span class="badge badge-danger px-2 py-1" style="font-size: 0.7rem; margin-left: 5px; background-color: #ef4444; color: white;">RECHAZADO</span>
                          <div class="smaller text-danger mt-1" style="font-weight: 600;"><i class="fas fa-exclamation-circle"></i> <%= p.audit_note %></div>
                        <% elsif p.draft? %>
                          <span class="badge badge-warning px-2 py-1" style="font-size: 0.7rem; margin-left: 5px; background-color: #f59e0b; color: white;">EN ARQUEO</span>
                        <% end %>
                      </td>
                      <td class="text-right font-weight-bold align-middle <%= p.rejected? ? 'text-danger' : 'text-success' %>">
                        <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(p.rode, precision: 2) %>
                      </td>
                      <td class="text-center px-2 align-middle">
                        <div class="d-flex justify-content-center gap-1">
                          <%= link_to payment_pdf_path(payment_id: p.id, format: 'pdf'), class: "btn btm-sm btn-icon-only text-primary mr-1", target: "_blank", title: "Imprimir Recibo" do %>
                            <i class="fas fa-print"></i>
                          <% end %>

                          <% if current_user.is_admin? || current_user.is_manager? %>
                            <button type="button" class="btn btn-sm btn-icon-only text-warning mr-1" 
                                    onclick="editPosPayment('<%= p.id %>', '<%= p.rode %>', '<%= p.num_payment %>', '<%= p.date %>', '<%= p.payment_type_id %>', '<%= p.box_id %>', '<%= p.account_id %>')"
                                    title="Editar Cobro">
                              <i class="fas fa-edit"></i>
                            </button>

                            <%= link_to p, method: :delete, remote: true, data: { confirm: '¿Está seguro de eliminar este cobro? El movimiento de caja será revertido.' }, class: "btn btn-sm btn-icon-only text-danger", title: "Eliminar Cobro" do %>
                              <i class="fas fa-trash-alt"></i>
                            <% end %>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% else %>
              <div class="p-5 text-center text-muted">Aún no se han registrado cobros.</div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Right Column: Payment Form -->
      <div class="col-lg-5">
        <% if @sale.saldo > 0.1 %>
          <div class="payment-action-card sticky-top shadow-lg" style="top: 20px;">
            <div class="card-topping bg-primary-gradient p-4 text-center">
              <div class="text-white-50 text-uppercase smaller font-weight-bold mb-1">Saldo por Cobrar</div>
              <div class="h1 text-white font-weight-bold mb-0">
                <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(@sale.saldo, precision: 2) %>
              </div>
            </div>
            
            <div class="card-body p-4 bg-white">
              <div id="pos-payment-errors"></div>
              <%= form_for @payment, url: payments_path, method: :post, remote: true, html: { id: "pos-payment-confirm-form" } do |f| %>
                <%= f.hidden_field :sale_id %>
                
                <div class="row">
                  <div class="col-md-6">
                    <div class="form-group mb-4">
                      <label class="pos-input-label">Nro. de Recibo</label>
                      <%= f.text_field :num_payment, class: "form-control pos-input-field", placeholder: "000" %>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-group mb-4">
                      <label class="pos-input-label">Fecha de Registro</label>
                      <%= f.date_field :date, class: "form-control pos-input-field", value: Date.current %>
                    </div>
                  </div>
                </div>

                <div class="form-group mb-4">
                  <label class="pos-input-label">Método de Cobro</label>
                  <%= f.collection_select :payment_type_id, @methods, :id, :nethod, 
                      { include_blank: 'Seleccione el método...' }, 
                      { class: "form-control pos-input-field custom-select", required: true, id: "payment_method_select" } %>
                </div>

                <div class="row">
                  <div class="col-md-7">
                    <!-- Para Efectivo (ID: 1): Mostrar Caja de Ruta -->
                    <div class="form-group mb-4" id="select-box-wrapper" style="display: none;">
                      <label class="pos-input-label">Caja de Ruta</label>
                      <%= f.collection_select :box_id, @boxes || [], :id, :name_with_currency, 
                          { include_blank: 'Seleccione Caja...' }, 
                          { class: "form-control pos-input-field custom-select", id: "payment_box_select" } %>
                    </div>
                    
                    <!-- Para Otros: Mostrar Cuenta -->
                    <div class="form-group mb-4" id="select-account-wrapper">
                      <label class="pos-input-label">Cuenta de Depósito</label>
                      <%= f.collection_select :account_id, @accounts || [], :id, :name, 
                          { include_blank: 'Seleccione Cuenta...' }, 
                          { class: "form-control pos-input-field custom-select", id: "payment_account_select", required: true } %>
                    </div>
                  </div>
                  <div class="col-md-5">
                    <div class="form-group mb-4">
                      <label class="pos-input-label">Descuento (%)</label>
                      <div class="input-group">
                        <%= f.number_field :discount, class: "form-control pos-input-field", placeholder: "0", min: 0, max: 100 %>
                        <div class="input-group-append">
                          <span class="input-group-text bg-light border-left-0" style="border-radius: 0 12px 12px 0; border: 1.5px solid #e2e8f0; border-left: none;">%</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="form-group mb-5">
                  <label class="pos-input-label">Importe a Recibir</label>
                  <div class="input-group amount-group">
                    <div class="input-group-prepend">
                      <span class="input-group-text border-0 bg-transparent text-primary font-weight-bold"><%= @mycompany.get_current_currency.symbol %></span>
                    </div>
                    <%= f.number_field :rode, class: "form-control amount-field", 
                        placeholder: "0.00", required: true, step: :any,
                        value: sprintf("%.2f", @sale.saldo) %>
                  </div>
                </div>

                <% if current_user.can_direct_pay? %>
                  <div class="direct-pay-wrapper mb-5 p-3 rounded-xl border d-flex justify-content-between align-items-center" style="background: #f0fdf4; border-color: #bcf0da !important;">
                    <div style="flex: 1;">
                      <label class="pos-input-label mb-1" style="color: #065f46;">Abono Directo</label>
                      <p class="text-muted smaller mb-0" style="font-size: 0.7rem; line-height: 1.2;">Saltar proceso de arqueo e ingresar dinero a caja inmediatamente.</p>
                    </div>
                    <div class="custom-control custom-switch">
                      <%= f.check_box :state, { class: "custom-control-input", id: "direct_pay_switch", checked: true }, "confirmed", "draft" %>
                      <label class="custom-control-label" for="direct_pay_switch" style="cursor: pointer;"></label>
                    </div>
                  </div>
                <% end %>

                <%= f.button class: "btn btn-primary-gradient btn-block btn-lg py-4 rounded-xl font-weight-bold shadow-lg transform-hover", 
                             data: { disable_with: "<i class='fas fa-spinner fa-spin mr-2'></i> PROCESANDO..." } do %>
                  <i class="fas fa-check-circle mr-2"></i> REGISTRAR COBRO
                <% end %>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="success-card sticky-top text-center p-5 bg-white shadow-sm border-0" style="top: 20px; border-radius: 24px;">
            <div class="mb-4 pulse-animation">
              <i class="fas fa-check-circle fa-6x text-success"></i>
            </div>
            <h3 class="font-weight-bold text-dark">Totalmente Cancelada</h3>
            <p class="text-muted mb-4">Esta nota ya no cuenta con deudas pendientes.</p>
            <div class="d-grid gap-2">
              <%= link_to payments_path(current_sale_id: @sale.id, format: :pdf), class: "btn btn-outline-primary btn-block py-3 rounded-pill", target: "_blank" do %>
                <i class="fas fa-print mr-2"></i> IMPRIMIR HISTORIAL
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  .modern-card {
    border-radius: 20px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    border: 1px solid #f1f5f9;
  }

  .table-modern td { padding: 15px 10px; border-bottom: 1px solid #f8fafc; }
  .table-modern th { background: #f8fafc !important; }

  .bg-primary-gradient { 
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%) !important; 
  }
  
  .badge-success-soft { background: #dcfce7; color: #16a34a; }
  .badge-warning-soft { background: #fef3c7; color: #d97706; }

  .pos-input-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    color: #64748b;
    text-transform: uppercase;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  .pos-input-field {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    height: 50px;
    padding: 10px 15px;
    font-weight: 600;
  }

  .amount-field {
    border: none !important;
    background: transparent !important;
    height: 60px;
    font-size: 2rem;
    font-weight: 800;
    color: #10b981;
    text-align: right;
  }
</style>

<script>
  $(document).ready(function() {
    var originalBalance = parseFloat("<%= @sale.saldo %>");
    
    // Cambiar entre Caja y Cuenta según método de pago
    $('#payment_method_select').on('change', function() {
      var methodId = $(this).val();
      if (methodId === '1') { // Efectivo
        $('#select-box-wrapper').show().find('select').prop('required', true);
        $('#select-account-wrapper').hide().find('select').prop('required', false).val('');
      } else {
        $('#select-box-wrapper').hide().find('select').prop('required', false).val('');
        $('#select-account-wrapper').show().find('select').prop('required', true);
      }
    });

    $('#payment_method_select').trigger('change');
  });

  function editPosPayment(id, rode, num, date, methodId, boxId, accountId) {
    const form = $('#pos-payment-confirm-form');
    form.attr('action', '/payments/' + id);
    if (form.find('input[name="_method"]').length === 0) {
      form.append('<input type="hidden" name="_method" value="patch">');
    }
    $('#payment_rode').val(rode);
    $('#payment_num_payment').val(num);
    $('#payment_date').val(date);
    $('#payment_method_select').val(methodId).trigger('change');
    if (boxId) $('#payment_box_select').val(boxId);
    if (accountId) $('#payment_account_select').val(accountId);
  }
</script>
