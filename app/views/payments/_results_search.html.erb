<table class="table table-hover align-middle mb-0">
  <thead class="bg-light">
    <tr>
      <td colspan="8" class="p-0 border-0">
        <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
      </td>
    </tr>
    <tr class="text-uppercase small font-weight-bold text-muted">
      <th class="border-0 px-4">Recibo N°</th>
      <th class="border-0">Método</th>
      <th class="border-0 text-right">Monto</th>
      <th class="border-0 text-center">Descuento</th>
      <th class="border-0">Venta Ref.</th>
      <th class="border-0">Fecha</th>
      <th class="border-0 text-right px-4">Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @payments.each do |payment| %>
      <tr class="payment-row">
        <td class="px-4 font-weight-bold text-dark">
          <span class="badge badge-light p-2 border"><%= payment.get_num_payment %></span>
        </td>
        <td>
          <span class="payment-method-tag">
            <i class="fas fa-wallet text-muted mr-1"></i> <%= payment.payment_type.nethod %>
          </span>
        </td>
        <td class="text-right font-weight-bold text-success">
          <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(payment.rode, precision: 2) %>
        </td>
        <td class="text-center">
          <% if payment.discount.to_i > 0 %>
            <span class="badge badge-warning-soft text-warning px-2 py-1">
              <i class="fas fa-tag mr-1"></i> <%= number_to_percentage(payment.discount, precision: 1) %>
            </span>
          <% else %>
            <span class="text-muted small">-</span>
          <% end %>
        </td>
        <td>
          <span class="text-info font-weight-bold">
            <i class="fas fa-file-invoice mr-1"></i> <%= payment.sale.proformas.first.try(:number_recibo) || "S/N" %>
          </span>
        </td>
        <td class="text-muted">
          <%= payment.created_at.strftime("%d %b, %Y") %>
        </td>
        <td class="text-right px-4">
          <div class="btn-group shadow-sm rounded">
            <% if current_user.is_admin? %>
              <%= link_to edit_payment_path(payment), class: "btn btn-white btn-sm border", title: "Editar Pago" do %>
                <i class="fas fa-pencil-alt text-info"></i>
              <% end %>
              <%= link_to payment, method: :delete, data: { confirm: '¿Está seguro de eliminar este pago?' }, class: "btn btn-white btn-sm border", title: "Eliminar" do %>
                <i class="fas fa-trash-alt text-danger"></i>
              <% end %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<style>
  .payment-row { transition: all 0.2s; }
  .payment-row:hover { background-color: #f0f7ff !important; }
  .payment-method-tag { font-size: 0.9rem; color: #4a5568; }
  .badge-warning-soft { background-color: #fff9e6; border: 1px solid #ffeeba; }
  .btn-white { background: white; }
  .btn-white:hover { background: #f8f9fa; }
</style>