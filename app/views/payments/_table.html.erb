<table class="table">
  <thead>
    <tr>
      <th>N° Recibo</th>
      <th>Metodo de pago</th>
      <th>Monto</th>
      <th>Descuento</th>
      <th>Fecha de pago</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% payments.each do |payment| %>
      <tr>
        <td><%= payment.get_num_payment %></td>
        <td><%= payment.payment_type.nethod %></td>
        <td><%= @mycompany.get_current_currency.symbol %><%= payment.rode %></td>
        <td><%= number_to_percentage(payment.discount, precision: 1) %></td>
        <td><%= payment.created_at.strftime("%d/%m/%Y") %></td>
        <td> 
          <%= button_to  payment_path(payment), {method: :get,  remote:true, class: "btn btn-primary"} do %>
            <span class="fa fa-print" aria-hidden="true"> </span> 
          <% end %>
        </td>
        
        <td>
          <%= button_to edit_payment_path(payment), {method: :get, class: "btn btn-info"} do %>
            <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> Editar
          <% end %>
        </td>
        <td>
          <%= button_to payment, { method: :delete, data: { confirm: '¿Está seguro?' }, remote: true, class: "btn btn-danger" } do %>
            <span class="glyphicon glyphicon-trash" aria-hidden="true"> </span> Eliminar
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

