<table class="table table-sm table-hover border">
  <thead class="bg-light text-muted small">
    <tr>
      <th class="px-3 border-0">N° Recibo</th>
      <th class="border-0">Método</th>
      <th class="border-0 text-right">Monto</th>
      <th class="border-0 text-center">Desc.</th>
      <th class="border-0">Fecha</th>
      <th class="border-0 text-right px-3">Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% payments.each do |payment| %>
      <tr>
        <td class="px-3">
          <span class="badge badge-light border font-weight-bold text-dark"><%= payment.get_num_payment %></span>
        </td>
        <td class="small">
          <i class="fas fa-money-check-alt text-muted mr-1"></i> <%= payment.payment_type.nethod %>
        </td>
        <td class="text-right font-weight-bold text-success">
          <%= @mycompany.get_current_currency.symbol %><%= number_with_precision(payment.rode, precision: 2) %>
        </td>
        <td class="text-center small">
          <%= number_to_percentage(payment.discount, precision: 1) %>
        </td>
        <td class="text-muted small">
          <%= payment.created_at.strftime("%d/%m/%Y") %>
        </td>
        <td class="text-right px-3">
          <div class="btn-group shadow-xs">
            <%= link_to payment_path(payment), remote: true, class: "btn btn-white btn-xs border", title: "Imprimir" do %>
              <i class="fa fa-print text-primary"></i>
            <% end %>
            <%= link_to edit_payment_path(payment), class: "btn btn-white btn-xs border", title: "Editar" do %>
              <i class="glyphicon glyphicon-pencil text-info"></i>
            <% end %>
            <%= link_to payment, method: :delete, data: { confirm: '¿Está seguro?' }, remote: true, class: "btn btn-white btn-xs border", title: "Eliminar" do %>
              <i class="glyphicon glyphicon-trash text-danger"></i>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<style>
  .btn-xs { padding: 1px 5px; font-size: 12px; }
  .shadow-xs { box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
</style>

