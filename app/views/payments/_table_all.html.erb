
<table class="table">
  <thead>
    <tr>
      <th>N°</th>
      <th>Fecha de pago</th>
      <th>Metodo de pago</th>
      <th>Monto</th>
      <th>Descuento</th>
      <th>N° Proforma</th>
      <th colspan="1"></th>
    </tr>
  </thead>

  <tbody>
    <% payments.each do |payment| %>
      <tr>
        <td><%= payment.num_payment %></td>
         <td><%= payment.created_at.strftime("%d/%m/%Y") %></td>
         <td>
        <% if payment.payment_type.code == "EF" %>
          <span class="badge bg-purple"> <%= payment.payment_type.nethod %></span>
            <% end %>
        <% if payment.payment_type.code == "DB" %>
          <span class="badge bg-info"> <%= payment.payment_type.nethod %></span>
            <% end %>
        <% if payment.payment_type.code == "CB" %>
         <span class="badge bg-success"> <%= payment.payment_type.nethod %></span>
       <% end %>    

        </td>
        <td><%= payment.rode %> <%= @mycompany.get_current_currency.symbol%></td>
        <td><%= number_to_percentage(payment.discount, precision: 1) %> </td>
        <td><%= payment.sale.proformas.first.number_recibo %> </td>
        <% if can? :edit, payment %>        
        <td>
          <%= button_to edit_payment_path(payment), {method: :get, class: "btn btn-info"} do %>
            <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> Editar
          <% end %>
        </td>
        <% end %>
        <% if can? :destroy, payment %> 
        <td>
          <%= button_to payment, { method: :delete, data: { confirm: '¿Está seguro?' }, class: "btn btn-danger" } do %>
            <span class="glyphicon glyphicon-trash" aria-hidden="true"> </span> Eliminar
          <% end %>
        </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>