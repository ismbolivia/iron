<!DOCTYPE html>
<html>
<head>
  <meta charset='utf-8' />
  <title>Historial de Cobros - Venta</title>
  <style>
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #1e293b;
      font-size: 13px;
      line-height: 1.4;
      background: #fff;
      margin: 0;
    }
    .report-container {
      width: 100%;
      margin: 0 auto;
    }
    .header-section {
      width: 100%;
      border-bottom: 3px solid #4f46e5;
      padding-bottom: 20px;
      margin-bottom: 25px;
      display: table;
    }
    .header-left {
      display: table-cell;
      width: 60%;
      vertical-align: bottom;
    }
    .header-right {
      display: table-cell;
      width: 40%;
      text-align: right;
      vertical-align: bottom;
    }
    .company-name {
      font-size: 24px;
      font-weight: 800;
      color: #0f172a;
      letter-spacing: -0.5px;
      margin: 0 0 5px 0;
    }
    .report-title {
      font-size: 14px;
      text-transform: uppercase;
      font-weight: 700;
      color: #4f46e5;
      letter-spacing: 1px;
    }
    .sale-info-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 25px;
      display: table;
      width: 100%;
    }
    .info-item {
      display: table-cell;
      width: 33.33%;
    }
    .info-label {
      font-size: 11px;
      color: #64748b;
      text-transform: uppercase;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .info-value {
      font-size: 16px;
      color: #0f172a;
      font-weight: 600;
    }
    
    table.data-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }
    table.data-table th {
      background-color: #f1f5f9;
      color: #475569;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      padding: 12px 15px;
      text-align: left;
      border-bottom: 2px solid #cbd5e1;
    }
    table.data-table th.text-right { text-align: right; }
    table.data-table th.text-center { text-align: center; }
    
    table.data-table td {
      padding: 12px 15px;
      border-bottom: 1px solid #e2e8f0;
      color: #334155;
      font-size: 13px;
    }
    table.data-table td.text-right { text-align: right; font-weight: 600; }
    table.data-table td.text-center { text-align: center; }
    table.data-table tr:last-child td { border-bottom: 2px solid #cbd5e1; }
    
    .badge-method {
      background: #e2e8f0;
      color: #475569;
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: bold;
    }
    
    .totals-section {
      width: 100%;
      display: table;
    }
    .totals-spacer { display: table-cell; width: 60%; }
    .totals-box {
      display: table-cell;
      width: 40%;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 15px 20px;
    }
    .total-row {
      display: table;
      width: 100%;
      margin-bottom: 8px;
    }
    .total-row:last-child {
      margin-bottom: 0;
      padding-top: 8px;
      border-top: 1px dashed #cbd5e1;
    }
    .total-label {
      display: table-cell;
      text-align: left;
      color: #64748b;
      font-weight: 600;
    }
    .total-value {
      display: table-cell;
      text-align: right;
      font-weight: 800;
      font-size: 16px;
      color: #0f172a;
    }
    .total-final {
      color: #10b981;
      font-size: 20px;
    }
  </style>
</head>
<body>
  <% 
    sale = @payments_sale.first.try(:sale) 
    client_name = sale.client.try(:name) || 'Cliente General' rescue 'Cliente General'
    note_number = sale.proformas.first.try(:number_recibo) || sale.try(:number_sale) || sale.try(:number) || 'S/N' rescue 'S/N'
    total_paid = @payments_sale.sum(:rode)
    currency_sym = @mycompany.get_current_currency.symbol
  %>

  <div class="report-container">
    <!-- Encabezado del Reporte -->
    <div class="header-section">
      <div class="header-left">
        <h1 class="company-name"><%= @mycompany.name rescue 'Mi Empresa' %></h1>
        <div class="report-title">Historial y Extracto de Cobros</div>
      </div>
      <div class="header-right">
        <div style="font-size: 11px; color: #64748b; font-weight: bold; margin-bottom: 5px;">FECHA DE EMISIÓN</div>
        <div style="font-size: 15px; font-weight: 600;"><%= Date.current.strftime("%d/%m/%Y") %></div>
      </div>
    </div>

    <!-- Información de la Venta -->
    <div class="sale-info-box">
      <div class="info-item">
        <div class="info-label">Cliente / Entidad</div>
        <div class="info-value"><%= client_name %></div>
      </div>
      <div class="info-item">
        <div class="info-label">Reporte Vinculado a Nota N°</div>
        <div class="info-value" style="color: #4f46e5;">#<%= note_number %></div>
      </div>
      <div class="info-item" style="text-align: right;">
        <div class="info-label">Estado de Cuenta</div>
        <div class="info-value">
          <% if sale && sale.saldo <= 0 %>
            <span style="color: #10b981;">Totalmente Pagado</span>
          <% else %>
            <span style="color: #f59e0b;">Con Saldo Pendiente</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Tabla Detalle de Pagos -->
    <table class="data-table">
      <thead>
        <tr>
          <th>Fecha del Pago</th>
          <th class="text-center">N° Recibo (Sistema)</th>
          <th>Método de Ingreso</th>
          <th class="text-right">Descuento</th>
          <th class="text-right">Monto Recibido</th>
        </tr>
      </thead>
      <tbody>
        <% if @payments_sale.any? %>
          <% @payments_sale.each do |payment| %>
            <tr>
              <td>
                <span style="font-weight: 600;"><%= payment.created_at.strftime("%d/%m/%Y") %></span><br>
                <span style="font-size: 11px; color: #94a3b8;"><%= payment.created_at.strftime("%H:%M") %> hrs</span>
              </td>
              <td class="text-center" style="font-weight: 700; color: #dc2626;">
                #<%= payment.get_num_payment %>
              </td>
              <td>
                <span class="badge-method"><%= payment.payment_type.try(:nethod) || 'Caja Común' %></span>
              </td>
              <td class="text-right">
                <%= number_to_percentage(payment.discount, precision: 1) %>
              </td>
              <td class="text-right" style="color: #059669;">
                <%= currency_sym %> <%= number_with_precision(payment.rode, precision: 2) %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="text-center" style="padding: 30px; color: #94a3b8; font-style: italic;">
              No se han registrado pagos para esta nota aún.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Resumen de Totales -->
    <div class="totals-section">
      <div class="totals-spacer"></div>
      <div class="totals-box">
        <% if sale %>
          <div class="total-row">
            <div class="total-label">Deuda Original:</div>
            <div class="total-value" style="font-size: 14px; color: #64748b;"><%= currency_sym %> <%= number_with_precision(sale.total_final, precision: 2) %></div>
          </div>
        <% end %>
        <div class="total-row">
          <div class="total-label" style="color: #0f172a;">Total Recaudado:</div>
          <div class="total-value total-final"><%= currency_sym %> <%= number_with_precision(total_paid, precision: 2) %></div>
        </div>
        <% if sale && sale.saldo > 0 %>
          <div class="total-row" style="border-top: none; padding-top: 0;">
            <div class="total-label" style="color: #ef4444; font-size: 12px;">Saldo Restante:</div>
            <div class="total-value" style="color: #ef4444; font-size: 14px;"><%= currency_sym %> <%= number_with_precision(sale.saldo, precision: 2) %></div>
          </div>
        <% end %>
      </div>
    </div>
    
  </div>
</body>
</html>
