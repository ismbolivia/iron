    function addToCartByIndex(index) {
        var p = allProducts[index];
        if(!p) return;
        addToCart(p.id, p.name, p.price, p.unit, p.image_url, p.presentations, null, p.available_lots);
    }

    function addToCart(id, name, price, unit, image, presentations = [], presentation_id = null, available_lots = []) {
        var existing = currentCart.find(i => i.id === id && i.presentation_id === presentation_id);
        
        // Validación estricta de stock
        var p = allProducts.find(x => x.id == id);
        if (p) {
            var maxStock = (p.stock > 0 ? p.stock : (p.active_lot_stock || 0));
            var added_qty = existing ? (existing.qty + 1) : 1;
            var qty_base_future = added_qty;
            
            if (presentation_id && presentations.length > 0) {
                var pres = presentations.find(x => x.id == presentation_id);
                if (pres) qty_base_future = added_qty * (pres.qty || 1);
            }
            
            if (qty_base_future > maxStock) {
                showToast(`La cantidad requerida (${qty_base_future}) supera el stock disponible (${maxStock} uds).`, 'error');
                return;
            }
        }

        if (existing) {
            existing.qty++;
        } else {
            currentCart.push({ 
                id: id, 
                name: name, 
                price: parseFloat(price), 
                base_price: parseFloat(price), // This might be wrong if 'price' passed is already the package price
                qty: 1, 
                discount: 0, 
                unit: unit, 
                image: image,
                presentations: presentations,
                presentation_id: presentation_id,
                available_lots: available_lots
            });
            
            // Validate coverage for the first added unit
            var qty_base = presentation_id ? (presentations.find(p => p.id == presentation_id)?.qty || 1) : 1;
            validatePosLotCoverage(id, qty_base, available_lots);

            // Re-adjust base price
            var newItem = currentCart[currentCart.length - 1];
            if(presentation_id) {
                // Find original unit price from allProducts if possible, or assume 'price' passed is package price
                // For now, let's just make sure updatePresentation-like logic is applied.
                var p = allProducts.find(x => x.id == id);
                if(p) newItem.base_price = parseFloat(p.price);
            }
        }
        renderCart();
    }

    function removeFromCart(id) {
        currentCart = currentCart.filter(i => i.id !== id);
        renderCart();
    }

    function updateQty(id, delta) {
        var existing = currentCart.find(i => i.id === id);
        if (existing) {
            var newQty = existing.qty + delta;
            if (newQty <= 0) {
                removeFromCart(id);
                return;
            }

            var p = allProducts.find(x => x.id == id);
            var maxStock = p ? (p.stock > 0 ? p.stock : (p.active_lot_stock || 0)) : 0;
            
            var qty_base = newQty;
            if (existing.presentation_id && existing.presentations) {
                var pres = existing.presentations.find(x => x.id == existing.presentation_id);
                if (pres) qty_base = newQty * (pres.qty || 1);
            }

            if (p && qty_base > maxStock) {
                showToast(`La cantidad supera el stock disponible (${maxStock} uds).`, 'error');
                return; // Bloqueamos el incremento
            }

            existing.qty = newQty;
            renderCart();
            validatePosLotCoverage(existing.id, qty_base, existing.available_lots);
        }
    }

    function updateQtyAbsolute(id, val) {
        var existing = currentCart.find(i => i.id === id);
        if (existing) {
            var newQty = parseFloat(val);
            if (isNaN(newQty) || newQty <= 0) return;

            var p = allProducts.find(x => x.id == id);
            var maxStock = p ? (p.stock > 0 ? p.stock : (p.active_lot_stock || 0)) : 0;
            
            var qty_base = newQty;
            if (existing.presentation_id && existing.presentations) {
                var pres = existing.presentations.find(x => x.id == existing.presentation_id);
                if (pres) qty_base = newQty * (pres.qty || 1);
            }

            if (p && qty_base > maxStock) {
                showToast(`La cantidad introducida supera el stock disponible (${maxStock} uds).`, 'error');
                // Revert parameter to maximum possible, or current valid qty
                var maxAllowed = existing.presentation_id ? Math.floor(maxStock / (pres.qty || 1)) : maxStock;
                existing.qty = maxAllowed > 0 ? maxAllowed : existing.qty;
                renderCart(); // Re-render to reset input
                return;
            }

            existing.qty = newQty;
            updateRowVisuals(existing);
            updateCartTotals();
            validatePosLotCoverage(existing.id, qty_base, existing.available_lots);
        }
    }

    function validatePosLotCoverage(itemId, requestedQty, availableLots) {
        if (!availableLots || availableLots.length <= 1) return;
        var firstLot = availableLots[0];
        if (requestedQty > firstLot.qty_available) {
            var nextLot = availableLots[1];
            showToast('⚠️ Lote agotado ('+firstLot.qty_available+' pzs). El resto se tomará del ' + nextLot.lote, 'warning');
        }
    }

    function updateItemDiscount(id, val) {
        var existing = currentCart.find(i => i.id === id);
        if (existing) {
            existing.discount = parseFloat(val) || 0;
            // Update DOM in-place
            var row = $(`#cart-item-${id}`);
            if(row.length) {
                row.find('.discount-input-mini').val(existing.discount);
                updateRowVisuals(existing);
                updateCartTotals();
            } else {
                renderCart();
            }
        }
    }

    function updateItemPrice(id, val) {
        var existing = currentCart.find(i => i.id === id);
        if (existing) {
            existing.price = parseFloat(val) || 0;
            // Update DOM in-place
            var row = $(`#cart-item-${id}`);
            if(row.length) {
                row.find('.input-price-mini').val(existing.price.toFixed(4));
                updateRowVisuals(existing);
                updateCartTotals();
            } else {
                renderCart();
            }
        }
    }

    function updatePresentation(itemId, presentationId) {
        var item = currentCart.find(i => i.id == itemId);
        if(!item) return;

        item.presentation_id = presentationId || null;
        
        if (presentationId) {
            var pres = item.presentations.find(p => p.id == presentationId);
            if (pres) {
                // Set the price for that presentation
                // In this system, if price is set on presentation, use it. 
                // Otherwise, use base_unit_price * pres_qty
                if (pres.price > 0) {
                    item.price = parseFloat(pres.price);
                } else {
                    item.price = item.base_price * parseFloat(pres.qty);
                }
            } else {
                item.price = item.base_price;
            }
        } else {
            item.price = item.base_price;
        }
        
        renderCart();
    }

    function updateRowVisuals(item) {
        var item_total = item.qty * item.price;
        var item_discount_val = (item.discount || 0);
        var item_total_discounted = item_total * (1 - item_discount_val / 100);
        
        $(`#cart-item-${item.id} .cart-item-total`).text('$ ' + item_total_discounted.toFixed(2));
    }

    function updateCartTotals() {
        var subtotal_sum = 0;
        currentCart.forEach(function(item) {
            var item_total = item.qty * item.price;
            var item_discount_val = (item.discount || 0);
            var item_total_discounted = item_total * (1 - item_discount_val / 100);
            subtotal_sum += item_total_discounted;
        });
        
        var global_discount = parseFloat($('#global_discount_input').val()) || 0;
        var grand_total = subtotal_sum * (1 - global_discount / 100);
        
        var showBs = $('#sale_show_bs').is(':checked');
        var displayTotal = grand_total;
        var currencySymbol = '$';
        var currencyLabel = 'USD';

        if(showBs) {
            displayTotal = grand_total * (exchangeRate || 6.97);
            currencySymbol = 'Bs.';
            currencyLabel = 'BOB';
        }

        $('#cart_subtotal').text('$ ' + subtotal_sum.toFixed(2));
        $('#cart_items_count').text(currentCart.length);
        
        $('.total-display-area small:first').text(currencySymbol);
        $('#cart_total').text(displayTotal.toFixed(2));
        $('.total-display-area small:last').text(currencyLabel);
    }

    function renderCart() {
        var container = $('#cart_items_container');
        if (currentCart.length === 0) {
            container.html(`
            <div class="text-center text-muted" style="margin-top: 50px;">
                <i class="fa fa-shopping-cart fa-3x" style="opacity: 0.3; color: var(--text-muted);"></i>
                <p style="margin-top: 15px; font-weight: 500; color: var(--text-muted);">Su carrito está vacío</p>
                <small style="color: var(--text-muted);">Seleccione productos para comenzar</small>
            </div>`);
            $('#cart_total').text('0.00');
            return;
        }

        // Check if we are doing a full re-render or just an update is needed.
        // For simplicity, we stick to full render when structure changes (add/remove), 
        // but rely on specific update functions for value changes.
        // However, this function is called on ADD/REMOVE.
        
        var html = '';
        var subtotal_sum = 0;

        currentCart.forEach(function(item, index) {
            var item_total = item.qty * item.price;
            var item_discount_val = (item.discount || 0);
            var item_total_discounted = item_total * (1 - item_discount_val / 100);
            
            subtotal_sum += item_total_discounted;
            
            // Generate presentations options
            var presHtml = '';
            if (item.presentations && item.presentations.length > 0) {
                presHtml = `<select class="form-control" style="height: 30px; width: auto; min-width: 135px; max-width: 180px; padding: 0 8px; font-size: 0.9rem; border-radius: 4px; font-weight: 700; color: var(--text-main); border: 1px solid #cbd5e1; background: #f8fafc; cursor: pointer;" onchange="updatePresentation(${item.id}, this.value)" title="Elegir Empaque">
                    <option value="">[Elegir Empaque]</option>
                    ${item.presentations.map(p => `<option value="${p.id}" ${item.presentation_id == p.id ? 'selected' : ''}>${p.name}</option>`).join('')}
                </select>`;
            }

            html += `
            <div class="cart-item fade-in" id="cart-item-${item.id}" style="display: flex; flex-direction: row; align-items: center; padding: 6px 10px; gap: 8px; background: var(--bg-card); border-bottom: 1px solid var(--border-card);">
                
                <!-- Presentation Box First -->
                ${presHtml ? `<div>${presHtml}</div>` : ''}

                <!-- Name -->
                <div style="flex: 1; min-width: 0; display: flex; align-items: center;">
                    <div class="cart-item-name" style="font-size: 1.05rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-main);" title="${item.name}">${item.name}</div>
                </div>

                <!-- Controls Container -->
                <div style="display: flex; align-items: center; gap: 8px;">
                    <!-- Price -->
                    <div style="width: 100px;" title="Precio Unitario">
                        <input type="number" step="0.0001" class="input-price-mini" style="width: 100%; border: none; background: transparent; border-bottom: 1px dashed var(--border-main); color: var(--text-main); font-weight: 700; text-align: center; font-size: 0.95rem; padding: 0;" value="${item.price.toFixed(4)}" onchange="updateItemPrice(${item.id}, this.value)" onclick="this.select()" tabindex="-1">
                    </div>

                    <!-- Discount -->
                    <div style="width: 80px; display: flex; align-items: center; background: #fff7ed; padding: 0 4px; border-radius: 4px;" title="Descuento">
                        <input type="number" class="discount-input-mini" value="${item.discount}" style="width: 50px; border: none; background: transparent; text-align: center; font-size: 1.05rem; font-weight: 700; color: #ea580c; padding: 0;" onchange="updateItemDiscount(${item.id}, this.value)" onclick="this.select()" tabindex="-1">
                        <span style="font-size: 0.85rem; color: #ea580c; font-weight: 800;">%</span>
                    </div>

                    <!-- QTY -->
                    <div class="cart-qty-wrapper" style="display: flex; height: 26px; border-radius: 4px; border: 1px solid var(--border-main); width: 115px; background: var(--bg-panel);" title="Cantidad">
                        <button class="btn-qty-mini" onclick="updateQty(${item.id}, -1)" tabindex="-1" style="width: 30px; border: none; background: transparent;"><i class="fas fa-minus" style="font-size: 0.75rem; color: var(--text-muted);"></i></button>
                        <input type="number" value="${item.qty}" class="input-qty-mini" style="width: 50px; border: none; background: var(--bg-card); text-align: center; font-size: 1.05rem; font-weight: 800; padding: 0; color: var(--text-main);" oninput="updateQtyAbsolute(${item.id}, this.value)" onchange="updateQtyAbsolute(${item.id}, this.value)" onclick="this.select()">
                        <button class="btn-qty-mini" onclick="updateQty(${item.id}, 1)" tabindex="-1" style="width: 30px; border: none; background: transparent;"><i class="fas fa-plus" style="font-size: 0.75rem; color: var(--text-muted);"></i></button>
                    </div>

                    <!-- Total -->
                    <div class="cart-item-total" style="font-size: 1.15rem; font-weight: 800; width: 85px; text-align: right; color: var(--text-main);" title="Importe">
                        ${item_total_discounted.toFixed(2)}
                    </div>

                    <!-- Remove -->
                    <div class="cart-item-remove" onclick="removeFromCart(${item.id})" style="width: 24px; text-align: center; color: var(--text-muted); cursor: pointer; padding: 4px; transition: 0.2s;" onmouseover="this.style.color='#ef4444';" onmouseout="this.style.color='var(--text-muted)';">
                        <i class="fas fa-times"></i>
                    </div>
                </div>
            </div>
            `;
        });

        container.html(html);
        updateCartTotals();
    }

    function filterCategory(catId) {
        $('.category-btn').removeClass('active');
        event.target.classList.add('active'); 
        
        if (catId === 'all') catId = '';
        loadProducts($('#product_search').val(), catId);
    }

    function processOrder(type) {
        if (currentCart.length === 0) {
            showToast('Por favor, agregue productos al carrito antes de continuar.', 'warning');
            return;
        }
        
        var clientId = $('#client_select').val();
        if (!clientId) {
            showToast('Es necesario seleccionar un cliente para la venta.', 'warning');
            $('#client_select').focus().css('border-color', 'red');
            return;
        }

        var actionText = (type === 'quote') ? 'generar Cotización' : 'procesar Venta';
        
        // Custom Modal Confirmation
        var confirmMsg = '¿Está seguro de ' + actionText + '?';
        var confirmBtnText = (type === 'quote') ? 'Crear Cotización' : 'Procesar Venta';
        var confirmBtnClass = (type === 'quote') ? 'btn-info' : 'btn-success';

        confirmAction(confirmMsg, function() {
            $('.btn-pos').prop('disabled', true);
            
            var global_discount = parseFloat($('#global_discount_input').val()) || 0;
            var isCredit = $('#sale_credit').is(':checked');
            var isShowBs = $('#sale_show_bs').is(':checked');

            // Credit Limit Validation
            if (type === 'sale') {
                var creditAvailable = parseFloat($('#info_client_credit').data('val')) || 0;
                var currentTotalStr = $('#cart_total').text();
                var currentTotal = parseFloat(currentTotalStr) || 0;
                
                if (currentTotal > creditAvailable) {
                    showToast('Crédito insuficiente. El cliente ha excedido su límite permitido.', 'error');
                    $('.btn-pos').prop('disabled', false); // Re-enable buttons
                    return;
                }
            }

            $.ajax({
                url: '/pos/process_sale',
                method: 'POST',
                data: {
                    authenticity_token: $('meta[name="csrf-token"]').attr('content'),
                    client_id: clientId,
                    items: currentCart, 
                    discount: global_discount,
                    date: $('#sale_date').val(),
                    credit_expiration: $('#sale_expiration').val(),
                    credit: isCredit,
                    show_bs: isShowBs,
                    type: type,
                    sale_id: window.editingSaleId // Add sale ID if editing
                },
                success: function(response) {
                $('.btn-pos').prop('disabled', false);
                
                if(response.success) {
                    var msg = (window.editingSaleId) ? '¡Venta actualizada correctamente!' : ( (type === 'quote') ? '¡Cotización creada con éxito!' : '¡Venta procesada exitosamente!' );
                    showToast(msg, 'success');
                    
                    if (response.sale_id) {
                        var styleParam = (type === 'quote') ? '?style=modern' : '';
                        var pdfUrl = '/sales/' + response.sale_id + '/note_sale.pdf' + styleParam + '#toolbar=0&navpanes=0&scrollbar=0&view=FitH';
                        var fullPdfUrl = '/sales/' + response.sale_id + '/note_sale.pdf' + styleParam; // URL limpia para abrir en nueva pestaña
                        
                        // Embed PDF in cart container
                         var pdfHtml = `
                            <div style="height: 100%; display: flex; flex-direction: column; background: var(--bg-card);">
                                <div style="padding: 12px; border-bottom: 1px solid var(--border-main); background: var(--bg-panel); display: flex; justify-content: space-between; align-items: center;">
                                    <div>
                                        <button class="btn btn-primary btn-sm" onclick="document.getElementById('embeddedPdfFrame').contentWindow.print()" style="border-radius: 8px; font-weight: 700;">
                                            <i class="fa fa-print"></i> Imprimir
                                        </button>
                                        <a href="${fullPdfUrl}" target="_blank" class="btn btn-default btn-sm" download style="border-radius: 8px; font-weight: 700; margin-left: 5px; background: var(--bg-card); color: var(--text-main); border-color: var(--border-main);">
                                            <i class="fa fa-download"></i> Descargar
                                        </a>
                                        <a href="${fullPdfUrl}" target="_blank" class="btn btn-info btn-sm" style="border-radius: 8px; font-weight: 700; margin-left: 5px;">
                                            <i class="fa fa-eye"></i> Ver
                                        </a>
                                    </div>
                                    <button class="btn btn-danger btn-sm" onclick="resetCartView()" style="border-radius: 8px; font-weight: 700;">
                                        <i class="fa fa-times"></i> Cerrar
                                    </button>
                                </div>
                                <iframe id="embeddedPdfFrame" src="${pdfUrl}" style="flex-grow: 1; width: 100%; border: none; background: white;"></iframe>
                            </div>
                        `;
                        
                        $('#cart_items_container').html(pdfHtml);
                        
                    } else {
                        resetCartView(); 
                    }

                    // Reset data behind the scenes
                    currentCart = [];
                    $('#client_select').val('');
                    $('#client_search_input').val('');
                    $('#client_info_panel').hide(); 
                    $('#sale_credit').prop('checked', false);
                    toggleCreditExpiration();
                    
                    $('#sale_date').val(new Date().toISOString().split('T')[0]);
                    
                    if (type === 'sale') {
                            var activeBtn = $('.category-btn.active');
                            var catId = '';
                            if (activeBtn.length > 0) {
                                var match = activeBtn.attr('onclick').match(/'(.*)'/);
                                if (match) catId = match[1];
                            }
                            if (catId === 'all') catId = '';
                            loadProducts($('#product_search').val(), catId);
                    }
                } else {
                    showToast('Ocurrió un error: ' + response.error, 'error');
                }
                },
                error: function(xhr) {
                    $('.btn-pos').prop('disabled', false);
                    showToast('No se pudo procesar la solicitud: ' + (xhr.responseJSON ? xhr.responseJSON.error : xhr.statusText), 'error');
                }
            });
        }, confirmBtnText, confirmBtnClass);
    }

    function resetCartView() {
        currentCart = [];
        renderCart(); // This restores the default list view
    }

    function createClient() {
        var name = $('#client_new_name').val();
        
        var isManualAddress = $('#manual_address_check').is(':checked');
        var address_id = $('#client_new_address').val();
        var address_text = $('#client_manual_address').val();
        
        if(!name) {
            showToast('El nombre del cliente es obligatorio.', 'warning');
            return;
        }
        
        if (isManualAddress && !address_text) {
             showToast('Por favor, escriba una dirección válida.', 'warning');
             return;
        }
        
        if (!isManualAddress && !address_id) {
             showToast('Por favor, seleccione una dirección de la lista.', 'warning');
             return;
        }
        
        var clientParams = {
            name: name,
            phone: $('#client_new_phone').val(),
            mobile: $('#client_new_mobile').val(),
            email: $('#client_new_email').val() || '',
            discount: 0,
            credit_limit: $('#client_new_credit_limit').val() || 0,
            asig_a_user_id: $('#client_new_assigned_user').val() || <%= current_user.id %>
        };

        if (isManualAddress) {
             // Send address attributes to create it on the fly
             var countryId = $('#client_country').val();
             var deptId = $('#client_dept').val();
             var provinceId = $('#client_province').val();
             var zonaId = $('#client_zona').val();
             
             clientParams.address_attributes = {
                 country_id: countryId,
                 departamento_id: deptId,
                 province_id: provinceId,
                 zona_id: zonaId,
                 calles: address_text,
                 description: 'Creado desde POS'
             };
        } else {
             clientParams.address_id = address_id;
        }
        
        var data = {
            authenticity_token: $('meta[name="csrf-token"]').attr('content'),
            client: clientParams
        };

        $.ajax({
            url: '/clients.json',
            method: 'POST',
            data: data,
            success: function(response) {
                $('#newClientModal').modal('hide');
                
                var displayAddress = isManualAddress ? address_text : $("#client_new_address option:selected").text();

                // Adapt response
                var clientData = {
                    id: response.id,
                    name: response.name,
                    phone: response.phone,
                    mobile: response.mobile,
                    address: displayAddress, 
                    discount: 0,
                    credit_available: 0
                };
                
                selectClient(response.id, response.name, clientData);
                
                // Clear modal and reset state
                $('#newClientForm')[0].reset();
                $('#manual_address_check').prop('checked', false);
                toggleAddressMode();
                
                showToast('¡Cliente registrado exitosamente!', 'success');
            },
            error: function(xhr) {
                var msg = 'No se pudo registrar el cliente';
                if(xhr.responseJSON) {
                    msg += ': ' + JSON.stringify(xhr.responseJSON);
                } else {
                    msg += ': ' + xhr.statusText;
                }
                showToast(msg, 'error');
            }
        });
    }

    function toggleAddressMode() {
        if($('#manual_address_check').is(':checked')) {
            $('#select_address_container').hide();
            $('#manual_address_container').show();
            $('#client_manual_address').focus();
        } else {
            $('#manual_address_container').hide();
            $('#select_address_container').show();
        }
    }
    
    // Cascading Dropdowns Logic
    $(document).ready(function(){
        // When Department changes, load Provinces
        $('#client_dept').on('change', function(){
            var deptId = $(this).val();
            var provinceSelect = $('#client_province');
            var zonaSelect = $('#client_zona');
            
            provinceSelect.html('<option>Cargando...</option>');
            zonaSelect.html(''); // Clear zones as they correspond to province
            
            if(deptId) {
                $.ajax({
                    url: '/departamento_provincias',
                    data: { departamento_id: deptId },
                    success: function(response) {
                        // Response comes as [ {valid:..., id:..., pro: [...]} ]
                        console.log("Provinces response:", response);
                        var data = response[0];
                        if(data && data.pro && data.pro.length > 0) {
                             var html = '';
                             data.pro.forEach(function(p){
                                 html += '<option value="'+p.id+'">'+p.name+'</option>';
                             });
                             provinceSelect.html(html);
                             // Trigger change to load zones for first province
                             provinceSelect.trigger('change');
                        } else {
                             provinceSelect.html('<option value="">Sin provincias</option>');
                        }
                    },
                    error: function() {
                        provinceSelect.html('<option value="">Error al cargar</option>');
                    }
                });
            } else {
                provinceSelect.html('');
                zonaSelect.html('');
            }
        });
        
        // When Province changes, load Zonas
        $('#client_province').on('change', function(){
            var provId = $(this).val();
            var zonaSelect = $('#client_zona');
            
            zonaSelect.html('<option>Cargando...</option>');
            
            if(provId) {
                $.ajax({
                    url: '/provincia_zonas',
                    data: { province_id: provId },
                    success: function(response) {
                         // Response comes as [ {valid:..., id:..., zon: [...]} ]
                        var data = response[0];
                        if(data && data.zon && data.zon.length > 0) {
                             var html = '';
                             data.zon.forEach(function(z){
                                 html += '<option value="'+z.id+'">'+z.name+'</option>';
                             });
                             zonaSelect.html(html);
                        } else {
                             zonaSelect.html('<option value="">Sin zonas</option>');
                        }
                    },
                    error: function() {
                        zonaSelect.html('<option value="">Error al cargar</option>');
                    }
                });
            } else {
                zonaSelect.html('');
            }
        });
    });
</script>

<!-- New Client Modal -->
<div class="modal fade" id="newClientModal" tabindex="-1" role="dialog" aria-labelledby="newClientModalLabel">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="newClientModalLabel">Nuevo Cliente Rápido</h4>
      </div>
      <div class="modal-body">
        <form id="newClientForm">
          <div class="form-group">
            <label for="client_new_name">Nombres y Apellidos *</label>
            <input type="text" class="form-control" id="client_new_name" required placeholder="Nombre completo">
          </div>
          
          <div class="form-group">
              <div class="checkbox" style="margin-top: 0; margin-bottom: 10px;">
                <label>
                  <input type="checkbox" id="manual_address_check" onchange="toggleAddressMode()"> 
                  <strong>Ingresar dirección manualmente</strong>
                </label>
              </div>
              
              <div id="select_address_container">
                <label for="client_new_address">Seleccionar Dirección *</label>
                <select class="form-control" id="client_new_address">
                   <% if @addresses.present? %>
                       <% @addresses.each do |addr| %>
                         <option value="<%= addr.id %>"><%= addr.get_direccion_all.truncate(60) rescue "Dirección #{addr.id}" %></option>
                       <% end %>
                   <% else %>
                        <option value="">No hay direcciones disponibles</option>
                   <% end %>
                </select>
              </div>

              <div id="manual_address_container" style="display: none;">
                  <div class="row">
                      <div class="col-md-6">
                          <div class="form-group">
                              <label for="client_country">País</label>
                              <select class="form-control input-sm" id="client_country" disabled> <!-- Temporalmente disabled para simplificar POS -->
                                 <% if @default_country %>
                                     <option value="<%= @default_country.id %>" selected><%= @default_country.name %></option>
                                 <% end %>
                              </select>
                          </div>
                      </div>
                      <div class="col-md-6">
                          <div class="form-group">
                              <label for="client_dept">Departamento</label>
                              <select class="form-control input-sm" id="client_dept">
                                   <% if @default_departamento %>
                                       <option value="<%= @default_departamento.id %>" selected><%= @default_departamento.name %></option>
                                   <% end %>
                                   <% @departamentos.each do |d| %>
                                        <% next if d.id == @default_departamento&.id %>
                                        <option value="<%= d.id %>"><%= d.name %></option>
                                    <% end %>
                              </select>
                          </div>
                      </div>
                  </div>
                  
                  <div class="row">
                      <div class="col-md-6">
                          <div class="form-group">
                              <label for="client_province">Provincia</label>
                              <select class="form-control input-sm" id="client_province">
                                   <% if @default_province %>
                                       <option value="<%= @default_province.id %>" selected><%= @default_province.name %></option>
                                   <% end %>
                                   <% @provinces.each do |p| %>
                                        <% next if p.id == @default_province&.id %>
                                        <option value="<%= p.id %>"><%= p.name %></option>
                                    <% end %>
                              </select>
                          </div>
                      </div>
                      <div class="col-md-6">
                          <div class="form-group">
                              <label for="client_zona">Zona</label> <!-- Zona como combo select -->
                              <select class="form-control input-sm" id="client_zona">
                                   <% if @default_zona %>
                                       <option value="<%= @default_zona.id %>" selected><%= @default_zona.name %></option>
                                   <% end %>
                                   <% @zonas.each do |z| %>
                                        <% next if z.id == @default_zona&.id %>
                                        <option value="<%= z.id %>"><%= z.name %></option>
                                    <% end %>
                              </select>
                          </div>
                      </div>
                  </div>
              
                  <label for="client_manual_address">Dirección Detallada (Calle, #)</label>
                  <input type="text" class="form-control" id="client_manual_address" placeholder="Ej: Av. 6 de Agosto #123">
              </div>
          </div>
          
          <div class="row">
              <div class="col-md-6">
                  <div class="form-group">
                     <label for="client_new_phone">Teléfono</label>
                     <input type="text" class="form-control" id="client_new_phone" placeholder="Opcional">
                  </div>
              </div>
              <div class="col-md-6">
                   <div class="form-group">
                     <label for="client_new_mobile">Celular</label>
                     <input type="text" class="form-control" id="client_new_mobile" placeholder="Opcional">
                  </div>
              </div>
          </div>
          <div class="row">
              <div class="col-md-6">
                   <div class="form-group">
                     <label for="client_new_credit_limit">Límite de Crédito</label>
                     <input type="number" class="form-control" id="client_new_credit_limit" value="0">
                  </div>
              </div>
              <div class="col-md-6">
                  <div class="form-group">
                      <label for="client_new_assigned_user">Asignado a</label>
                      <select class="form-control" id="client_new_assigned_user">
                          <% if @users_for_assignment %>
                              <% @users_for_assignment.each do |u| %>
                                 <option value="<%= u.id %>" <%= 'selected' if u.id == current_user.id %>><%= u.name %></option>
                              <% end %>
                          <% else %>
                              <option value="<%= current_user.id %>" selected><%= current_user.name %></option>
                          <% end %>
                      </select>
                  </div>
              </div>
          </div>
          <div class="form-group">
             <label for="client_new_email">Email</label>
             <input type="email" class="form-control" id="client_new_email" placeholder="Opcional">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="createClient()">Guardar Cliente</button>
      </div>
    </div>
  </div>
</div>



<script>
    function toggleDarkMode() {
        var container = $('.pos-container');
        container.toggleClass('dark-mode');
        
        var icon = $('#darkModeIcon');
        if(container.hasClass('dark-mode')) {
            icon.removeClass('fa-moon').addClass('fa-sun');
            localStorage.setItem('posDateMode', 'true');
        } else {
            icon.removeClass('fa-sun').addClass('fa-moon');
            localStorage.setItem('posDateMode', 'false');
        }
    }
    
    var posThemes = [
        '', // Default
        'pos-theme-green', 'pos-theme-purple', 'pos-theme-orange', 'pos-theme-red', 'pos-theme-blue',
        'pos-theme-green-dark', 'pos-theme-purple-dark', 'pos-theme-orange-dark', 'pos-theme-red-dark', 'pos-theme-blue-dark'
    ];
    var currentThemeIndex = 0;

    function toggleTheme() {
        var container = $('.pos-container');
        container.removeClass(posThemes.join(' '));
        
        currentThemeIndex = (currentThemeIndex + 1) % posThemes.length;
        var newTheme = posThemes[currentThemeIndex];
        
        if(newTheme) container.addClass(newTheme);
        localStorage.setItem('posThemeClass', newTheme);
    }

    function toggleFullScreen() {
        if (!document.fullscreenElement) {
            var elem = document.querySelector(".main");
            if (elem && elem.requestFullscreen) {
                elem.requestFullscreen();
            } else if (document.documentElement.requestFullscreen) {
                 document.documentElement.requestFullscreen();
            }
            $('#fullScreenIcon').removeClass('fa-expand-arrows-alt').addClass('fa-compress-arrows-alt');
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
                $('#fullScreenIcon').removeClass('fa-compress-arrows-alt').addClass('fa-expand-arrows-alt');
            }
        }
    }

    function toggleCartFullScreen() {
        var elem = document.querySelector(".cart-panel");
        if (!document.fullscreenElement) {
            if (elem && elem.requestFullscreen) {
                elem.requestFullscreen();
            }
            $('#cartFullScreenIcon').removeClass('fa-expand').addClass('fa-compress');
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
                $('#cartFullScreenIcon').removeClass('fa-compress').addClass('fa-expand');
            }
        }
    }

    // Initialize from storage
    $(document).ready(function() {
        var savedTheme = localStorage.getItem('posThemeClass');
        if(savedTheme && posThemes.includes(savedTheme)) {
            $('.pos-container').addClass(savedTheme);
            currentThemeIndex = posThemes.indexOf(savedTheme);
        }

        if(localStorage.getItem('posDateMode') === 'true') {
            // Apply without animation for instant load
             var container = $('.pos-container');
             container.addClass('dark-mode');
             $('#darkModeIcon').removeClass('fa-moon').addClass('fa-sun');
        }

        // Listen for fullscreen changes to update icon if exited via ESC key
        document.addEventListener('fullscreenchange', (event) => {
            if (!document.fullscreenElement) {
                $('#fullScreenIcon').removeClass('fa-compress-arrows-alt').addClass('fa-expand-arrows-alt');
                $('#cartFullScreenIcon').removeClass('fa-compress').addClass('fa-expand');
            }
        });
    });

    // Toast Functionality
    function showToast(message, type) {
        var icon = 'fa-info-circle';
        var toastClass = 'pos-toast-info';
        
        if (type === 'success') {
            icon = 'fa-check-circle';
            toastClass = 'pos-toast-success';
        } else if (type === 'error') {
            icon = 'fa-exclamation-circle';
            toastClass = 'pos-toast-error';
        } else if (type === 'warning') {
            icon = 'fa-exclamation-triangle';
            toastClass = 'pos-toast-warning';
        }
        
        var toastId = 'toast-' + Date.now();
        var html = `
        <div id="${toastId}" class="pos-toast ${toastClass}">
            <i class="fa ${icon} pos-toast-icon"></i>
            <div class="pos-toast-message">${message}</div>
            <div class="pos-toast-close" onclick="$('#${toastId}').remove()"><i class="fa fa-times"></i></div>
        </div>`;
        
        $('#pos-toast-container').append(html);
        
        // Timeout to allow DOM insertion before adding 'show' class for animation
        setTimeout(function() {
            var $toast = $('#' + toastId);
            $toast.addClass('show');
            
            // Auto hide after 4s (or 10s for warnings/errors)
            var displayTime = (type === 'warning' || type === 'error') ? 10000 : 4000;
            setTimeout(function() {
                $toast.removeClass('show');
                setTimeout(function() { $toast.remove(); }, 300); // Wait for transition
            }, displayTime);
        }, 10);
    }

    // Confirm Action Function
    function confirmAction(message, onConfirm, btnText, btnClass) {
        $('#posConfirmMessage').text(message);
        
        var confirmBtn = $('#posConfirmBtn');
        // Reset specific classes
        confirmBtn.removeClass('btn-primary btn-success btn-info btn-warning btn-danger');
        
        // Apply new text and class
        confirmBtn.text(btnText || 'Confirmar');
        confirmBtn.addClass(btnClass || 'btn-primary');
        
        // Remove previous handlers to prevent stacking
        confirmBtn.off('click').on('click', function() {
            $('#posConfirmModal').modal('hide');
            if (onConfirm) onConfirm();
        });
        
        $('#posConfirmModal').modal('show');
    }
</script>
