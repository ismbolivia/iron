<script>
    var currentCart = [];
    var allProducts = []; // Cache simple
    var exchangeRate = <%= @exchange_rate || 6.97 %>;

    // PANEL RESIZING LOGIC
    (function() {
        const resizer = document.getElementById('pos_resizer');
        const rightPanel = document.getElementById('pos_right_panel');
        const container = document.querySelector('.pos-container');
        
        if(!resizer || !rightPanel || !container) return;

        let isResizing = false;

        resizer.addEventListener('mousedown', function(e) {
            isResizing = true;
            document.body.style.cursor = 'col-resize';
            resizer.classList.add('is-dragging');
            document.body.style.userSelect = 'none';
        });

        document.addEventListener('mousemove', function(e) {
            if (!isResizing) return;

            const containerRect = container.getBoundingClientRect();
            const newRightWidth = containerRect.right - e.clientX;
            
            // Min/Max widths for the cart panel
            if (newRightWidth > 350 && newRightWidth < 900) {
                rightPanel.style.width = newRightWidth + 'px';
                localStorage.setItem('posRightPanelWidth', newRightWidth);
            }
        });

        document.addEventListener('mouseup', function() {
            if (isResizing) {
                isResizing = false;
                document.body.style.cursor = 'default';
                resizer.classList.remove('is-dragging');
                document.body.style.userSelect = 'auto';
            }
        });
        
        // Initial load from storage
        const savedWidth = localStorage.getItem('posRightPanelWidth');
        if (savedWidth) {
            rightPanel.style.width = savedWidth + 'px';
        }
    })();

    $(document).ready(function() {
        // Cargar productos al inicio
        loadProducts();

        // Buscador Productos
        var searchTimer;
        $('#product_search').on('keyup', function() {
            clearTimeout(searchTimer);
            var term = $(this).val();
            searchTimer = setTimeout(function() {
                loadProducts(term);
            }, 300);
        });

        // Buscador Clientes
        var clientTimer;
        $('#client_search_input').on('keyup focus', function() {
            var term = $(this).val();
            clearTimeout(clientTimer);
            clientTimer = setTimeout(function() {
                searchClients(term);
            }, 300);
        });

        // Ocultar dropdown al hacer clic fuera
        $(document).on('click', function(e) {
            if (!$(e.target).closest('.cart-header').length) {
                $('#client_results').hide();
            }
        });

        // Toggle Expiration Date
        toggleCreditExpiration();
        $('#sale_credit').on('change', function() {
            toggleCreditExpiration();
        });
    });

    function toggleCreditExpiration() {
        if($('#sale_credit').is(':checked')) {
            $('#expiration_date_container').show();
            // Default to 30 days from now if empty and not editing with existing date
            if(!$('#sale_expiration').val()) {
                var date = new Date();
                date.setDate(date.getDate() + 30);
                var futureDate = date.toISOString().split('T')[0];
                $('#sale_expiration').val(futureDate);
            }
        } else {
            $('#expiration_date_container').hide();
            $('#sale_expiration').val(''); 
        }
    }
    
    // Logic for Editing Sale (Pre-load data)
    <% if @sale_edit_data %>
        $(document).ready(function() {
             var saleData = <%= raw @sale_edit_data %>;
             var cartData = <%= raw @cart_items_data %>;
             var clientData = <%= raw @client_edit.to_json %>;
             
             // Pre-select client
             // We need to fetch formatted client address/credit info first or mock it
             // Let's rely on standard searchClients logic but with direct call or manual population
             // Manual population since we have the object
             var fullClientData = {
                 id: clientData.id,
                 name: clientData.name,
                 phone: clientData.phone,
                 mobile: clientData.mobile,
                 address: '<%= @client_edit.address.get_direccion_cli rescue "" %>',
                 credit_limit: <%= @client_edit.credit_limit %>,
                 credit_available: <%= @client_edit.line_credit_available %>,
                 discount: clientData.discount
             };
             
             selectClient(clientData.id, clientData.name, fullClientData);
             
             // Populate Cart
             currentCart = cartData;
             renderCart();
             
             // Set other fields
             $('#sale_date').val(saleData.date);
             $('#global_discount_input').val(saleData.discount);
             
             if(saleData.credit) {
                 $('#sale_credit').prop('checked', true);
                 $('#sale_expiration').val(saleData.credit_expiration);
                 toggleCreditExpiration();
             }

             if(saleData.show_bs) {
                 $('#sale_show_bs').prop('checked', true);
             }
             
             // Visual indicators for Edit Mode
             if(saleData.type == 'confirmed') {
                 $('.btn-payment').html('<i class="fa fa-sync-alt btn-icon-side"></i><div class="btn-content"><span class="btn-title">Actualizar</span><span class="btn-subtitle">Guardar Venta</span></div>').addClass('btn-warning').removeClass('btn-payment');
                 $('.btn-quote').hide();
             } else if(saleData.type == 'quoted') {
                 $('.btn-payment').html('<i class="fa fa-check-circle btn-icon-side"></i><div class="btn-content"><span class="btn-title">Confirmar</span><span class="btn-subtitle">Convertir en Venta</span></div>').addClass('btn-success').removeClass('btn-payment');
                 $('.btn-quote').html('<i class="fa fa-sync-alt" style="margin-right: 5px;"></i> Actualizar Cotiz.').show();
             }
             
             // Store sale ID for submission
             window.editingSaleId = saleData.id;
        });
    <% end %>

    function searchClients(term) {
        $.ajax({
            url: '/pos/search_clients',
            data: { term: term },
            success: function(clients) {
                var html = '';
                if(clients.length === 0) {
                    html = '<div class="client-result-item text-muted" style="padding: 15px; text-align: center;">No se encontraron clientes</div>';
                } else {
                    clients.forEach(function(c) {
                        var clientData = JSON.stringify(c).replace(/"/g, '&quot;');
                        html += `<div class="client-result-item" onclick="selectClient(${c.id}, '${c.name.replace(/'/g, "\\'")}', ${clientData})">${c.name}</div>`;
                    });
                }
                $('#client_results').html(html).show();
            }
        });
    }

    function selectClient(id, name, data) {
        $('#client_select').val(id);
        $('#client_search_input').val(name);
        $('#client_results').hide();
        
        // Populate Info Panel
        if(data) {
            $('#info_client_name').text(data.name);
            $('#info_client_address').text(data.address || 'Sin dirección');
            var phones = [];
            if(data.phone) phones.push(data.phone);
            if(data.mobile) phones.push(data.mobile);
            $('#info_client_phone').text(phones.join(' / ') || 'Sin teléfono');
            
            $('#info_client_discount').text(data.discount || 0);
            var creditAvail = parseFloat(data.credit_available || 0);
            $('#info_client_credit').text(creditAvail.toFixed(2));
            $('#info_client_credit').data('val', creditAvail); // Store for validation
            
            $('#client_info_panel').slideDown();
        }
    }

    function loadProducts(term = '', categoryId = '') {
        $('#product_grid').html('<div class="col-md-12 text-center"><i class="fa fa-spinner fa-spin fa-2x"></i></div>');
        
        $.ajax({
            url: '/pos/search_products',
            data: { term: term, category_id: categoryId },
            success: function(products) {
                renderGrid(products);
                allProducts = products;
            }
        });
    }

