                                    p.presentations.map(pr => `
                                        <div class="pres-chip" onclick="event.stopPropagation(); addToCart(${p.id}, '${p.name.replace(/'/g, "\\'")}', ${pr.price > 0 ? pr.price : p.price * pr.qty}, '${p.unit}', '${p.image_url}', ${JSON.stringify(p.presentations).replace(/"/g, '&quot;')}, ${pr.id}, ${JSON.stringify(p.available_lots).replace(/"/g, '&quot;')})" 
