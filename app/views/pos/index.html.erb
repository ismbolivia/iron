                if(hasAdjustment) originIndicator += '<span class="badge" style="background: #059669; color: white; font-size: 0.85rem; padding: 4px 10px; border-radius: 8px; box-shadow: 0 4px 6px rgba(5, 150, 105, 0.4); border: 2px solid white;" title="Contiene stock de AJUSTE MANUAL"><i class="fas fa-tools"></i> AJUSTE</span>';

