<% sale.sale_details.each do |detail| %>
  <tr class="item-row fade-in-up" id="detail-<%= detail.id %>">
    <td>
      <div class="d-flex align-items-center">
        <div class="item-icon m-r-15">
          <i class="fas fa-cube text-primary opacity-50"></i>
        </div>
        <div>
          <div class="font-bold text-dark"><%= detail.item.name %></div>
          <small class="text-muted"><%= detail.item.code %></small>
        </div>
      </div>
    </td>
    <td class="text-center">
      <div class="quantity-control">
        <input type="number" 
               value="<%= detail.qty %>" 
               class="form-control text-center input-qty-ajax" 
               data-id="<%= detail.id %>"
               min="1">
      </div>
    </td>
    <td class="text-right font-mono">
      <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(detail.price_sale, precision: 2) %>
    </td>
    <td class="text-center">
      <input type="number" 
             value="<%= detail.discount %>" 
             class="form-control text-center input-discount-ajax" 
             data-id="<%= detail.id %>"
             min="0" max="100">
    </td>
    <td class="text-right font-bold text-dark">
      <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(detail.qty * detail.price_sale, precision: 2) %>
    </td>
    <td class="text-center">
      <button type="button" class="btn btn-link text-danger btn-delete-item" data-id="<%= detail.id %>">
        <i class="fas fa-trash-alt"></i>
      </button>
    </td>
  </tr>
<% end %>
