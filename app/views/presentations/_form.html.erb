
<div class="container-fluid">
  <div class="row">
    <div class="panel-body">   
     <%= form_for :presentation, url: presentations_url, method: :post, remote: true do |form| %>  
          <div id="div-error">
            
          </div>

    <div class="col-xs-8">
        <div class="form-group">
          <%= form.text_field :name, autofocus: true, placeholder: "Nombre", class: "form-control" %>
        </div>
        <div class="form-group">
          <%= form.number_field :qty, autofocus: true, placeholder: "Cantidad", class: "form-control" %>
        </div>
        <div class="form-group">
          <%= form.collection_select :unit_id, @units, :id, :name,
              {selected: @presentation.unit_id, include_blank: 'Seleccione unidad'},
              {class: "form-control"} %>
              <span class="input-group-btn">
        </div>
        <%= hidden_field_tag :is_item_presentation, @is_item_presentation %>
       <% if @is_item_presentation %>
           <div class="form-group">
            <%= form.collection_select :item_id, @items, :id, :name,
                {selected: @presentation.item_id, include_blank: 'Seleccione producto'},
                {class: "form-control"} %>
                <span class="input-group-btn">
          </div>
       <% else %>
              <%= form.hidden_field :item_id %>
       <% end %> 
        
  </div>
    <div class="col-xs-4">
      <div class="product-img "> 
          <%= image_tag(presentation.image_presentation.large.url, :alt => "imge-item", class: "image-form") %><br>
        <div class="fileupload btn btn-info waves-effect waves-light"><span><i class="ion-upload m-r-5"></i>Subir una imagen </span>
          <%= form.file_field :image_presentation, :class =>"upload"%>
        </div>
         <%= form.submit "Aceptar", class: "btn btn-success" %>                            
                 </div>
          </div>
       
      <% end %>
    </div>
  </div>
</div>
