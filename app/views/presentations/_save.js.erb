$('#div-error').addClass('alert alert-danger');
	 document.getElementById("div-error").innerHTML = "<h2><%= pluralize(@presentation.errors.count, 'error') %> prohibited this presentation from being saved:</h2>"+
	" <ul><% @presentation.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul>";
