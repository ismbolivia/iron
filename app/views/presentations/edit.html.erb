


<style>
.premium-dashboard {
  background: #fdfdfd;
  border-radius: 12px;
  padding: 1.5rem;
  box-shadow: 0 5px 20px rgba(0,0,0,0.03);
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

.gradient-banner {
  background: linear-gradient(135deg, #09203f 0%, #537895 100%);
  color: white;
  border-radius: 12px;
  padding: 1.5rem 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-panel {
  background: white;
  border-radius: 12px;
  padding: 2.2rem;
  box-shadow: 0 2px 15px rgba(0,0,0,0.02);
  margin-bottom: 2rem;
  border: 1px solid #edf2f7;
}

.access-panel {
  background: white;
  border-radius: 12px;
  padding: 1.8rem;
  box-shadow: 0 2px 15px rgba(0,0,0,0.02);
  border: 1px solid #edf2f7;
}

.btn-premium-back {
  background: rgba(255, 255, 255, 0.15);
  color: white !important;
  font-weight: 600;
  padding: 9px 18px;
  border-radius: 20px;
  transition: all 0.2s;
  border: 1px solid rgba(255, 255, 255, 0.25);
  font-size: 0.85rem;
  text-decoration: none !important;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.btn-premium-back:hover {
  background: rgba(255, 255, 255, 0.25);
  transform: translateY(-1px);
}
</style>

<div class="premium-dashboard">
  <div class="gradient-banner">
    <div>
      <h2 class="m-0" style="font-weight: 700; font-size: 1.35rem; letter-spacing: -0.3px;">
         <i class="fas fa-edit mr-2" style="font-size: 1.2rem; opacity: 0.9;"></i> Editar Presentación
      </h2>
      <p class="m-0" style="color: rgba(255,255,255,0.75); font-size: 0.85rem; margin-top: 4px;">Modifique los valores para actualizar la variante de este producto.</p>
    </div>
    <%= link_to presentations_path, class: "btn-premium-back" do %>
         <i class="fas fa-arrow-left" style="font-size: 0.8rem;"></i> Volver
    <% end %>
  </div>

  <div class="form-panel">
    <%= render 'form', presentation: @presentation %>
  </div>

  <div class="access-panel">
    <%= render 'presentations_access', presentation: @presentation %>
  </div>
</div>
