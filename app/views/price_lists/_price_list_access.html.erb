
  <div class="tab-content">
  <div role="tabpanel" class="tab-pane active" id="ihome">
    <div class="white-box" style="border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
      
      <!-- 🔍 Paginador y Filtros -->
      <div style="margin-bottom: 20px;">
        <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
      </div>

      <div class="table-responsive">
        <table class="table table-hover product-overview" style="vertical-align: middle;">
          <thead style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
            <tr>
              <th style="padding: 1.2rem; color: #0f172a; font-weight: 800; border: none;">Producto</th>
              <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800; border: none;">Imagen</th>
              <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800; border: none;">Categoría</th>
              <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800; border: none;">Costo ($)</th>
              <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800; border: none;">Utilidad (%)</th>
              <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800; border: none;">P. Venta ($)</th>
              <% if can? :read, Item %>
                <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800; border: none;">Actualización</th>
              <% end %>
            </tr>
          </thead>

          <tbody style="border: none;">
            <% @items.each do |item| %>
              <% 
                # 🏷️ Buscamos el registro de precio específico para esta lista
                price_record = Price.find_by(item_id: item.id, price_list_id: @price_list.id)
              %>
              <tr style="transition: all 0.2s; border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 1rem 1.2rem; vertical-align: middle;">
                  <div style="font-weight: 700; color: #1e293b; font-size: 14px;"><%= item.name %></div>
                  <div style="font-size: 11px; color: #64748b; font-family: 'JetBrains Mono', monospace;"><%= item.code %></div>
                </td>
                
                <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
                  <% if item.image.present? %>
                    <%= image_tag(item.image.large.url, style: "width: 45px; height: 45px; object-fit: contain; border-radius: 6px; border: 1px solid #f1f5f9; background: white;") %>
                  <% else %>
                    <div style="width: 45px; height: 45px; background: #f8fafc; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: 10px; margin: 0 auto;">NA</div>
                  <% end %>
                </td>

                <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
                  <span class="badge" style="background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; font-weight: 600; font-size: 11px; border-radius: 4px;">
                    <%= item.category&.name || 'N/A' %>
                  </span>
                </td>

                <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: right; color: #475569; font-family: 'JetBrains Mono', monospace; font-weight: 600;">
                  <%= number_to_currency(price_record&.price_purchase || 0, precision: 4) %>
                </td>

                <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center;">
                  <span class="badge" style="background: #f0fdf4; color: #166534; border: 1px solid #dcfce7; font-weight: 700;">
                    <%= price_record&.utility || 0 %>%
                  </span>
                </td>

                <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: right;">
                  <div style="font-weight: 800; color: #0f172a; font-family: 'JetBrains Mono', monospace; font-size: 15px;">
                    <%= number_to_currency(price_record&.price_sale || 0, precision: 4) %>
                  </div>
                </td>

                <% if can? :read, item %>
                  <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: center; color: #94a3b8; font-size: 12px;">
                    <%= item.updated_at.strftime("%d/%m/%Y") %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>



