


<table class="table">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Estado</th>
      <th>Fecha</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @price_lists.each do |price_list| %>
      <tr>
        <td><%= price_list.name %></td>
    
        <td><%= price_list.state %></td>
        <td><%= price_list.date %></td>
   
        <td>
            <% if can? :read, PriceList %>
          <%= link_to 'Ver', price_list, class: "btn btn-info" %>
            <%= link_to 'Ver', price_list_item_path(id: price_list), class: "btn btn-success" %>
            <% end %>
          </td>
        <td>
           <% if can? :update, PriceList %>
          <%= link_to 'Editar', edit_price_list_path(price_list), class: "btn btn-primary"  %>
            <% end %>
          </td>
        <td>
          <% if can? :destroy, PriceList %>
          <%= link_to 'Eliminar', price_list, method: :delete, data: { confirm: 'Are you sure?' },class: "btn btn-danger"  %>
            <% end %>
          </td>
      </tr>
    <% end %>
  </tbody>
</table>
