<div class="row">
  <div class="col-lg-1"></div>
  <div class="col-lg-10 panel panel-info">
    <div class="white-box">
      
      <%= form_for(@price_list) do |f| %>
        <!-- 📝 Cabecera y Nombre de la Lista -->
        <div class="row" style="margin-bottom: 25px; align-items: center;">
          <div class="col-md-5">
            <h4 class="box-title" style="margin-top: 0; font-weight: 800; color: #1e293b;">
              <i class="fa fa-sliders" style="color: #0284c7;"></i> Constructor POS: <%= @price_list.name %>
            </h4>
          </div>
          <div class="col-md-3">
            <div class="form-group" style="margin-bottom: 0;">
              <%= f.text_field :name, class: "form-control", placeholder: "Nombre de la Lista", style: "border-radius: 8px; font-weight: 600; border: 2px solid #e2e8f0; padding: 10px 15px;", required: true %>
            </div>
          </div>
          <div class="col-md-2" style="display: flex; align-items: center; gap: 8px; justify-content: center;">
            <%= f.check_box :default, style: "width: 18px; height: 18px; cursor: pointer;" %>
            <label for="price_list_default" style="font-weight: 600; color: #475569; margin-bottom: 0; cursor: pointer;">Por Defecto</label>
          </div>
          <div class="col-md-2 text-right">
            <%= f.submit "Actualizar", class: "btn btn-success btn-rounded btn-outline btn-block", style: "font-weight: bold;" %>
          </div>
        </div>

        <div class="row" style="display: flex; align-items: stretch; gap: 20px;">
          
          <!-- 🎛️ COLUMNA IZQUIERDA: Mosaico de Categorías (POS Estilo) -->
          <div class="col-md-4" style="background: #f8fafc; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0;">
            <h5 style="font-weight: 800; color: #475569; margin-bottom: 12px; font-size: 11px; text-transform: uppercase;">Cargar Categorías</h5>
            <div class="pos-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
              <% @categories.each do |cat| %>
                <% 
                  category_included = @datas.any? { |d| d[:category] == cat } 
                %>
                <button type="button" class="pos-tile <%= 'tile-selected' if category_included %>" onclick="addCategoryToBuilder(<%= cat.id %>, this)" id="tile-<%= cat.id %>" style="width: 100%; border: 1px solid #e2e8f0;">
                  <div class="tile-circle"><i class="fa fa-folder-open"></i></div>
                  <div class="tile-name"><%= cat.name %></div>
                  <span class="tile-count"><%= cat.items.where(active: true).count %> artículos</span>
                </button>
              <% end %>
            </div>
          </div>

          <!-- 📊 COLUMNA DERECHA: Tabla de Actualización / Carrito -->
          <div class="col-md-8" style="flex-grow: 1;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <h5 style="font-weight: 800; color: #1e293b; margin: 0; font-size: 13px;">Vista Previa de Artículos</h5>
              <%= link_to price_list_item_price_list_path(@price_list), class: "btn btn-xs btn-info btn-outline btn-rounded" do %>
                 <i class="fa fa-eye"></i> Vista Impresión
              <% end %>
            </div>

            <div class="table-responsive" style="background: white; border-radius: 12px; border: 1px solid #e2e8f0;">
              <table class="table table-bordered table-striped" id="items-table" style="vertical-align: middle; margin-bottom: 0;">
                <thead>
                  <tr style="background: #2c3e50; color: white;">
                    <th class="text-center" style="width: 120px;">Categoría</th>
                    <th>Producto</th>
                    <th class="text-center">P. Venta ($)</th>
                    <th class="text-center">P. Venta (Bs.)</th>
                    <th class="text-center" style="width: 50px;">Incluir</th>
                  </tr>
                </thead>
                <tbody id="empty-placeholder" class="<%= 'hidden' if @datas.any? %>">
                  <tr>
                    <td colspan="5" class="text-center" style="padding: 40px; color: #94a3b8; font-style: italic;">
                      <i class="fa fa-shopping-basket" style="font-size: 35px; display: block; margin-bottom: 10px; color: #cbd5e1;"></i>
                      Lienzo vacío. Agrega categorías desde el panel lateral izquierdo para planificar.
                    </td>
                  </tr>
                </tbody>
                <!-- 📜 Carga de Items Existentes -->
                <% @datas.each do |data| %>
                   <%= render partial: 'price_lists/category_tbody_new', locals: { category: data[:category], items: data[:items] } %>
                <% end %>
              </table>
            </div>
          </div>

        </div>
      <% end %>

    </div>
  </div>
  <div class="col-lg-1"></div>
</div>

<!-- 🧪 Estilos POS -->
<style>
  .pos-tile { background: white; border-radius: 10px; padding: 12px; text-align: center; cursor: pointer; transition: 0.2s; min-height: 85px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; }
  .pos-tile:hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(0,0,0,0.06); border-color: #38bdf8; }
  .pos-tile.tile-selected { background: #e0f2fe !important; border-color: #0284c7 !important; }
  .pos-tile.tile-selected .tile-circle { background: #0284c7 !important; color: white !important; }
  .pos-tile.tile-selected .tile-name { color: #0284c7 !important; }
  .tile-circle { width: 30px; height: 30px; background: #e0f2fe; color: #0284c7; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 12px; }
  .tile-name { font-weight: 700; font-size: 13px; color: #334155; }
  .tile-count { font-size: 10px; color: #94a3b8; }
  .hidden { display: none !important; }
</style>

<!-- 🧠 Javascript para Actualización Máquina POS -->
<script>
  function addCategoryToBuilder(catId, element) {
    if (!catId) return;
    const table = document.getElementById("items-table");
    const placeholder = document.getElementById("empty-placeholder");
    const existingGroup = document.getElementById("cat-group-" + catId);

    if (existingGroup) {
      if (confirm("¿Remover esta categoría completa del lienzo?")) {
          existingGroup.parentNode.removeChild(existingGroup);
          if (element) element.classList.remove("tile-selected");
      }
      return;
    }

    if(element) element.style.opacity = "0.6";

    fetch(`/price_lists/get_category_rows?category_id=${catId}`)
    .then(response => response.json())
    .then(data => {
      if(element) { element.style.opacity = "1"; element.classList.add("tile-selected"); }

      if (data.success) {
         if (placeholder) placeholder.classList.add('hidden');
         table.insertAdjacentHTML('beforeend', data.html);
      }
    })
    .catch(error => { console.error('Error POS Update:', error); });
  }

  // 🗑️ Remover de Lienzo local
  function removeCategoryFromNew(catId) {
    const group = document.getElementById("cat-group-" + catId);
    const tile = document.getElementById("tile-" + catId);
    if (group) {
        group.parentNode.removeChild(group);
        if (tile) tile.classList.remove("tile-selected");
    }
  }

  // 🔘 Desmarcar un solo item (Borra su input hidden del post)
  function toggleSingleRow(checkbox, itemId) {
       const row = checkbox.closest('tr');
       const hiddenInput = row.querySelector('.items-to-save');
       
       if (checkbox.checked) {
           row.style.background = "";
           if (hiddenInput) hiddenInput.disabled = false;
       } else {
           row.style.background = "#f1f5f9";
           if (hiddenInput) hiddenInput.disabled = true; 
       }
  }
</script>
