<style>
  :root {
    --primary-gradient: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
    --bg-light: #f8fafc;
    --border-color: #e2e8f0;
    --text-main: #1e293b;
    --text-muted: #64748b;
  }

  .premium-index-wrapper {
    background: var(--bg-light); padding: 1.5rem; font-family: 'Inter', system-ui, sans-serif; min-height: 100vh;
  }

  .premium-banner {
    background: var(--primary-gradient); padding: 2.2rem; border-radius: 20px;
    color: white; margin-bottom: 2rem; position: relative; overflow: hidden;
    box-shadow: 0 10px 30px rgba(14, 165, 233, 0.15);
    display: flex; justify-content: space-between; align-items: center;
  }

  .banner-info h1 { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.02em; margin: 0; }
  .banner-info p { font-size: 1.1rem; opacity: 0.9; margin-top: 6px; }

  .index-metrics {
    display: flex; gap: 1.5rem;
  }
  .metric-card {
    background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 16px;
    padding: 12px 20px; text-align: right; min-width: 150px;
  }
  .metric-label { font-size: 0.85rem; opacity: 0.8; font-weight: 600; text-transform: uppercase; }
  .metric-value { font-size: 1.5rem; font-weight: 800; margin-top: 2px; display: block; }

  .action-bar {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding: 0 5px;
  }

  .btn-premium-solid {
    background: var(--primary-gradient); border: none; border-radius: 12px;
    color: white !important; font-weight: 700; padding: 12px 24px; font-size: 1rem;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.25); transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 8px; cursor: pointer; text-decoration: none;
  }
  .btn-premium-solid:hover {
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35); transform: translateY(-1px);
  }

  .btn-premium-outline {
    background: white; border: 1.5px solid #cbd5e1; border-radius: 12px;
    color: #475569; font-weight: 700; padding: 11px 22px; font-size: 1rem;
    transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
  }
  .btn-premium-outline:hover {
    background: #f1f5f9; border-color: #94a3b8; color: #1e293b;
  }

  /* 🛠️ Estilos para Botones de Acción en la Tabla */
  .btn-action-premium {
    width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
    border-radius: 10px; transition: all 0.2s; text-decoration: none !important;
    border: 1px solid transparent;
  }
  .btn-action-premium:hover {
    transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    border-color: rgba(0,0,0,0.05);
  }

  .table tbody tr:hover {
    background: #f8fafc !important;
  }
</style>

<script>
  function togglePriceListState(priceListId) {
    const badge = document.getElementById('badge-state-' + priceListId);
    
    // Indicador visual de carga
    badge.style.opacity = '0.5';
    badge.style.cursor = 'wait';

    $.ajax({
      url: '/price_lists/' + priceListId + '/toggle_state',
      type: 'PATCH',
      data: { authenticity_token: '<%= form_authenticity_token %>' },
      success: function(response) {
        if (response.success) {
          if (response.state === 'activo') {
            badge.innerText = 'ACTIVO';
            badge.style.background = '#f0fdf4';
            badge.style.color = '#166534';
            badge.style.borderColor = '#dcfce7';
          } else {
            badge.innerText = 'INACTIVO';
            badge.style.background = '#fef2f2';
            badge.style.color = '#b91c1c';
            badge.style.borderColor = '#fee2e2';
          }
        }
      },
      error: function() {
        alert('Error al actualizar el estado de la lista.');
      },
      complete: function() {
        badge.style.opacity = '1';
        badge.style.cursor = 'pointer';
      }
    });
  }
</script>

<div class="premium-index-wrapper">
  <!-- 🚩 Banner Principal -->
  <div class="premium-banner">
    <div class="banner-info">
      <h1><i class="fa fa-tags mr-2" style="opacity: 0.7;"></i> Listas de Precios</h1>
      <p>Configura y gestiona tus estrategias comerciales desde un solo lugar.</p>
    </div>

    <div class="index-metrics">
      <div class="metric-card">
        <span class="metric-label">Activas</span>
        <span class="metric-value"><%= @price_lists.where(state: 'activo').count %></span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Default</span>
        <span class="metric-value"><%= @price_lists.where(default: true).count %></span>
      </div>
    </div>
  </div>

  <!-- 🛠️ Barra de Acciones y Controles -->
  <div class="action-bar">
    <div>
      <h3 style="font-weight: 800; color: #1e293b; margin: 0; font-size: 1.3rem;">Catálogo de Estrategias</h3>
    </div>
    
    <div style="display: flex; gap: 12px;">
      <%= link_to price_list_for_sale_path(format: :pdf), class: "btn-premium-outline", target: "_blank" do %>
        <i class="fas fa-file-pdf" style="color: #ef4444;"></i> Catálogo Público
      <% end %>

      <%= link_to new_price_list_path, class: "btn-premium-solid" do %>
        <i class="fa fa-plus-circle"></i> Nueva Lista
      <% end %>
    </div>
  </div>

  <!-- 📊 Tabla de Resultados (Modernizada en el paso anterior) -->
  <%= render partial: 'results_search' %>

  <!-- 📜 Footer de Información -->
  <div style="margin-top: 2rem; padding: 1.5rem; background: #f1f5f9; border-radius: 15px; border: 1px dashed #cbd5e1; display: flex; align-items: center; gap: 15px;">
    <div style="background: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0284c7; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
      <i class="fa fa-info-circle"></i>
    </div>
    <div style="font-size: 0.95rem; color: #64748b;">
      <strong style="color: #475569;">Consejo:</strong> Las listas marcadas como <span style="font-weight: 700; color: #b45309;">PREDETERMINADAS</span> son las que el sistema utilizará automáticamente en el punto de venta (POS) y facturación móvil.
    </div>
  </div>
</div>
