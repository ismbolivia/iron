<!DOCTYPE html>
<html>
<head>
	<title>Productos</title>
    <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>		
	    <div class="col-md-12">
	    	<div class=" printableArea">        		   	
	         	<div class="row"  align="center">			  
					<h3><b> <%= @price_list.name%> </b> </h3>	           
				</div>
			</div>
		</div>
    <div class="row">
        <div class="col-lg-1"> </div>
            <div class="col-lg-10 panel">
                <div class="white-box">
                  <div class="">               	     
					<% @datas[1].each do |data| %>     
					   <%if data.class == Category %>	
					    	<div align="center" class="text-info">
					 			<h4 ><strong>PRODUCTOS DE LA CATEGORIA (<%= data.name %>)</strong></h4>
					  		</div>
							<table class="table table-bordered ">
								<thead>
							      <tr class="">		
								   <% data.items.order(:name).limit(6).each_with_index do |item, index| %>
								    	<% if index == 2 or index==3 %>
								   		<th class="table_center">
											<%= wicked_pdf_image_tag item.image.large.url, :alt => "imge-item", :style => "iwidth:100%; height:100px;" %>	
									    </th>
									  
									    <% else %>
										<th class="table_center"> <%= wicked_pdf_image_tag item.image.large.url, :alt => "imge-item", :style => "iwidth:100%; height:100px;" %></th>
										<% end%>
									   <%end%> 	    
								   </tr>
							    </thead>					
							</table>						  	  	
						  	  	 <% end %>
						  	  	 <%if data.class == Array %>							  	  	
						  	  	 <table class="table product-overview table-bordered ">
								    <thead class="conf-pdf text-center">
									    <tr>
									      <th style="width:250px">NOMBRE</th>
									      <th style="width:350px">DETALLE</th>
									      <th style="width:80px">UNIDAD</th>
									      <th>PRECIO $</th>
									      <% @mycompany.get_current_currency.getChangePrices.each do |price_rate| %>
									      <th>PRECIO  <%=price_rate.currencyReference.symbol %></th>
									      <% end %>									      
										</tr>
									</thead>
									<tbody>
										<% data.each do |item| %> 
										<tr>
										    <td><%= item.name %></td>
										    <td><%= item.description %></td>
										    <td><%= item.unit.name %></td>
										    <td><%= number_to_currency(item.getPriceAsignado(@datas[0].name)) %></td>
									         <% @mycompany.get_current_currency.getChangePrices.each do |price_rate| %>
									        <td> <%=price_rate.currencyReference.symbol %> <%= price_rate.getPriceCurrencyRate(item.getPriceAsignado(@datas[0].name)) %></td>	
								        <% end %>			   										      
										</tr>
										<% end %>
									</tbody>
								 </table>
									<% end %>
						  	 <%end %>					                               	  	
                    </div>
                  </div>
                </div>
              <div class="col-lg-1">
            </div>
    </div>
	</body>	
</html>
