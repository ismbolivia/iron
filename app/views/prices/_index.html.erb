<div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
  <table class="table product-overview" style="margin-bottom: 0;">
    <thead style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
      <tr>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Nombre / Tipo</th>
        <th style="padding: 1.2rem; color: #0f172a; font-weight: 800;">Costo de Compra</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">% Utilidad</th>
        <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800;">Precio de Venta</th>
        <th style="padding: 1.2rem; text-align: center; color: #0f172a; font-weight: 800;">Estado</th>
        <th style="padding: 1.2rem; text-align: right; color: #0f172a; font-weight: 800;">Acciones</th>
      </tr>
    </thead>

    <tbody>
      <% # 💎 Filtramos para mostrar solo las listas operativas (Sistema)
         prices_to_show = @item.prices.joins(:price_list).where(price_lists: { list_type: :sistema })
         prices_to_show.each do |price| 
      %>
        <tr style="transition: all 0.2s;">
          <td style="padding: 1.2rem; vertical-align: middle;">
            <div style="font-weight: 800; color: var(--text-main); font-size: 1.2rem;"><%= price.name %></div>
            <div style="font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">Lista de Precios</div>
          </td>
          <td style="padding: 1.2rem; vertical-align: middle; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 600;">
            <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(price.price_purchase, precision: 4) %>
          </td>
          <td style="padding: 1.2rem; vertical-align: middle; text-align: center;">
            <span class="badge" style="background: #ecfdf5; color: #059669; border: 1px solid #d1fae5; font-weight: 800; padding: 8px 12px; font-size: 1.1rem;">
              <%= price.utility %>%
            </span>
          </td>
          <td style="padding: 1.2rem; vertical-align: middle; text-align: right;">
            <div style="font-weight: 900; color: var(--accent-indigo); font-size: 1.5rem;">
              <%= @mycompany.get_current_currency.symbol %> <%= number_with_precision(price.price_sale, precision: 4) %>
            </div>
          </td>
          <td style="padding: 1.2rem; vertical-align: middle; text-align: center;">
            <% if price.active %>
              <span class="badge" style="background: #eff6ff; color: #3b82f6; border: 1px solid #dbeafe; font-size: 0.9rem; font-weight: 800; padding: 6px 12px;">ACTIVO</span>
            <% else %>
              <span class="badge" style="background: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; font-size: 0.9rem; font-weight: 800; padding: 6px 12px;">INACTIVO</span>
            <% end %>
          </td>
          <td style="padding: 1rem 1.2rem; vertical-align: middle; text-align: right;">
            <div class="btn-group">
              <%= link_to edit_price_path(price), class: "btn btn-sm", style: "background: #f8fafc; color: #475569; border: 1px solid #e2e8f0; margin-right: 5px;", remote: true, title: "Actualizar" do %>
                <i class="fas fa-edit"></i>
              <% end %>
              <%= link_to price, method: :delete, remote: true, data: { confirm: '¿Está seguro de eliminar este precio?' }, class: "btn btn-sm", style: "background: #fff1f2; color: #e11d48; border: 1px solid #ffe4e6;", title: "Eliminar" do %>
                <i class="fas fa-trash"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
