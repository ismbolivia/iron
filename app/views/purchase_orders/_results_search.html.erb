<table class="table table-hover po-table mb-0">
  <thead>
    <tr>
      <th style="width: 15%;">Código / Fecha</th>
      <th style="width: 25%;">Proveedor</th>
      <th style="width: 25%;">Nota</th>
      <th style="width: 12%; text-align: center;">Estado</th>
      <th style="width: 13%; text-align: right;">Total</th>
      <th style="width: 10%; text-align: center;">Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% if @purchase_orders.any? %>
      <% @purchase_orders.each do |po| %>
        <tr>
          <td>
            <div style="font-weight: 800; color: #3b82f6; font-size: 1.1rem; margin-bottom: 3px;"><%= po.name %></div>
            <div style="font-size: 0.85rem; color: #94a3b8; font-weight: 600;"><i class="far fa-calendar-alt"></i> <%= po.date_order.present? ? po.date_order.strftime("%d/%m/%Y") : (po.created_at.strftime("%d/%m/%Y") rescue "") %></div>
          </td>
          <td>
            <div style="display: flex; align-items: center; gap: 12px;">
              <div style="min-width: 40px; height: 40px; border-radius: 12px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #64748b; font-size: 1.15rem;">
                <i class="fas fa-building"></i>
              </div>
              <span style="font-weight: 700; color: #1e293b; font-size: 1.05rem;"><%= po.supplier&.name || 'Sin Proveedor' %></span>
            </div>
          </td>
          <td>
            <% if po.note.present? %>
              <div style="color: #64748b; font-size: 0.95rem; max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= po.note %>">
                <%= po.note %>
              </div>
            <% else %>
              <span style="color: #cbd5e1; font-size: 0.95rem; font-style: italic;">Sin nota particular</span>
            <% end %>
          </td>
          <td style="text-align: center;">
            <span class="badge-status bg-status-<%= po.state %>"><%= (po.state || 'N/A').upcase %></span>
          </td>
          <td style="text-align: right;">
            <span style="font-weight: 800; color: #10b981; font-size: 1.25rem;">
              <%= po.currency&.symbol || 'Bs.' %> <%= number_with_precision(po.subtotal, precision: 2, delimiter: ',') %>
            </span>
          </td>
          <td style="text-align: center; white-space: nowrap;">
            <%= link_to po, class: "action-btn action-view", title: "Ver Detalle" do %>
              <i class="fas fa-eye"></i>
            <% end %>
            <%= link_to edit_purchase_order_path(po), class: "action-btn action-edit", title: "Editar" do %>
              <i class="fas fa-pen"></i>
            <% end %>
            <%= link_to po, method: :delete, data: { confirm: '¿Estás seguro de eliminar esta orden?' }, class: "action-btn action-delete", title: "Eliminar" do %>
              <i class="fas fa-trash"></i>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="6" style="text-align: center; padding: 5rem 2rem;">
          <div style="opacity: 0.4;">
            <i class="fas fa-file-invoice-dollar fa-4x mb-4 text-muted"></i>
            <h4 style="color: #64748b; font-weight: 800;">No hay pedidos de compra</h4>
            <p style="color: #94a3b8; font-size: 1.1rem;">Inicia creando tu primer pedido.</p>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="p-4 border-top">
  <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
</div>
