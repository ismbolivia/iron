<tr>
  <td class="text-center"><span style="font-family: monospace; font-size: 0.85rem; color: var(--text-muted); background: #f1f5f9; padding: 2px 6px; border-radius: 4px;"><%= index + 1 %></span></td>
  <td style="font-weight: 600; color: #1e293b; font-size: 0.95rem;">
    <div class="d-flex align-items-center gap-2">
      <% if item[:priority].present? %>
        <span class="badge" style="background: #f1f5f9; color: #475569; font-size: 0.85rem; border: 1px solid #cbd5e1;" title="Priority: <%= item[:priority] %>">P<%= item[:priority] %></span>
      <% end %>
      <span><%= item[:name] %></span>
    </div>
    <% if item[:category_name].present? %>
      <div style="font-size: 0.9rem; color: #64748b; font-weight: 400; margin-top: 2px;"><i class="fas fa-tag mr-1"></i><%= item[:category_name] %></div>
    <% end %>
  </td>
  
  <td class="text-center">
    <% if item[:stock_actual] <= 0 %>
      <span class="pv2-badge pv2-badge-danger" style="display: block; margin-bottom: 5px;"><%= item[:stock_actual] %> <small><%= item[:unit_name] %></small></span>
      <span style="font-size: 0.75rem; color: #ef4444; font-weight: 800;"><i class="fas fa-exclamation-triangle"></i> AGOTADO </span>
    <% elsif item[:is_critical] %>
      <span class="pv2-badge" style="background: #fffbeb; color: #b45309; border: 1px solid #fde68a; display: block; margin-bottom: 5px;"><%= item[:stock_actual] %> <small><%= item[:unit_name] %></small></span>
      <span style="font-size: 0.75rem; color: #dc2626; font-weight: 800;"><i class="fas fa-bolt"></i> <%= item[:days_remaining] %> DÍAS RESTANTES </span>
    <% else %>
      <span class="pv2-badge pv2-badge-success"><%= item[:stock_actual] %> <small><%= item[:unit_name] %></small></span>
    <% end %>
  </td>
  
  <td class="text-center" style="border-right: 2px solid var(--border-color); background: #f8fafc;">
    <div class="d-flex align-items-center justify-content-center gap-1">
      <input type="number" min="0" step="0.0001" class="pv2-qty-input" value="<%= item[:suggested_qty] %>" data-item-id="<%= item[:id] %>" title="Basado en velocidad de venta ponderada y stock actual">
      <span style="font-size: 0.75rem; color: #64748b; font-weight: 600;"><%= item[:unit_name] %></span>
    </div>
  </td>

  <td class="text-center" style="border-right: 2px solid var(--border-color); background: #ecfdf5;">
    <input type="number" min="0" step="0.0001" class="pv2-cost-input" value="<%= item[:last_price] %>" data-item-id="<%= item[:id] %>" title="Último costo de compra histórica">
  </td>
  
  <td class="text-center" style="background:#f1f5f9; font-weight:800; color:#0f172a; font-size: 0.95rem;"><%= item[:qty_30d].to_i %></td>
  <td class="text-center" style="color: var(--text-muted);"><%= item[:qty_90d].to_i %></td>
  <td class="text-center" style="color: var(--text-muted);"><%= item[:qty_180d].to_i %></td>
  <td class="text-center" style="border-right: 2px solid var(--border-color); font-weight:700; color:#475569;"><%= item[:qty_365d].to_i %></td>

  <td class="text-center col-historic" style="color: #be185d; font-size: 0.85rem; background: #fff1f2;"><%= item[:hist_yr_0_qty].to_i %></td>
  <td class="text-center col-historic" style="font-weight: 700; color: #e11d48; border-right: 1px solid #fda4af; background: #fff1f2;"><%= number_with_precision(item[:hist_yr_0_avg], precision: 4) %></td>

  <td class="text-center col-historic" style="color: #64748b; font-size: 0.85rem;"><%= item[:hist_yr_1_qty].to_i %></td>
  <td class="text-center col-historic" style="font-weight: 700; color: #4f46e5; border-right: 1px solid #e2e8f0; background: #eff6ff;"><%= number_with_precision(item[:hist_yr_1_avg], precision: 4) %></td>
  
  <td class="text-center col-historic" style="color: #64748b; font-size: 0.85rem;"><%= item[:hist_yr_2_qty].to_i %></td>
  <td class="text-center col-historic" style="font-weight: 700; color: #4f46e5; border-right: 1px solid #e2e8f0; background: #eff6ff;"><%= number_with_precision(item[:hist_yr_2_avg], precision: 4) %></td>
  
  <td class="text-center col-historic" style="color: #64748b; font-size: 0.85rem;"><%= item[:hist_yr_3_qty].to_i %></td>
  <td class="text-center col-historic" style="font-weight: 700; color: #4f46e5; background: #eff6ff;"><%= number_with_precision(item[:hist_yr_3_avg], precision: 4) %></td>
  
  <td class="text-center" style="border-left: 2px solid var(--border-color); background: #f8fafc;">
    <button class="pv2-btn-remove" title="Quitar de esta lista">
      <i class="fas fa-times"></i>
    </button>
  </td>
</tr>
