              <th colspan="2" style="color: #34d399; font-size: 0.75rem; text-align: center; border: none; vertical-align: middle;">
                <div style="text-transform: uppercase; font-weight: 800;"><i class="fas fa-tag"></i> RESULTADO DE VENTA</div>
              </th>
            </tr>
