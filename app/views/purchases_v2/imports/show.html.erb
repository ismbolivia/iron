              <th style="color: white; border: none; text-align: right; background: rgba(255,255,255,0.05);">Ant.</th>
              <th style="color: white; border: none; text-align: right; background: rgba(255,255,255,0.05);">Landed Final</th>
              <th style="color: white; border: none; text-align: center; width: 100px;">C1 ($)</th>
              <th style="color: white; border: none; text-align: center; width: 100px;">C2 ($)</th>
              <th style="color: white; border: none; text-align: center; width: 100px;">C3 ($)</th>
              <th style="color: white; border: none; text-align: center; width: 110px; background: rgba(255,255,255,0.05);">% OPEX</th>
              <th style="color: white; border: none; text-align: center; width: 110px; background: rgba(255,255,255,0.05);">% Util. Neta</th>
              <th style="color: white; border: none; text-align: right;">Ant.</th>
