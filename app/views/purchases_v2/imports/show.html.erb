            <% else %>
              <tr><td colspan="8" style="text-align: center; padding: 2rem; color: #94a3b8;">No hay productos vinculados.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  <% else %>
    <!-- Laboratorio de Precios (Fase: Recibido / Completado) -->
    <div class="card-premium" style="margin-top: 1.5rem; border: 3px solid #4f46e5; border-radius: 20px;">
