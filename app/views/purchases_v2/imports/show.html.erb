                  <td style="font-weight: 700; color: #4f46e5;"><%= cost[:item_code] %></td>
                  <td><%= cost[:item_name] %></td>
                  <td style="text-align: center;"><%= cost[:qty].to_i %></td>
                  <td><input type="number" class="form-control item-dim-input" value="<%= item&.volume_m3 %>" step="0.001" data-id="<%= cost[:item_id] %>" data-field="volume_m3" style="width: 90px; text-align: center; border-radius: 8px; border: 1.5px solid #cbd5e1; height: 38px;"></td>
                  <td><input type="number" class="form-control item-dim-input" value="<%= item&.weight_kg %>" step="0.1" data-id="<%= cost[:item_id] %>" data-field="weight_kg" style="width: 90px; text-align: center; border-radius: 8px; border: 1.5px solid #cbd5e1; height: 38px;"></td>
                  <td><input type="number" class="form-control item-dim-input <%= 'disabled' unless @import.borrador? %>" <%= 'disabled' unless @import.borrador? %> value="<%= cost[:costo_fob] %>" step="0.01" data-id="<%= cost[:item_id] %>" data-line-id="<%= cost[:line_id] %>" data-field="costo_fob" style="width: 100px; text-align: right; border-radius: 8px; border: 1.5px solid #cbd5e1; height: 38px;"></td>
