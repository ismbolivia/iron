<!-- Script AJAX para guardar peso y volumen al cambiar los inputs -->
<script>
  $(document).on('change', '.item-dim-input', function() {
    const itemId = $(this).data('id');
    const field = $(this).data('field');
    const val = $(this).val();

    // Encontrar el otro input de la misma fila para mandar ambos valores
    const $row = $(this).closest('tr');
    const vol = $row.find(`[data-field="volume_m3"]`).val();
    const weight = $row.find(`[data-field="weight_kg"]`).val();
    const costoFob = $row.find(`[data-field="costo_fob"]`).val();
    const lineId = $row.find(`[data-field="costo_fob"]`).data('line-id');

    let postData = {
      item_id: itemId,
      line_id: lineId,
      volume_m3: vol,
      weight_kg: weight,
      costo_fob: costoFob,
      authenticity_token: '<%= form_authenticity_token %>'
    };

    $(this).css('border-color', '#f59e0b'); // Indicador de guardado

    $.ajax({
      url: '<%= update_item_dims_purchases_v2_import_path(@import) %>',
      method: 'POST',
      data: postData,
      success: function(response) {
        if (response.success) {
          $row.find('.item-dim-input').css('border-color', '#10b981'); // Guardado ok
          // Opcional: Recargar la pagina para que se recalcule la cubicación del contenedor general
          setTimeout(() => { location.reload(); }, 600);
        } else {
          $row.find('.item-dim-input').css('border-color', '#ef4444');
          alert('Error al guardar dimensiones.');
        }
      },
      error: function() {
        $row.find('.item-dim-input').css('border-color', '#ef4444');
      }
    });
  });
</script>
</div>
