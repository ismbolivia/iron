        <table class="table-premium" style="margin: 0; min-width: 1100px;">
          <thead style="background: #1e1b4b;">
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
              <th style="color: rgba(255,255,255,0.6); font-size: 0.75rem; text-align: center; border: none;">IDENTIFICACIÓN</th>
              <th colspan="2" style="color: #fbbf24; font-size: 0.75rem; text-align: center; border: none; background: rgba(255,255,255,0.05);">📉 ANÁLISIS DE COSTOS</th>
              <th colspan="3" style="color: #93c5fd; font-size: 0.75rem; text-align: center; border: none;">🔎 COMPETENCIA</th>
