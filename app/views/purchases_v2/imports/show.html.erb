                    </td>
                    <td>
                      <input type="number" class="form-control pricing-lab px-comp3 <%= 'disabled' if @import.completado? %>" <%= 'disabled' if @import.completado? %> data-id="<%= price.id %>" value="<%= price.comp_3_price %>" step="0.5" style="font-weight: 700; text-align: center; border: 1.5px dashed #94a3b8; border-radius: 6px; font-size: 0.95rem; color: #475569;" placeholder="C3">
                    </td>
                    <td>
                      <input type="number" class="form-control pricing-lab px-opex <%= 'disabled' if @import.completado? %>" <%= 'disabled' if @import.completado? %> data-id="<%= price.id %>" data-landed="<%= new_cost %>" value="<%= price.opex_margin %>" step="0.1" style="font-weight: 800; text-align: center; border: 2px solid #cbd5e1; border-radius: 8px; font-size: 1.05rem; color: #f59e0b;">
                    </td>
                    <td>
                      <input type="number" class="form-control pricing-lab px-util <%= 'disabled' if @import.completado? %>" <%= 'disabled' if @import.completado? %> data-id="<%= price.id %>" data-landed="<%= new_cost %>" value="<%= price.utility %>" step="0.1" style="font-weight: 800; text-align: center; border: 2px solid #cbd5e1; border-radius: 8px; font-size: 1.05rem; color: #4f46e5;">
                    </td>
                    <td style="text-align: right; color: #94a3b8; text-decoration: line-through;"><%= number_to_currency(price.price_sale, precision: 4) %></td>
                    <td class="px-new-sale-<%= price.id %>" style="text-align: right; font-weight: 900; color: #10b981; font-size: 1.25rem;"><%= number_to_currency(sugerido, precision: 4) %></td>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @import.recibido? %>
        <div style="padding: 2.5rem; background: #f8fafc; text-align: center; border-radius: 0 0 17px 17px; border-top: 1px solid #e2e8f0;">
          <h3 style="font-weight: 900; color: #1e293b; margin-bottom: 0.5rem;">Cierre Definitivo de Importación</h3>
          <p style="color: #64748b; margin-bottom: 2rem;">Confirma que has revisado los márgenes propuestos. Este botón re-escribirá todos los precios de venta públicamente y enviará los productos al inventario para la venta.</p>
          
          <%= link_to confirm_reception_purchases_v2_import_path(@import), method: :post, data: { confirm: 'ATENCIÓN: ¿Estás completamente seguro de APROBAR los precios actuales y habilitar el stock? Esta acción SELLA PERMANENTEMENTE la carpeta logística.' }, class: "btn-premium-solid", style: "background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white !important; font-size: 1.2rem; padding: 16px 40px; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4); text-transform: uppercase;" do %>
            <i class="fas fa-check-double mr-2"></i> Aprobar Precios e Inyectar Stock
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Script del Laboratorio de Precios -->
  <script>
    $(document).on('change', '.px-opex, .px-util, .px-comp1, .px-comp2, .px-comp3', function() {
      calculatePrice($(this).closest('tr'));
    });

    function calculatePrice($row) {
      const priceId = $row.find('.px-util').data('id');
      const landedCost = parseFloat($row.find('.px-util').data('landed')) || 0;
      const logic = $('#import-logic-toggle').val();
      
      const opex = parseFloat($row.find('.px-opex').val()) || 0;
      const util = parseFloat($row.find('.px-util').val()) || 0;
      const comp1 = parseFloat($row.find('.px-comp1').val()) || 0;
      const comp2 = parseFloat($row.find('.px-comp2').val()) || 0;
      const comp3 = parseFloat($row.find('.px-comp3').val()) || 0;
      
      let c_operativo = landedCost;
      if (opex > 0 && opex <= 100) {
        c_operativo = landedCost * (1 + (opex / 100));
      } else if (opex > 100) {
        c_operativo = landedCost + opex;
      }

      let sugerido = 0;
      if (logic === 'margin') {
        if (util > 0 && util < 100) {
          const factor = 1 - (util / 100);
          sugerido = c_operativo / factor;
        } else {
          sugerido = c_operativo + util;
        }
      } else {
        // Lógica de Markup sobre Costo
        sugerido = c_operativo * (1 + (util / 100));
      }
      
      // Formatear a moneda con 4 decimales
      const formatter = new Intl.NumberFormat('en-US', { 
        style: 'currency', 
        currency: 'USD',
        minimumFractionDigits: 4,
        maximumFractionDigits: 4
      });
      $('.px-new-sale-' + priceId).text(formatter.format(sugerido.toFixed(4)));

      $.ajax({
        url: '<%= update_price_margins_purchases_v2_import_path(@import) rescue "#" %>',
        method: 'POST',
        data: {
          price_id: priceId,
          pricing_logic: logic, // Siempre enviamos la lógica actual
          opex_margin: opex,
          utility: util,
          comp_1: comp1,
          comp_2: comp2,
          comp_3: comp3,
          authenticity_token: '<%= form_authenticity_token %>'
        },
        success: function(response) {
          if(response.success) {
            $row.find('.pricing-lab').css('border-color', '#10b981'); // Verde "guardado"
          } else {
            console.error('Error al guardar el margen.');
          }
        }
      });
    }

    $('.btn-import-logic').on('click', function() {
      const logic = $(this).data('logic');
      
      // Update UI
      $('.btn-import-logic').removeClass('active').css({ 'background': 'transparent', 'color': 'rgba(255,255,255,0.6)' });
      $(this).addClass('active');
      if (logic === 'margin') {
        $(this).css({ 'background': '#10b981', 'color': 'white' });
      } else {
        $(this).css({ 'background': '#f59e0b', 'color': 'white' });
      }

      // Update Logic Value
      $('#import-logic-toggle').val(logic);

      // Guardar lógica en el servidor
      $.ajax({
        url: '<%= update_price_margins_purchases_v2_import_path(@import) %>',
        method: 'POST',
        data: { pricing_logic: logic, authenticity_token: '<%= form_authenticity_token %>' }
      });

      $('.table-premium tbody tr').each(function() {
        if ($(this).find('.px-util').length > 0) {
          calculatePrice($(this));
        }
      });
    });

    $('#apply-all-utility').on('click', function() {
      const firstUtil = $('.px-util').first().val();
      if (confirm('¿Deseas aplicar el margen del ' + firstUtil + '% a TODOS los productos de esta importación?')) {
        $('.px-util').val(firstUtil);
        $('.table-premium tbody tr').each(function() {
          if ($(this).find('.px-util').length > 0) {
            calculatePrice($(this));
          }
        });
      }
    });
  </script>

  <!-- Botón Regresar -->
  <div style="margin-top: 1rem;">
    <%= link_to purchases_v2_imports_path, class: "btn-premium-outline" do %>
      <i class="fas fa-arrow-left"></i> Volver al listado
    <% end %>
  </div>
</div>

