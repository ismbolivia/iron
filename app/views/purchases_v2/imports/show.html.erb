                <% item.prices.activo.each do |price| %>
                  <% old_cost = price.price_purchase.to_f %>
                  <% new_cost = cost[:costo_landed].to_f %>
                  <% delta = old_cost > 0 ? (((new_cost - old_cost) / old_cost) * 100).round(1) : 0 %>
                  
                  <% c_operativo = new_cost * (1 + (price.opex_margin.to_f / 100)) %>
                  <% factor = 1 - (price.utility.to_f / 100) %>
                  <% sugerido = price.utility.to_f < 100 && price.utility.to_f > 0 ? (c_operativo / (factor.zero? ? 1 : factor)).round(4) : (c_operativo + price.utility.to_f).round(4) %>

                  <tr>
                    <td style="padding-left: 3rem; font-weight: 700; color: #475569;"><i class="fas fa-tag"></i> <%= price.price_list.name %></td>
