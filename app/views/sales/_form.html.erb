
<div class="" id="sale-form">
  <div class="row">
    <div class="">
      <%= form_for(@sale) do |f| %>
        <% if @sale.errors.any? %>
          <div id="error_explanation">
            <h2><%= pluralize(@sale.errors.count, "error") %> prohibited this sale from being saved:</h2>
            <ul>
            <% @sale.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
            </ul>
          </div>
        <% end %>
    </div>
  </div>
</div>

<div class="row">
 <div class="col-md-3 col-lg-3 col-sm-5 panel panel-default">
    <br>
  <div class="col-md-12 col-lg-12 col-sm-12">
       <div style="padding: 10px 0;">
          <div style="text-transform: uppercase; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); letter-spacing: 1px; margin-bottom: 5px;">Información del Cliente</div>          
          <div class="form-group" style="margin-bottom: 20px;">
                <h2 style="font-weight: 950; color: var(--accent-indigo); margin: 0; line-height: 1.1;"><%= @sale.client.name %></h2>
          </div>
          
          <div class="form-group" style="background: #f8fafc; padding: 12px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="additional-info-wrap">
                <label class="checkbox-inline" for="Checkboxes_Grape" style="font-weight: 700; color: var(--text-main); font-size: 1rem;">
                    <%= f.check_box :credit, id:"Checkboxes_Grape", checked: true %>
                    <span id="id_credit">Venta a Crédito</span>
                </label>
                <div class="additional-info" style="margin-top: 10px;">
                    <%= f.date_field :credit_expiration, placeholder: "Fecha Vencimiento", class: "form-control", style: "font-weight: 600;" %>
                </div>
            </span>
          </div>

          <div style="display: flex; gap: 10px; margin-top: 15px;">
              <div style="flex: 1; background: #eef2ff; padding: 10px; border-radius: 8px; text-align: center; border: 1px solid #e0e7ff;">
                  <div style="font-size: 0.7rem; font-weight: 800; color: var(--accent-indigo); text-transform: uppercase;">Desc. Máx</div>
                  <div style="font-size: 1.25rem; font-weight: 900; color: var(--accent-indigo);"><%=@sale.client.discount%>%</div>
              </div>
          </div>

          <div style="margin-top: 20px;">
              <div style="text-transform: uppercase; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); margin-bottom: 8px;">Estado de Crédito</div>
              <div style="background: #fdfdfd; border: 1px solid #eee; border-radius: 10px; padding: 15px;">
                  <div style="margin-bottom: 10px;">
                      <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">Límite Total:</div>
                      <div style="font-size: 1.1rem; font-weight: 800; color: var(--text-main);"><%= @mycompany.get_current_currency.symbol%> <%=@sale.client.credit_limit %></div>
                  </div>
                  <hr style="margin: 10px 0;">
                  <div>
                      <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">Disponible:</div>
                      <div style="font-size: 1.3rem; font-weight: 950; color: var(--accent-green);"><%= @mycompany.get_current_currency.symbol%> <%= @sale.client.line_credit_available %></div>
                  </div>
              </div>
          </div>
       </div>
    </div>

    <div class="col-md-12 col-lg-12 col-sm-12 ">
        <div class="">
            <h4 class="box-title">Dirección</h4>
            <hr>
            <h5><i class="ti-mobile"></i><label id="phones_clients_sales"> <%= @sale.client.phone %> - <%= @sale.client.mobile %></label></h5> <small id="address_client_sale"> <%= @sale.client.address.get_direccion_all %></small>
        </div>
    </div>
    <div class="col-md-12 col-lg-12 col-sm-12 ">
        <hr>
    </div>
  </div>
    <div class="col-md-9 col-lg-9 col-sm-7 ">

        <div class="panel-wrapper collapse in" aria-expanded="true">
            <div class="panel-body">
                <div class="col-md-12 col-lg-12 col-sm-9">
                    <div class="col-xs-3 col-md-3 pull-left">
                        <div class="form-group">
                            <%= f.label :number, "Número" %>
                            <%= f.text_field :number, placeholder: "Número", class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-5 col-md-5">
                        <div class="form-group">
                            <%= f.label :discount, "Descuento en ventas %" %>
                            <%= f.text_field :discount, class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-2 col-md-2" style="margin-top: 25px;">
                        <div class="form-group">
                            <%= f.check_box :show_bs %>
                            <%= f.label :show_bs, "Ver en Bs." %>
                        </div>
                    </div>
                    <div class="col-xs-4 col-md-4 pull-right">
                        <div class="form-group">
                            <%= f.label :date, "Fecha" %>
                            <%= f.date_field :date, placeholder: "Fecha", class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-4 col-md-4 pull-right">
                        <div class="form-group">                            
                            <%= hidden_field :price_list_id, '' %>
                             <%= f.hidden_field :client_id  %>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-9 col-lg-9 col-sm-7 ">
        <div class="panel-wrapper collapse in" aria-expanded="true">
            <div class="panel-body" id="sale-details">
                 <%= (@sale.sale_details.count > 0) ? render(partial: 'table', locals: { sale: @sale, show_actions: true }) : 'No hay detalles cargados' %>
                </div>
                <hr>
                <!-- aqui se debe condicionar para clientes que superan su linea de credito -->
                <div id="action_sale_details_id">
                    <%= link_to 'Atras', sales_path, class: "btn btn-default btn-outline "  %>
                    <% message = (action_name == 'edit') ? "Actualizar" : "Aceptar" %>
                    <%= f.submit message, class: "btn btn-success" %>
                    <%= link_to "Añadir producto", new_sale_sale_detail_path(sale_id: @sale.id), remote: true, class: "btn btn-info pull-right" %>
                </div>                
        </div><hr>
    </div>
 </div>
</div>

<% end %>
<div class="modal fade" id="new-detail-modal" title="Modal"></div>