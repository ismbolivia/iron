
<div class="" id="sale-form">
  <div class="row">
    <div class="">
      <%= form_for(@sale) do |f| %>
        <% if @sale.errors.any? %>
          <div id="error_explanation">
            <h2><%= pluralize(@sale.errors.count, "error") %> prohibited this sale from being saved:</h2>
            <ul>
            <% @sale.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
            </ul>
          </div>
        <% end %>
    </div>
  </div>
</div>

<div class="row">
 <div class="col-md-3 col-lg-3 col-sm-5 panel panel-default">
    <br>
  <div class="col-md-12 col-lg-12 col-sm-12 ">
       <div class="">
        <small>Información Del Clientes</small>          
          <div class="form-group">
                <h3 class="m-b-0 m-t-0 m-t-40 text-center"><%= @sale.client.name %></h3>
          </div>
          <div class="form-group  ">
            <span class="additional-info-wrap">
                <label class="checkbox-inline " for="Checkboxes_Grape">
                    <%= f.check_box :credit, id:"Checkboxes_Grape", checked: true %>
                    <span id="id_credit">A Credito</span>
                </label>
                <div class="additional-info ">
                    <%= f.date_field :credit_expiration, placeholder: "Fecha", class: "form-control" %>
                </div>
            </span>
         </div>
          <hr>
          <h4 id="discount_client_sales">Descuento Max:  <span class="badge badge-info"><%=@sale.client.discount%>% </span></h4>                 
          <hr>          
          <small>Linea de Credito</small>
          <h4>Credito <span class="badge badge-success"><%= @mycompany.get_current_currency.symbol%> <%=@sale.client.credit_limit %></span></h4>
          <h4>Credito disponible<span class="badge badge-warning"><%= @mycompany.get_current_currency.symbol%> <%= @sale.client.line_credit_available %></span></h4>          
       </div>
    </div>

    <div class="col-md-12 col-lg-12 col-sm-12 ">
        <div class="">
            <h4 class="box-title">Dirección</h4>
            <hr>
            <h5><i class="ti-mobile"></i><label id="phones_clients_sales"> <%= @sale.client.phone %> - <%= @sale.client.mobile %></label></h5> <small id="address_client_sale"> <%= @sale.client.address.get_direccion_all %></small>
        </div>
    </div>
    <div class="col-md-12 col-lg-12 col-sm-12 ">
        <hr>
    </div>
  </div>
    <div class="col-md-9 col-lg-9 col-sm-7 ">

        <div class="panel-wrapper collapse in" aria-expanded="true">
            <div class="panel-body">
                <div class="col-md-12 col-lg-12 col-sm-9">
                    <div class="col-xs-3 col-md-3 pull-left">
                        <div class="form-group">
                            <%= f.label :number, "Número" %>
                            <%= f.text_field :number, placeholder: "Número", class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-5 col-md-5">
                        <div class="form-group">
                            <%= f.label :discount, "Descuento en ventas %" %>
                            <%= f.text_field :discount, class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-4 col-md-4 pull-right">
                        <div class="form-group">
                            <%= f.label :date, "Fecha" %>
                            <%= f.date_field :date, placeholder: "Fecha", class: "form-control" %>
                        </div>
                    </div>
                    <div class="col-xs-4 col-md-4 pull-right">
                        <div class="form-group">                            
                            <%= hidden_field :price_list_id, '' %>
                             <%= f.hidden_field :client_id  %>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-9 col-lg-9 col-sm-7 ">
        <div class="panel-wrapper collapse in" aria-expanded="true">
            <div class="panel-body" id="sale-details">
                 <%= (@sale.sale_details.count > 0) ? render(partial: 'table', locals: { sale: @sale, show_actions: true }) : 'No hay detalles cargados' %>
                </div>
                <hr>
                <!-- aqui se debe condicionar para clientes que superan su linea de credito -->
                <div id="action_sale_details_id">
                    <%= link_to 'Atras', sales_path, class: "btn btn-default btn-outline "  %>
                    <% message = (action_name == 'edit') ? "Actualizar" : "Aceptar" %>
                    <%= f.submit message, class: "btn btn-success" %>
                    <%= link_to "Añadir producto", new_sale_sale_detail_path(sale_id: @sale.id), remote: true, class: "btn btn-info pull-right" %>
                </div>                
        </div><hr>
    </div>
 </div>
</div>

<% end %>
<div class="modal fade" id="new-detail-modal" title="Modal"></div>