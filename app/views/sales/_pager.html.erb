<nav>
	<ul class="pager">
		<li class="previous <%= page == 0 ? 'disabled' : '' %>">
			<% if page >=1 %>			
			<%= link_to_if page > 0, "&larr; Anterior".html_safe,
						sales_path(keywords: keywords, page: page - 1, filter: filter) %>
			<% end %>				
		</li>
		<li class="next <%= page == @number_of_pages ? 'disabled' : '' %>">
			<%= link_to_if page < @number_of_pages, "Siguiente &rarr;".html_safe,
						sales_path(keywords: keywords, page: page + 1, filter: filter) %>
		</li>
	</ul>
</nav>