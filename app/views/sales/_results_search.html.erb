<table class="table table-bordered">
  <thead>
      <tr>
 
      <th>N° Recibo</th>
      <th>Fecha</th>
      <th>Cliente</th>
      <th> Estado</th>
      <th>Total</th>
      <th>Saldo</th>
      <th>dis</th>
      <th colspan="1">Opciones</th>
    </tr>
  </thead>

  <tbody>
    <% @sales.each do |sale| %>
      <tr class="<%= status_row_class(sale.payment_status) %>">
     
        <%if  sale.proformas.count > 0 %>
           <th><%= sale.proformas.first.number_recibo %></th>
        <%else%>
        <td></td>
        <%end%>
        <td><%= sale.date.strftime("%d/%m/%Y") %></td>
        <td> <%=sale.client.name %></td>      
        <td><%= status_badge_html(sale.payment_status) %></td>  
        <td><%= number_to_currency(sale.total_final) %></td>
        <td><%= number_to_currency(sale.saldo) %></td>
        <td><%= number_to_percentage(sale.discount_total, precision: 1) %></td>
        <td> <div class="col-md-12">
          <div class="col-md-4">
          <% if can? :read, sale %>
            <%= button_to sale_path(sale), {method: :get, class: "btn btn-success", id:"show_id"} do %>
              <span class="fa fa-eye" aria-hidden="true"> </span> 
            <% end %>
          <% end %></div>
        <div class="col-md-4">
        
           <% if can? :update, sale %>
              <%= button_to edit_sale_path(sale), {method: :get, class: "btn btn-info"} do %>
                <span class=" fas fa-edit" aria-hidden="true"> </span> 
              <% end %>
          <% end %>
        </div>
        <div class="col-md-4">
        
          <% if can? :destroy, sale %>
              <%= button_to sale, { method: :delete, data: { confirm: '¿Está seguro?' }, class: "btn btn-danger" } do %>
                <span class="fas fa-trash" aria-hidden="true"> </span> 
          <% end %>
          <% end %>
        </div>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>  
</table>
<table>
   <thead>
    <tr>
      <%= render partial: "pager", locals: { keywords: @keywords, page: @page, filter: params[:filter] } %>
    </tr>
  </thead>
</table>