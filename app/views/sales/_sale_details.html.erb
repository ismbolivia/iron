 <div class="modal-content">
    <div class="modal-header modal-header-warning"> 
        <button type="button" class="close" data-dismiss="modal" aria-hidden="true"> [ × ] </button>
        <h2><i class="fas fa-box"></i>  Nueva Devolución </h2>
    </div>

 <table class="table">
  <thead>
    <tr>
      <th>Cantidad</th>
      <th>Detalle</th>
      <th>Cantidad</th>
      <th>Obs</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @sale_details.each do |sale_detail| %>
      <tr>
          <td><%= sale_detail.qty %></td>
          <td><%= sale_detail.item.item_description  %></td>
        <% if  sale_detail.devolutions.count > 0 %>
          <td><span class="badge bg-purple">Devolución Efectuado</span> </td>
        <% else %>
          <td>
            <%= link_to 'Devolver', new_devolution_path(sale_detail_id: sale_detail.id), remote: true, class: 'btn btn-warning' %>
          </td>
        <% end %> 
      </tr>
  </div>
    <% end %>
  </tbody>
</table>
