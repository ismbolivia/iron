
<style>
  /* Colores oscuros personalizados para estados */
  .btn-dark-pink, .label-dark-pink { background-color: #831843 !important; color: white !important; border: none; } /* Rosa oscuro */
  .btn-dark-gray, .label-dark-gray { background-color: #334155 !important; color: white !important; border: none; } /* Slate / Plomo oscuro */
  .btn-dark-orange, .label-dark-orange { background-color: #7c2d12 !important; color: white !important; border: none; } /* Naranja quemado / Café */
  .btn-dark-red, .label-dark-red { background-color: #7f1d1d !important; color: white !important; border: none; } /* Rojo oscuro */
  .btn-dark-purple, .label-dark-purple { background-color: #581c87 !important; color: white !important; border: none; } /* Púrpura oscuro */
  
  /* Ajuste para los pills cuando están activos */
  .btn-inverse { background-color: #0f172a !important; color: white !important; border: 1px solid #1e293b; }
</style>

<div class="row">
  <div class="col-md-12">
    <div class="white-box" style="border: none; border-radius: 16px; box-shadow: 0 4px 25px rgba(0,0,0,0.05); padding: 2rem;">
      <div class="d-flex justify-content-between align-items-center mb-4" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid #f1f5f9; padding-bottom: 1.5rem;">
        <h3 class="box-title" style="font-weight: 800; color: #1e293b; margin: 0; font-size: 1.5rem;">
          <i class="fas fa-shopping-cart mr-2" style="color: #6366f1;"></i> Listado de Ventas
        </h3>
        <div style="display: flex; gap: 12px;">
          <%= link_to pos_path, class: "btn-premium-action", style: "background: #10b981; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); border: none;" do %>
            <i class="fas fa-cash-register"></i> Ir al POS
          <% end %>

          <%= link_to clients_path, {method: :get, class: "btn-premium-action btn-indigo", style: "background: #6366f1; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);"} do %>
            <i class="fas fa-plus-circle"></i> Nueva Venta
          <% end %>
        </div>
      </div>

      <div class="row">
        <!-- Buscador -->
        <div class="col-md-5">
          <div style="background: #f8fafc; padding: 1.2rem; border-radius: 12px; border: 1px solid #e2e8f0;">
            <%= render partial: 'layouts/partials/search_sale_form', locals: { search_entity: 'sales', word: "Nro. Nota o Cotización...", view_kamback: '', view_list: '', url_pdf: '', url_csv: '', url_xls: '', url: new_sale_path, ban: false } %>
          </div>
        </div>

        <!-- Filtros de Fecha -->
        <div class="col-md-7 text-right">
          <div style="display: inline-block; background: #f8fafc; padding: 1.2rem; border-radius: 12px; border: 1px solid #e2e8f0; width: 100%;">
            <% content_for :filter do %>
              <div class="form-group mb-0" style="margin-bottom: 0;">
                <select name="filter" id="filters" class="form-control" style="border-radius: 8px; border: 1px solid #cbd5e1; font-weight: 600;">
                  <option value="">Filtrar por Estado...</option>
                  <% Sale.states.keys.each do |state| %>
                    <option value="<%= state %>" <%= 'selected' if params[:filter] == state %>><%= t("activerecord.attributes.sale.states.#{state}") %></option>
                  <% end %>
                </select>
              </div>
            <% end %>
            <%= render partial: 'layouts/partials/report_form', locals: { report_entity: 'report', state: '' } %>
          </div>
        </div>
      </div>

      <!-- Pills de Filtros Rápidos -->
      <div class="filter-pills-container" style="margin: 2rem 0; display: flex; flex-wrap: wrap; gap: 10px; padding: 1rem; background: #f1f5f9; border-radius: 12px;">
        <%= link_to sales_path(filter: nil), class: "btn btn-sm #{(params[:filter].blank? ? 'btn-inverse' : 'btn-default')}", style: "border-radius: 20px; font-weight: 700; padding: 6px 15px;" do %>
           TODOS
        <% end %>
        
        <% Sale::PAYMENT_STATUSES.values.uniq.each do |status| %>
          <% 
            active = params[:filter] == status
            # Restaurando la clase de color original
            specific_color_class = status_color_class(status)
            btn_class = active ? "btn-inverse" : specific_color_class
          %>
          <%= link_to sales_path(filter: status, data_init: @data_init, data_limit: @data_limit), class: "btn btn-sm #{btn_class}", style: "border-radius: 20px; font-weight: 700; padding: 6px 15px; #{(active ? '' : 'color: white;')}" do %>
            <%= status.upcase %>
          <% end %>
        <% end %>
      </div>

      <div id="sales-results">
        <%= render partial: 'results_search' %>
      </div>
    </div>
  </div>
</div>

<script>
  var ranges = {
    "Hoy": [moment(), moment()],
    "Últimos 7 días": [moment().subtract(6, 'days'), moment()],
    "Últimos 30 días": [moment().subtract(29, 'days'), moment()],
    "Este mes": [moment().startOf('month'), moment().endOf('month')],
    "Mes pasado": [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')],
    "Este año": [moment().startOf('year'), moment().endOf('year')]
  };

  $('input[name="dateranges"]').daterangepicker({
      startDate: moment("<%= l @data_init, format:'%Y-%m-%d' %>"),
      endDate: moment("<%= l @data_limit, format:'%Y-%m-%d' %>"),
      ranges: ranges,
      alwaysShowCalendars: true,
      locale: {
        format: 'DD/MM/YYYY',
        applyLabel: 'Aplicar',
        cancelLabel: 'Cancelar',
        fromLabel: 'Desde',
        toLabel: 'Hasta',
        customRangeLabel: 'Personalizado'
      }
  }, function(start, end, label){
    $("#data_init").val(start.format('YYYY-MM-DD'));
    $("#data_limit").val(end.format('YYYY-MM-DD'));
  });
</script>
