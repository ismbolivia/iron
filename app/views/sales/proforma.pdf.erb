          <p>Sub total: <%=@mycompany.get_current_currency.symbol %><%= @sale.sub_total_before_devolution %> </p>
          <p>Descuentos(<%= number_to_percentage(@sale.discount_total, precision: 1) %>): <%= @mycompany.get_current_currency.symbol%><%= (@sale.duscount_mount_all_final) %></p>
          <p><b>Total parcial :</b> <%= @mycompany.get_current_currency.symbol%><%= (@sale.total_final_afther) %></p> 
        
      </div>
  </div>
