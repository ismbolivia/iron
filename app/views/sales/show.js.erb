var pdfUrl = "<%= j(note_sale_sale_path(@sale, format: :pdf)) %>";
var title = "<%= @sale.quoted? ? 'Cotización' : 'Nota de Venta' %>: <%= j(@sale.number.to_s) %>";
var iconClass = "<%= @sale.quoted? ? 'fas fa-file-invoice' : 'fas fa-file-pdf' %>";
var headerGradient = "<%= @sale.quoted? ? 'linear-gradient(135deg, #831843 0%, #9d174d 100%)' : 'linear-gradient(135deg, #1e1b4b 0%, #312e81 100%)' %>";
var primaryColor = "<%= @sale.quoted? ? '#db2777' : '#4338ca' %>";

var modalHtml = '<div class="modal-dialog modal-lg" style="width: 90%; max-width: 1200px;">' +
                '  <div class="modal-content" style="border-radius: 20px; overflow: hidden; border: none; box-shadow: 0 20px 50px rgba(0,0,0,0.2);">' +
                '    <div class="modal-header" style="background: ' + headerGradient + '; color: white; padding: 1.5rem 2rem; border: none;">' +
                '      <button type="button" class="close" data-dismiss="modal" style="color: white; opacity: 1; font-size: 2rem;">&times;</button>' +
                '      <h4 class="modal-title" style="font-weight: 800; display: flex; align-items: center; gap: 1rem;">' +
                '        <i class="' + iconClass + '"></i> ' + title +
                '      </h4>' +
                '    </div>' +
                '    <div class="modal-body" style="padding: 0; background: #f1f5f9; height: 80vh;">' +
                '      <iframe src="' + pdfUrl + '" style="width: 100%; height: 100%; border: none;"></iframe>' +
                '    </div>' +
                '    <div class="modal-footer" style="background: white; border-top: 1px solid #e2e8f0; padding: 1rem 2rem;">' +
                '      <button type="button" class="btn btn-default" data-dismiss="modal" style="border-radius: 10px; font-weight: 700; padding: 0.6rem 1.5rem;">Cerrar</button>' +
                '      <a href="' + pdfUrl + '" target="_blank" class="btn btn-primary" style="background: ' + primaryColor + '; border: none; border-radius: 10px; font-weight: 700; padding: 0.6rem 1.5rem;">' +
                '        <i class="fas fa-external-link-alt mr-2"></i> Abrir en Pantalla Completa' +
                '      </a>' +
                '    </div>' +
                '  </div>' +
                '</div>';

$("#new-pdf-modal").html(modalHtml).modal("show");
