<div class="row bg-title">
    <div class="col-lg-5 col-md-5 col-sm-5 col-xs-12">
        <h4 class="page-title">📊 Resumen de Rentabilidad y Resultados <small>(Desde: <%= @desde.strftime("%d/%m/%Y") %> | Hasta: <%= @hasta.strftime("%d/%m/%Y") %>)</small></h4>
    </div>
    <div class="col-lg-7 col-sm-7 col-md-7 col-xs-12">
        <ol class="breadcrumb">
            <li><a href="/">Dashboard</a></li>
            <li class="active">Rentabilidad</li>
        </ol>
    </div>
</div>

<!-- 🔍 Barra de Filtros -->
<div class="row">
    <div class="col-sm-12">
        <div class="white-box">
            <%= form_tag sales_profitability_report_path, method: :get, class: 'form-inline' do %>
                <div class="form-group m-r-10">
                    <label class="control-label">👤 Vendedor</label><br>
                    <%= select_tag :vendedor_id, options_from_collection_for_select(User.all, :id, :name, @vendedor_id), prompt: 'Todos', class: 'form-control input-sm' %>
                </div>

                <div class="form-group m-r-10">
                    <label class="control-label">📅 Desde</label><br>
                    <%= date_field_tag :desde, @desde, class: 'form-control input-sm' %>
                </div>

                <div class="form-group m-r-10">
                    <label class="control-label">📅 Hasta</label><br>
                    <%= date_field_tag :hasta, @hasta, class: 'form-control input-sm' %>
                </div>

                <div class="form-group m-t-20">
                    <button type="submit" class="btn btn-info btn-sm"><i class="fa fa-search"></i> Calcular</button>
                </div>
            <% end %>
        </div>
    </div>
</div>

<!-- 🏆 Fila 1: Ingresos y Costos de Ventas -->
<div class="row">
    <div class="col-lg-4 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #707cd2; color: white; border-radius: 12px; padding: 25px;">
            <h3 class="text-white">💰 Total Ventas</h3>
            <ul class="list-inline m-t-15 text-white">
                <li><i class="fa fa-shopping-cart fa-3x"></i></li>
                <li class="text-right m-l-15"><h2 class="text-white" style="font-weight: 800; font-size: 2.5rem;">$ <%= '%.2f' % @total_ventas %></h2></li>
            </ul>
        </div>
    </div>
    <div class="col-lg-4 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #f19f4d; color: white; border-radius: 12px; padding: 25px;">
            <h3 class="text-white">📦 Costo de Ventas (COGS)</h3>
            <ul class="list-inline m-t-15 text-white">
                <li><i class="fa fa-tags fa-3x"></i></li>
                <li class="text-right m-l-15"><h2 class="text-white" style="font-weight: 800; font-size: 2.5rem;">$ <%= '%.2f' % @total_costo_mercaderia %></h2></li>
            </ul>
        </div>
    </div>
    <div class="col-lg-4 col-sm-12 col-xs-12">
        <div class="white-box" style="background: #4caf50; color: white; border-radius: 12px; padding: 25px;">
            <h3 class="text-white">🟢 Utilidad Bruta</h3>
            <ul class="list-inline m-t-15 text-white">
                <li><i class="fa fa-arrow-up fa-3x"></i></li>
                <li class="text-right m-l-15"><h2 class="text-white" style="font-weight: 800; font-size: 2.5rem;">$ <%= '%.2f' % @utilidad_bruta %></h2></li>
            </ul>
        </div>
    </div>
</div>

<!-- 🏆 Fila 2: Gastos Operativos -->
<div class="row">
    <div class="col-lg-4 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #f44336; color: white; border-radius: 12px; padding: 20px;">
            <h4 class="text-white">🔴 Gastos Operativos Totales</h4>
            <ul class="list-inline m-t-10 text-white">
                <li><i class="fa fa-calculator fa-2x"></i></li>
                <li class="text-right m-l-15"><h3 class="text-white" style="font-weight: 700;">$ <%= '%.2f' % @total_gastos %></h3></li>
            </ul>
        </div>
    </div>
    <div class="col-lg-4 col-sm-6 col-xs-12">
        <div class="white-box" style="background: #4c5667; color: white; border-radius: 12px; padding: 20px;">
            <h4 class="text-white">📌 Gastos Fijos</h4>
            <ul class="list-inline m-t-10 text-white">
                <li><i class="fa fa-thumb-tack fa-2x"></i></li>
                <li class="text-right m-l-15"><h3 class="text-white" style="font-weight: 700;">$ <%= '%.2f' % @total_gastos_fijos %></h3></li>
            </ul>
        </div>
    </div>
    <div class="col-lg-4 col-sm-12 col-xs-12">
        <div class="white-box" style="background: #00bcd4; color: white; border-radius: 12px; padding: 20px;">
            <h4 class="text-white">📈 Gastos Variables</h4>
            <ul class="list-inline m-t-10 text-white">
                <li><i class="fa fa-line-chart fa-2x"></i></li>
                <li class="text-right m-l-15"><h3 class="text-white" style="font-weight: 700;">$ <%= '%.2f' % @total_gastos_variables %></h3></li>
            </ul>
        </div>
    </div>
</div>

<!-- 🏆 Fila 3: Resultados Finales -->
<div class="row">
    <div class="col-md-12">
        <div class="white-box" style="text-align: center; padding: 3.5rem; border-radius: 15px; border: 2px solid <%= @utilidad_neta >= 0 ? '#bbf7d0' : '#fecaca' %>;">
            <h2 class="box-title" style="font-weight: 800; font-size: 1.5rem; text-transform: uppercase;">📊 Estado de Resultados (Cierre Neto Real)</h2>
            <hr style="border-color: #f1f5f9; margin-bottom: 25px;">
            
            <span style="font-size: 1.1rem; color: #64748b; font-weight: 700; display: block; margin-bottom: 8px;">UTILIDAD NETA DISPONIBLE</span>
            
            <div style="font-size: 3.5rem; font-weight: 900; color: <%= @utilidad_neta >= 0 ? '#10b981' : '#ef4444' %>; text-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                $ <%= '%.2f' % @utilidad_neta %>
            </div>
            
            <p class="text-muted" style="margin-top: 15px; font-size: 0.95rem;">
               <i class="fa fa-info-circle"></i> Cálculo definitivo cruzando <strong>Ventas Confirmadas</strong> (-) <strong>Costos Landed asignados</strong> (-) <strong>Gastos Generales cargados en caja</strong>.
            </p>
        </div>
    </div>
</div>

<!-- 📊 Desglose de Gastos por Categoría -->
<div class="row">
    <div class="col-md-12">
        <div class="white-box" style="border-radius: 12px;">
            <h3 class="box-title">📊 Desglose de Operativos por Categoría</h3>
            <p class="text-muted">Asignación de egresos durante el rango de fechas seleccionado.</p>
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th>Categoría</th>
                            <th>Monto Gastado ($)</th>
                            <th>Porcentaje del Total Gastos</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if @expenses_by_category.any? %>
                            <% @expenses_by_category.each do |cat, amount| %>
                                <tr>
                                    <td><strong><%= cat.to_s.gsub('_', ' ').capitalize %></strong></td>
                                    <td style="font-weight: 800; color: #1e293b;">$ <%= '%.2f' % amount %></td>
                                    <td>
                                        <% pct = @total_gastos > 0 ? (amount / @total_gastos * 100).round(2) : 0 %>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <div style="background: #e2e8f0; border-radius: 8px; width: 100%; height: 10px; overflow: hidden;">
                                                <div style="background: #3b82f6; width: <%= pct %>%; height: 100%;"></div>
                                            </div>
                                            <span style="font-weight: 700;"><%= pct %>%</span>
                                        </div>
                                    </td>
                                </tr>
                            <% end %>
                        <% else %>
                            <tr><td colspan="3" class="text-center text-muted">No hay gastos operativos para este periodo.</td></tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
