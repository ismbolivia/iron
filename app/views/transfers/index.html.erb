<div class="row bg-title">
  <div class="col-lg-3 col-md-4 col-sm-4 col-xs-12">
    <h4 class="page-title">Módulo de Traspasos</h4>
  </div>
  <div class="col-lg-9 col-sm-8 col-md-8 col-xs-12">
    <%= link_to 'Nuevo Traspaso', new_transfer_path, class: "btn btn-info pull-right m-l-20 hidden-xs hidden-sm waves-effect waves-light" %>
  </div>
</div>

<div class="row">
  <div class="col-sm-12">
    <div class="white-box">
      <h3 class="box-title">Historial de Traspasos entre Sucursales</h3>
      <p class="text-muted">Gestione los envíos de mercadería de un almacén a otro</p>
      
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>Fecha Envío</th>
              <th>Sucursal Origen</th>
              <th>Sucursal Destino</th>
              <th>Estado</th>
              <th>Enviado Por</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>

          <tbody>
            <% @transfers.order(created_at: :desc).each do |transfer| %>
              <tr>
                <td>T-<%= transfer.id.to_s.rjust(5, '0') %></td>
                <td><%= transfer.date.strftime("%d/%m/%Y") if transfer.date %></td>
                <td>
                  <span class="label label-danger"><%= transfer.origin_branch&.name || 'Desconocida' %></span>
                </td>
                <td>
                  <span class="label label-success"><%= transfer.destination_branch&.name || 'Desconocida' %></span>
                </td>
                <td>
                  <% if transfer.in_transit? %>
                    <span class="label label-warning"><i class="fas fa-truck"></i> En Tránsito</span>
                  <% elsif transfer.received? %>
                    <span class="label label-info"><i class="fas fa-check-circle"></i> Recibido</span>
                  <% else %>
                    <span class="label label-danger"><i class="fas fa-times"></i> Cancelado</span>
                  <% end %>
                </td>
                <td><%= transfer.user&.name || transfer.user&.email %></td>
                <td class="text-center">
                  <%= link_to transfer, class: "btn btn-sm btn-info", title: "Ver Detalle" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <% if transfer.in_transit? %>
                    <%= link_to edit_transfer_path(transfer), class: "btn btn-sm btn-warning", title: "Editar" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
