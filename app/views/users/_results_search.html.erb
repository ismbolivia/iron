<div class="white-box">
    <div class="table-responsive">
            <table class="table product-overview">
              <thead>
                <tr>
                  <%= render partial: "pager", locals: { keywords: @keywords, page: @page } %>
                </tr>
                <tr>
                  <th>Imagen</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Rol</th>
                  <th>Sucursal</th>
                  <th>Fecha de Alta</th>
                  <th>Fecha de Modificación</th>
                  <th colspan="2"></th>
                </tr>
              </thead>

              <tbody>
                <% @users.each do |user| %>
                  <tr>
                    <td> 
            <%= image_tag(user.avatar.thumb.url, :alt => "user-img", width: "80",  height: "60") %>
                    </td>
                    <td><%= user.name %></td>
                    <td><%= user.email  %></td>
                    <td><span class="label label-info"><%= user.rol.name %></span></td>
                    <td>
                      <% if user.branch %>
                        <span class="label label-success"><%= user.branch.name %></span>
                      <% else %>
                        <span class="label label-default">Todas (Global)</span>
                      <% end %>
                    </td>
                    <td><%= user.created_at.strftime("%d/%m/%Y") %></td>
                    <td><%= user.updated_at.strftime("%d/%m/%Y") %></td>
                    <td>
                      <%= button_to edit_user_path(user), {method: :get, class: "btn btn-info"} do %>
                        <span class="glyphicon glyphicon-pencil" aria-hidden="true"> </span> 
                      <% end %>
                    </td>
                 
                  </tr>
                <% end %>
              </tbody>
            </table>
      </div>     
</div>