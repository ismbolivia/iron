
<!DOCTYPE html>
<html>
<head>
  <title>Almacen</title>
  <meta charset='utf-8' />
    <%= wicked_pdf_stylesheet_link_tag "pdf/pdf" %>
</head>
	<body>
	   <div class="col-md-12">
	 	<div class=" printableArea">	        	
	        <div class="row">
			  <table class="table product-overview table-bordered ">
			    <thead class="conf-pdf">
			    	<tr><th colspan="6" class="center">
				         	<h3><b><%=@title %></b> </h3>
				        </th>
				    </tr>
				      <th class="center">Código</th>
	                  <th class="center">Nombre</th>
	                  <th class="center">Descripción</th>
	                  <th class="center">Unidad</th>
	                  <th class="center">Stock</th>
	           
	                  <th class="center">Categoría</th>
	                 <!--  <th>Almacen</th> -->
	                  <th class="center">Precio</th>
	                  
	                </tr>
				     </thead>
				     <tbody>
				        <% @warehouse_items.each do |wi| %>
				      
				     <tr>
                    <td><%= wi.code %></td>
                    <td><%= wi.name  %></td>
                    <td><%= wi.item_description %></td>                   
                    <td><%= wi.unit ? wi.unit.name : '' %></td>
                    <td><%= wi.get_total_stock %></td>               
                    <td><%= wi.category ? wi.category.name : '' %></td>                    
                    <td><%= number_to_currency(wi.price) %></td>                  
                    
                  </tr>
				    <% end %>
				    <tr><th colspan="5"  class="text-center">
				         	<span><b>Valor total en inventario: </b> </span>
				        </th>
				         <th><%= @mycompany.get_current_currency.symbol%> </th>
				         
				       
				    </tr>
				  </tbody>
				</table>			    
			</div>
		</div>
	</div>

</body>
	
</html>
